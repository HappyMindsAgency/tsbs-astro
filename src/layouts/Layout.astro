---
import Head from "../components/Head.astro";
import '../styles/globals.scss';

const { entita, documentId, lang = 'it' } = Astro.props;
---
<!DOCTYPE html>
<html lang={lang}>
    <Head entita={entita} documentId={documentId} lang={lang} />

    <body
        data-bs-smooth-scroll="true"
        data-page-lang={lang ?? 'it'}
        data-page-entity={entita ?? ''}
        data-page-document-id={documentId ?? ''}
        data-page-pathname={Astro.url.pathname}
    >
        <slot />

        <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>
	    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.min.js" integrity="sha384-RuyvpeZCxMJCqVUGFI0Do1mQrods/hhxYlcVfGPOfQtPJh0JCw12tUAZ/Mv10S7D" crossorigin="anonymous"></script>
    </body>
</html>
    
