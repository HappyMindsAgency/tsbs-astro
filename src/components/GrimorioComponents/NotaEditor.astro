---
import NotaModal from '../PopupComponents/NotaModal.astro';
import ConfermaEliminaNota from '../toastComponents/ConfermaEliminaNota.astro';
import LoadNotaError from '../toastComponents/LoadNotaError.astro';
import LoadNotaOk from '../toastComponents/LoadNotaOk.astro';

interface Props {
	missioneSlug?: string;
	titleValue?: string;
	/** HTML della nota esistente da precaricare nell'editor (vuoto per una nuova nota). */
	bodyValue?: string;
	/** documentId della nota esistente: se presente, il salvataggio aggiorna invece di creare. */
	noteDocumentId?: string;
	/** Slug Categoria Grimorio ricevuto da Strapi: "salvata" oppure "inviata". */
	categorySlug?: string | null;
}

const {
	missioneSlug = '',
	titleValue = '',
	bodyValue = '',
	noteDocumentId = '',
	categorySlug = '',
} = Astro.props as Props;
---

<section
	class="note-editor"
	aria-labelledby="note-editor-title"
	data-note-editor
	data-note-missione-slug={missioneSlug}
	data-note-document-id={noteDocumentId}
	data-note-category-slug={categorySlug ?? ''}
>
	<div class="note-editor__head">
		<label class="visually-hidden" for="note-title-input">Titolo della nota</label>
		<input
			id="note-title-input"
			class="note-editor__title"
			type="text"
			value={titleValue}
			autocomplete="off"
			placeholder="Titolo della nota"
			data-note-title
		/>
		<button class="note-editor__icon-button" type="button" aria-label="Elimina nota" data-note-delete hidden={!noteDocumentId}>
			<i class="bi bi-trash" aria-hidden="true"></i>
		</button>
	</div>

	<div class="note-editor__toolbar" role="toolbar" aria-label="Formattazione nota">
		<div class="note-editor__button-group" aria-label="Stile testo">
			<button type="button" data-command="bold" aria-label="Grassetto" aria-pressed="false">
				<i class="bi bi-type-bold" aria-hidden="true"></i>
			</button>
			<button type="button" data-command="italic" aria-label="Corsivo" aria-pressed="false">
				<i class="bi bi-type-italic" aria-hidden="true"></i>
			</button>
		</div>

		<div class="note-editor__button-group" aria-label="Liste">
			<button type="button" data-command="insertUnorderedList" aria-label="Elenco puntato" aria-pressed="false">
				<i class="bi bi-list-ul" aria-hidden="true"></i>
			</button>
			<button type="button" data-command="insertOrderedList" aria-label="Elenco numerato" aria-pressed="false">
				<i class="bi bi-list-ol" aria-hidden="true"></i>
			</button>
		</div>
	</div>

	<div
		id="note-editor-title"
		class="note-editor__body"
		contenteditable="true"
		role="textbox"
		aria-label="Testo della nota"
		aria-multiline="true"
		data-placeholder="Scrivi qui le tue annotazioni"
		data-note-body
		set:html={bodyValue}
	></div>

	<p class="note-editor__feedback" data-note-feedback hidden></p>

	<div class="note-editor__actions">
		<button class="btn tsbs-cta-primary-soft note-editor__button" type="button" data-note-save>Salva nota</button>
		<button class="btn tsbs-cta-primary note-editor__button" type="button" data-note-submit>
			<span data-note-submit-label>Invia al Prefetto</span>
			<span class="note-editor__button-loader" data-note-submit-loader hidden aria-hidden="true"></span>
		</button>
	</div>
</section>

<NotaModal renderHidden />
<ConfermaEliminaNota renderHidden />
<LoadNotaOk renderHidden />
<LoadNotaError renderHidden />

<script>
	const setupNotaEditors = () => {
		document.querySelectorAll<HTMLElement>('[data-note-editor]').forEach((editor) => {
			if (editor.dataset.noteEditorReady === 'true') return;
			editor.dataset.noteEditorReady = 'true';

			const missioneSlug = editor.dataset.noteMissioneSlug || '';
			const titleInput = editor.querySelector<HTMLInputElement>('[data-note-title]');
			const bodyEditor = editor.querySelector<HTMLElement>('[data-note-body]');
			const saveButton = editor.querySelector<HTMLButtonElement>('[data-note-save]');
			const submitButton = editor.querySelector<HTMLButtonElement>('[data-note-submit]');
			const submitLabel = editor.querySelector<HTMLElement>('[data-note-submit-label]');
			const submitLoader = editor.querySelector<HTMLElement>('[data-note-submit-loader]');
			const deleteButton = editor.querySelector<HTMLButtonElement>('[data-note-delete]');
			const feedback = editor.querySelector<HTMLElement>('[data-note-feedback]');
			const commandButtons = editor.querySelectorAll<HTMLButtonElement>('[data-command]');
			let isSubmitted = editor.dataset.noteCategorySlug === 'inviata';
			let isPending = false;

			const getPlainBody = () => bodyEditor?.textContent?.replace(/\s+/g, ' ').trim() || '';

			const getNotePayload = () => ({
				title: titleInput?.value.trim() || '',
				body: bodyEditor?.innerHTML || '',
				plainBody: getPlainBody(),
				noteDocumentId: editor.dataset.noteDocumentId || '',
			});

			const setFeedback = (message: string, type: 'success' | 'error' = 'success') => {
				if (!feedback) return;
				feedback.textContent = message;
				feedback.dataset.noteFeedbackType = type;
				feedback.hidden = false;
			};

			const clearFeedback = () => {
				if (!feedback) return;
				feedback.textContent = '';
				feedback.hidden = true;
			};

			const setPending = (pending: boolean, showSubmitLoader = false) => {
				isPending = pending;
				if (saveButton) saveButton.disabled = pending || isSubmitted;
				if (submitButton) submitButton.disabled = pending || isSubmitted;
				if (deleteButton) deleteButton.disabled = pending;
				if (submitLoader) submitLoader.hidden = !(pending && showSubmitLoader);
				if (submitLabel) submitLabel.textContent = pending && showSubmitLoader ? 'Invio in corso' : 'Invia al Prefetto';
			};

			const setSubmittedState = () => {
				isSubmitted = true;
				if (titleInput) titleInput.readOnly = true;
				if (bodyEditor) bodyEditor.contentEditable = 'false';
				commandButtons.forEach((button) => {
					button.disabled = true;
				});
				if (saveButton) saveButton.disabled = true;
				if (submitButton) submitButton.disabled = true;
			};

			const persistDraft = async (action: 'draft' | 'submit') => {
				if (isPending) return null;

				const note = getNotePayload();
				clearFeedback();

				if (!note.plainBody) {
					setFeedback('Scrivi una nota prima di salvarla.', 'error');
					return null;
				}

				setPending(true, action === 'submit');
				if (action === 'submit') {
					document.dispatchEvent(new CustomEvent('tsbs:load-nota-clear'));
				}

				try {
					const response = await fetch('/api/grimorio/note', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({
							title: note.title,
							body: note.body,
							action,
							missioneSlug,
							noteDocumentId: note.noteDocumentId,
						}),
					});
					const payload = await response.json().catch(() => null);

					if (!response.ok) {
						throw new Error(payload?.message || payload?.error || 'Salvataggio non riuscito.');
					}

					if (payload?.noteDocumentId) {
						editor.dataset.noteDocumentId = payload.noteDocumentId;
						if (deleteButton) deleteButton.hidden = false;
					}

					if (payload?.categorySlug) {
						editor.dataset.noteCategorySlug = payload.categorySlug;
					}

					// Trofei confermati dal server al completamento missione: coda modale.
					const trofei = Array.isArray(payload?.trofeiSbloccati) ? payload.trofeiSbloccati : [];
					if (trofei.length > 0) {
						document.dispatchEvent(new CustomEvent('tsbs:trofei-sbloccati', { detail: { trofei } }));
					}

					if (payload?.missionCompleted && action === 'submit') {
						setFeedback('Nota inviata al Prefetto. Missione superata.');
					} else if (payload?.missionCompleted) {
						setFeedback('Nota salvata. Missione superata.');
					} else {
						setFeedback(action === 'submit' ? 'Nota inviata al Prefetto.' : 'Nota salvata.');
					}

					if (action === 'submit') {
						setSubmittedState();
						document.dispatchEvent(new CustomEvent('tsbs:load-nota-ok-open'));
					}

					return payload;
				} catch (error) {
					setFeedback(error instanceof Error ? error.message : 'Salvataggio non riuscito.', 'error');
					if (action === 'submit') {
						document.dispatchEvent(new CustomEvent('tsbs:load-nota-error-open'));
					}
					return null;
				} finally {
					setPending(false);
				}
			};

			const deleteCurrentNote = async () => {
				if (isPending) return;

				const noteDocumentId = editor.dataset.noteDocumentId || '';
				if (!noteDocumentId) {
					if (titleInput) titleInput.value = 'Titolo della nota';
					if (bodyEditor) bodyEditor.innerHTML = '';
					clearFeedback();
					updatePlaceholder();
					return;
				}

				setPending(true);
				clearFeedback();

				try {
					const response = await fetch('/api/grimorio/note', {
						method: 'DELETE',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ noteDocumentId }),
					});
					const payload = await response.json().catch(() => null);

					if (!response.ok) {
						throw new Error(payload?.message || payload?.error || 'Eliminazione non riuscita.');
					}

					window.location.assign('/scrivania/grimorio/');
				} catch (error) {
					setFeedback(error instanceof Error ? error.message : 'Eliminazione non riuscita.', 'error');
				} finally {
					setPending(false);
				}
			};

			const updatePlaceholder = () => {
				if (!bodyEditor) return;
				bodyEditor.classList.toggle('is-empty', getPlainBody().length === 0);
			};

			const isSelectionInsideBody = () => {
				if (!bodyEditor) return false;
				const selection = document.getSelection();
				const anchorNode = selection?.anchorNode;
				if (!anchorNode) return document.activeElement === bodyEditor;

				return bodyEditor.contains(anchorNode.nodeType === Node.ELEMENT_NODE ? anchorNode : anchorNode.parentNode);
			};

			const updateCommandStates = () => {
				const isInBody = isSelectionInsideBody();

				commandButtons.forEach((button) => {
					const command = button.dataset.command || '';
					let isActive = false;

					if (isInBody && command) {
						try {
							isActive = document.queryCommandState(command);
						} catch {
							isActive = false;
						}
					}

					button.classList.toggle('is-active', isActive);
					button.setAttribute('aria-pressed', String(isActive));
				});
			};

			const scheduleCommandStateUpdate = () => {
				window.requestAnimationFrame(updateCommandStates);
			};

			updatePlaceholder();
			updateCommandStates();
			if (isSubmitted) setSubmittedState();

			commandButtons.forEach((button) => {
				button.addEventListener('click', () => {
					const command = button.dataset.command;
					if (!command || !bodyEditor) return;

					bodyEditor.focus();
					document.execCommand(command, false);
					updatePlaceholder();
					scheduleCommandStateUpdate();
				});
			});

			bodyEditor?.addEventListener('input', () => {
				updatePlaceholder();
				scheduleCommandStateUpdate();
			});

			bodyEditor?.addEventListener('keyup', scheduleCommandStateUpdate);
			bodyEditor?.addEventListener('mouseup', scheduleCommandStateUpdate);
			bodyEditor?.addEventListener('focus', scheduleCommandStateUpdate);
			titleInput?.addEventListener('focus', scheduleCommandStateUpdate);
			document.addEventListener('selectionchange', scheduleCommandStateUpdate);

			saveButton?.addEventListener('click', () => {
				void persistDraft('draft');
			});

			submitButton?.addEventListener('click', () => {
				if (isPending || isSubmitted) return;
				document.dispatchEvent(new CustomEvent('tsbs:nota-modal-open'));
			});

			document.addEventListener('tsbs:nota-submit-confirm', async () => {
				await persistDraft('submit');
			});

			deleteButton?.addEventListener('click', () => {
				if (isPending) return;
				document.dispatchEvent(new CustomEvent('tsbs:nota-delete-open'));
			});

			document.addEventListener('tsbs:nota-delete-confirm', () => {
				void deleteCurrentNote();
			});
		});
	};

	document.addEventListener('astro:page-load', setupNotaEditors);
	setupNotaEditors();
</script>
