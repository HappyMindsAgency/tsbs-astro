---
import NotaModal from '../PopupComponents/NotaModal.astro';
import NotaToast from '../toastComponents/NotaToast.astro';

interface Props {
	missioneSlug?: string;
	storageKey?: string;
	titleValue?: string;
	/** HTML della nota esistente da precaricare nell'editor (vuoto per una nuova nota). */
	bodyValue?: string;
	/** documentId della nota esistente: se presente, il salvataggio aggiorna invece di creare. */
	noteDocumentId?: string;
	/** Token per-membro (documentId del Membro) usato per isolare le bozze in localStorage. */
	storageScope?: string;
}

const {
	missioneSlug = '',
	titleValue = 'Titolo della nota',
	bodyValue = '',
	noteDocumentId = '',
	storageScope = '',
	storageKey,
} = Astro.props as Props;

// La chiave localStorage è isolata per Membro (storageScope) per evitare che le
// bozze di un membro restino visibili a un altro sullo stesso browser.
const scope = storageScope || 'anon';
const resolvedStorageKey = storageKey
	?? (missioneSlug
		? `tsbs-grimorio-note-draft-${scope}-${missioneSlug}`
		: noteDocumentId
			? `tsbs-grimorio-note-${scope}-${noteDocumentId}`
			: `tsbs-grimorio-note-nuova-${scope}`);
---

<section
	class="note-editor"
	aria-labelledby="note-editor-title"
	data-note-editor
	data-note-storage-key={resolvedStorageKey}
	data-note-missione-slug={missioneSlug}
	data-note-document-id={noteDocumentId}
>
	<div class="note-editor__head">
		<label class="visually-hidden" for="note-title-input">Titolo della nota</label>
		<input
			id="note-title-input"
			class="note-editor__title"
			type="text"
			value={titleValue}
			autocomplete="off"
			data-note-title
		/>
		<button class="note-editor__icon-button" type="button" aria-label="Elimina nota" data-note-delete>
			<i class="bi bi-trash" aria-hidden="true"></i>
		</button>
	</div>

	<div class="note-editor__toolbar" role="toolbar" aria-label="Formattazione nota">
		<div class="note-editor__button-group" aria-label="Stile testo">
			<button type="button" data-command="bold" aria-label="Grassetto">
				<i class="bi bi-type-bold" aria-hidden="true"></i>
			</button>
			<button type="button" data-command="italic" aria-label="Corsivo">
				<i class="bi bi-type-italic" aria-hidden="true"></i>
			</button>
		</div>

		<div class="note-editor__button-group" aria-label="Liste">
			<button type="button" data-command="insertUnorderedList" aria-label="Elenco puntato">
				<i class="bi bi-list-ul" aria-hidden="true"></i>
			</button>
			<button type="button" data-command="insertOrderedList" aria-label="Elenco numerato">
				<i class="bi bi-list-ol" aria-hidden="true"></i>
			</button>
		</div>
	</div>

	<div
		id="note-editor-title"
		class="note-editor__body"
		contenteditable="true"
		role="textbox"
		aria-label="Testo della nota"
		aria-multiline="true"
		data-placeholder="Scrivi qui le tue annotazioni"
		data-note-body
		set:html={bodyValue}
	></div>

	<p class="note-editor__feedback" data-note-feedback hidden></p>

	<div class="note-editor__actions">
		<button class="btn tsbs-cta-primary-soft note-editor__button" type="button" data-note-save>Salva bozza</button>
		<button class="btn tsbs-cta-primary note-editor__button" type="button" data-note-submit>Invia al Prefetto</button>
	</div>
</section>

<NotaModal renderHidden />
<NotaToast renderHidden />

<script>
	const setupNotaEditors = () => {
		document.querySelectorAll<HTMLElement>('[data-note-editor]').forEach((editor) => {
			if (editor.dataset.noteEditorReady === 'true') return;
			editor.dataset.noteEditorReady = 'true';

			const storageKey = editor.dataset.noteStorageKey || 'tsbs-grimorio-note-draft';
			const missioneSlug = editor.dataset.noteMissioneSlug || '';
			const noteStorage = (() => {
				try {
					return window.localStorage;
				} catch {
					return null;
				}
			})();
			const titleInput = editor.querySelector<HTMLInputElement>('[data-note-title]');
			const bodyEditor = editor.querySelector<HTMLElement>('[data-note-body]');
			const saveButton = editor.querySelector<HTMLButtonElement>('[data-note-save]');
			const submitButton = editor.querySelector<HTMLButtonElement>('[data-note-submit]');
			const deleteButton = editor.querySelector<HTMLButtonElement>('[data-note-delete]');
			const feedback = editor.querySelector<HTMLElement>('[data-note-feedback]');
			const commandButtons = editor.querySelectorAll<HTMLButtonElement>('[data-command]');

			const getPlainBody = () => bodyEditor?.textContent?.replace(/\s+/g, ' ').trim() || '';

			const getDraft = () => ({
				title: titleInput?.value.trim() || '',
				body: bodyEditor?.innerHTML || '',
				plainBody: getPlainBody(),
				noteDocumentId: editor.dataset.noteDocumentId || '',
				updatedAt: new Date().toISOString(),
			});

			const setFeedback = (message: string, type: 'success' | 'error' = 'success') => {
				if (!feedback) return;
				feedback.textContent = message;
				feedback.dataset.noteFeedbackType = type;
				feedback.hidden = false;
			};

			const clearFeedback = () => {
				if (!feedback) return;
				feedback.textContent = '';
				feedback.hidden = true;
			};

			const saveLocalDraft = (status = 'draft') => {
				const draft = { ...getDraft(), status };
				noteStorage?.setItem(storageKey, JSON.stringify(draft));
				return draft;
			};

			const setPending = (pending: boolean) => {
				if (saveButton) saveButton.disabled = pending;
				if (submitButton) submitButton.disabled = pending;
			};

			const setSubmittedState = () => {
				if (titleInput) titleInput.readOnly = true;
				if (bodyEditor) bodyEditor.contentEditable = 'false';
				commandButtons.forEach((button) => {
					button.disabled = true;
				});
				if (saveButton) saveButton.disabled = true;
				if (submitButton) submitButton.disabled = true;
			};

			const persistDraft = async (action: 'draft' | 'submit') => {
				const draft = saveLocalDraft(action);
				clearFeedback();

				if (!draft.plainBody) {
					setFeedback('Scrivi una nota prima di salvarla.', 'error');
					return null;
				}

				setPending(true);

				try {
					const response = await fetch('/api/grimorio/note', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({
							title: draft.title,
							body: draft.body,
							action,
							missioneSlug,
							noteDocumentId: draft.noteDocumentId,
						}),
					});
					const payload = await response.json().catch(() => null);

					if (!response.ok) {
						throw new Error(payload?.message || payload?.error || 'Salvataggio non riuscito.');
					}

					if (payload?.noteDocumentId) {
						editor.dataset.noteDocumentId = payload.noteDocumentId;
						noteStorage?.setItem(storageKey, JSON.stringify({
							...draft,
							noteDocumentId: payload.noteDocumentId,
							status: action,
						}));
					}

					// Trofei confermati dal server al completamento missione: coda modale.
					const trofei = Array.isArray(payload?.trofeiSbloccati) ? payload.trofeiSbloccati : [];
					if (trofei.length > 0) {
						document.dispatchEvent(new CustomEvent('tsbs:trofei-sbloccati', { detail: { trofei } }));
					}

					if (payload?.missionCompleted && action === 'submit') {
						setFeedback('Nota inviata al Prefetto. Missione superata.');
					} else if (payload?.missionCompleted) {
						setFeedback('Nota salvata. Missione superata.');
					} else {
						setFeedback(action === 'submit' ? 'Nota inviata al Prefetto.' : 'Nota salvata.');
					}

					if (action === 'submit') {
						setSubmittedState();
					}

					return payload;
				} catch (error) {
					setFeedback(error instanceof Error ? error.message : 'Salvataggio non riuscito.', 'error');
					return null;
				} finally {
					setPending(false);
				}
			};

			const updatePlaceholder = () => {
				if (!bodyEditor) return;
				bodyEditor.classList.toggle('is-empty', getPlainBody().length === 0);
			};

			// documentId reso dal server (nota esistente): resta sempre la fonte di
			// verità, così una bozza locale non può puntare alla nota di un altro membro.
			const serverDocumentId = editor.dataset.noteDocumentId || '';

			const savedDraft = noteStorage?.getItem(storageKey);
			if (savedDraft) {
				try {
					const draft = JSON.parse(savedDraft);
					if (titleInput && draft.title) titleInput.value = draft.title;
					if (bodyEditor && draft.body) bodyEditor.innerHTML = draft.body;
					if (serverDocumentId) {
						editor.dataset.noteDocumentId = serverDocumentId;
					} else if (draft.noteDocumentId) {
						editor.dataset.noteDocumentId = draft.noteDocumentId;
					}
					if (draft.status === 'submitted') setSubmittedState();
				} catch {
					noteStorage?.removeItem(storageKey);
				}
			}

			updatePlaceholder();

			commandButtons.forEach((button) => {
				button.addEventListener('click', () => {
					const command = button.dataset.command;
					if (!command || !bodyEditor) return;

					bodyEditor.focus();
					document.execCommand(command, false);
					updatePlaceholder();
				});
			});

			bodyEditor?.addEventListener('input', () => {
				updatePlaceholder();
				saveLocalDraft('draft');
			});

			titleInput?.addEventListener('input', () => {
				saveLocalDraft('draft');
			});

			saveButton?.addEventListener('click', () => {
				void persistDraft('draft');
			});

			submitButton?.addEventListener('click', () => {
				document.dispatchEvent(new CustomEvent('tsbs:nota-modal-open'));
			});

			document.addEventListener('tsbs:nota-submit-confirm', async () => {
				const payload = await persistDraft('submit');
				if (payload) {
					document.dispatchEvent(new CustomEvent('tsbs:nota-toast-open'));
				}
			});

			deleteButton?.addEventListener('click', () => {
				if (!editor.dataset.noteDocumentId) {
					setFeedback('La cancellazione delle note salvate non è ancora disponibile.', 'error');
					return;
				}

				const shouldDelete = window.confirm('Eliminare questa nota?');
				if (!shouldDelete) return;

				noteStorage?.removeItem(storageKey);
				delete editor.dataset.noteDocumentId;
				if (titleInput) titleInput.value = 'Titolo della nota';
				if (bodyEditor) bodyEditor.innerHTML = '';
				clearFeedback();
				updatePlaceholder();
			});
		});
	};

	document.addEventListener('astro:page-load', setupNotaEditors);
	setupNotaEditors();
</script>
