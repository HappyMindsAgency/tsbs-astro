---
import Layout from '../../layouts/Layout.astro';
import Nav from '../Nav.astro';
import arboreaPattern from '../../assets/Arborea-pattern-the-secret-bookish-society.webp';
import arcadiaPattern from '../../assets/Arcadia-pattern-the-secret-bookish-society.webp';
import armoniaPattern from '../../assets/Armonia-pattern-the-secret-bookish-society.webp';
import astrariaPattern from '../../assets/Astraria-pattern-the-secret-bookish-society.webp';
import trophyIcon from '../../assets/trofei-icona-scrivania.png';

const {
	lang = 'it',
	academy = 'arborea',
	showBoxCronache = false,
	showUserRank = false,
	useLocalAcademyTheme = true,
} = Astro.props;
const academyKeys  = ['astraria', 'arcadia', 'armonia', 'arborea'] as const;
type AcademyTheme = typeof academyKeys[number];
const isAcademyTheme = (value: unknown): value is AcademyTheme => {
	return typeof value === 'string' && academyKeys.includes(value as AcademyTheme);
}

const academyTheme: AcademyTheme = isAcademyTheme(academy) ? academy : 'arborea';

const academyPatterns: Record<AcademyTheme, typeof arboreaPattern> = {
	astraria: astrariaPattern,
	arcadia: arcadiaPattern,
	armonia: armoniaPattern,
	arborea: arboreaPattern,
};
const academyPattern = academyPatterns[academyTheme];

const localAcademyThemeClass = useLocalAcademyTheme ? ` theme-${academyTheme}` : '';
const localAcademyPatternStyle = useLocalAcademyTheme ? `--tsbs-page-pattern-image: url(${academyPattern.src});` : undefined;
const profileHref = '/scrivania/utenti-preferiti/esploso-profilo-utente/';

// Binding futuro:
// showBoxCronache e showUserRank dovranno essere true solo quando l'accademia
// mostrata coincide con quella dell'utente loggato.
const currentRankingRow = { position: '24', initials: 'Tu', name: 'Adepto Mario', points: 24 };

const rankingRows = [
	{ position: 'I', medal: 'gold', initials: 'G', name: 'Adepto 1', points: 50 },
	{ position: 'II', medal: 'silver', initials: 'L', name: 'Adepto 2', points: 45 },
	{ position: 'III', medal: 'bronze', initials: 'S', name: 'Adepto 3', points: 43 },
	{ position: '4', initials: 'M', name: 'Adepto 4', points: 39 },
	{ position: '5', initials: 'G', name: 'Adepto 5', points: 37 },
	{ position: '6', initials: 'G', name: 'Adepto 6', points: 35 },
	{ position: '7', initials: 'L', name: 'Adepto 7', points: 32 },
	{ position: '8', initials: 'L', name: 'Adepto 8', points: 31 },
	{ position: '9', initials: 'S', name: 'Adepto 9', points: 30 },
	{ position: '10', initials: 'S', name: 'Adepto 10', points: 30 },
	{ position: '11', initials: 'M', name: 'Adepto 11', points: 30 },
	{ position: '12', initials: 'M', name: 'Adepto 12', points: 29 },
	{ position: '13', initials: 'L', name: 'Adepto 13', points: 28 },
	{ position: '14', initials: 'G', name: 'Adepto 14', points: 27 },
];

const chronicleRows = [
	{ meta: 'OGGI • ADEPTO 3' },
	{ meta: 'IERI • ADEPTO 15' },
	{ meta: 'LUN • ADEPTO 8' },
];
---

<Layout lang={lang}>
	<Nav lang={lang} />

	<main class={`tsbs-app-shell academy-page academy-ranking-page${localAcademyThemeClass}`} data-academy={academyTheme} style={localAcademyPatternStyle}>
		<header class="missions-header academy-ranking-header">
			<h1>Classifica</h1>
		</header>

		<div class="container-xl tsbs-app-container academy-ranking-page__content">
			<p class="academy-ranking-intro">Aenean placerat eros turpis, nec posuere massa fermentum malesuada. Morbi at est et tortor laoreet placerat id in neque. Maecenas vel erat lacinia, sodales ipsum id.</p>

			<section class="academy-section" aria-labelledby="academy-ranking-title">
				<h2 id="academy-ranking-title" class="tsbs-section-title">Classifica</h2>

				<div class="academy-ranking-list">
					{rankingRows.map((row, index) => (
						<a class={`academy-ranking-card ${index > 12 ? 'is-hidden' : ''}`} href={profileHref} data-academy-ranking-card>
							<div class="academy-ranking-card__position">
								{row.medal ? (
									<img
										class={`academy-ranking-card__medal-icon is-${row.medal}`}
										src={trophyIcon.src}
										width={trophyIcon.width}
										height={trophyIcon.height}
										alt=""
										aria-hidden="true"
										loading="lazy"
										decoding="async"
									/>
								) : (
									<span>{row.position}</span>
								)}
								<span class={`academy-ranking-card__roman ${row.medal ? `is-${row.medal}` : ''}`}>{row.medal ? row.position : ''}</span>
							</div>
							<div class="academy-ranking-card__avatar" aria-hidden="true">{row.initials}</div>
							<p class="academy-ranking-card__name">{row.name}</p>
							<p class="academy-ranking-card__points">
								<strong>{row.points}</strong>
								<i class="bi bi-trophy" aria-hidden="true"></i>
							</p>
						</a>
					))}

					{showUserRank && (
						<a class="academy-ranking-card is-current" href={profileHref} data-academy-ranking-card>
							<div class="academy-ranking-card__position">
								<span>{currentRankingRow.position}</span>
								<span class="academy-ranking-card__roman"></span>
							</div>
							<div class="academy-ranking-card__avatar" aria-hidden="true">{currentRankingRow.initials}</div>
							<p class="academy-ranking-card__name">{currentRankingRow.name}</p>
							<p class="academy-ranking-card__points">
								<strong>{currentRankingRow.points}</strong>
								<i class="bi bi-trophy" aria-hidden="true"></i>
							</p>
						</a>
					)}
				</div>

				<div class="academy-ranking-load-more-row d-lg-flex justify-content-lg-end">
					<button class="missions-load-more academy-ranking-load-more" type="button" data-ranking-load-more aria-controls="academy-ranking-title">
						<span>Carica altro</span>
						<i class="bi bi-arrow-right" aria-hidden="true"></i>
					</button>
				</div>
			</section>

			{showBoxCronache && (
				<section class="academy-section academy-chronicles" aria-labelledby="academy-chronicles-title">
					<h2 id="academy-chronicles-title" class="tsbs-section-title">Cronache dell'ordine</h2>

					<div class="academy-chronicles-list">
						{chronicleRows.map((row, index) => (
							<article class={`academy-note-card ${index > 1 ? 'is-hidden' : ''}`} data-academy-note-card>
								<div>
									<p class="academy-note-card__meta">{row.meta}</p>
									<h3>Titolo della nota</h3>
									<p>Adepti della Civetta, la Sala Dantesca richiede la vostra attenzione. Nuovi indizi sono apparsi...</p>
								</div>
								<i class="bi bi-chevron-right" aria-hidden="true"></i>
							</article>
						))}
					</div>

					<button class="missions-load-more academy-load-more" type="button" data-load-more aria-controls="academy-chronicles-title">
						<span>Carica altro</span>
						<i class="bi bi-arrow-right" aria-hidden="true"></i>
					</button>
				</section>
			)}
		</div>
	</main>

	<script>
		const rankingLoadMore = document.querySelector<HTMLButtonElement>('[data-ranking-load-more]');
		const hiddenRankingCards = document.querySelectorAll<HTMLElement>('[data-academy-ranking-card].is-hidden');

		if (rankingLoadMore && hiddenRankingCards.length === 0) {
			rankingLoadMore.hidden = true;
		}

		rankingLoadMore?.addEventListener('click', () => {
			document.querySelectorAll<HTMLElement>('[data-academy-ranking-card].is-hidden').forEach((card) => {
				card.classList.remove('is-hidden');
			});

			rankingLoadMore.hidden = true;
			rankingLoadMore.dataset.expanded = 'true';
		});

		const academyLoadMore = document.querySelector<HTMLButtonElement>('.academy-load-more[data-load-more]');
		const academyHiddenCards = document.querySelectorAll<HTMLElement>('[data-academy-note-card].is-hidden');

		if (academyLoadMore && academyHiddenCards.length === 0) {
			academyLoadMore.hidden = true;
		}

		academyLoadMore?.addEventListener('click', () => {
			document.querySelectorAll<HTMLElement>('[data-academy-note-card].is-hidden').forEach((card) => {
				card.classList.remove('is-hidden');
			});

			academyLoadMore.hidden = true;
			academyLoadMore.dataset.expanded = 'true';
		});
	</script>
</Layout>
