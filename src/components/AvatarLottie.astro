---
// Avatar utente animato (.lottie in loop). Render statico server-side:
// la canvas viene inizializzata lato client da scripts/avatarLottie.ts.
interface Props {
	src?: string | null;
	class?: string;
	label?: string;
}

const { src, class: className, label = '' } = Astro.props;
---

{src && (
	<canvas
		class:list={['avatar-lottie', className]}
		data-avatar-lottie
		data-avatar-lottie-src={src}
		role="img"
		aria-label={label}
	></canvas>
)}

<script>
	import { initAvatarLotties } from '../scripts/avatarLottie';
	initAvatarLotties();
	document.addEventListener('astro:page-load', () => initAvatarLotties());
</script>

<style is:global>
	.avatar-lottie {
		display: block;
		width: 100%;
		height: 100%;
	}
</style>
