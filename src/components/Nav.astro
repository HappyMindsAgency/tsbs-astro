---
const { lang = "it" } = Astro.props;

const pathname = Astro.url.pathname;

const mobileItems = [
  { label: "Scrivania", href: "/scrivania/", icon: "bi-book" },
  { label: "Missioni", href: "/missioni/", icon: "bi-award" },
  { label: "Atrio", href: "/", icon: "bi-house-door" },
  { label: "Accademia", href: "/accademia/", icon: "bi-mortarboard" },
  { label: "Biblioteca", href: "/biblioteca/", icon: "bi-archive" },
];

const desktopItems = [
  { label: "Atrio", href: "/", icon: "bi-house-door" },
  { label: "Scrivania", href: "/scrivania/", icon: "bi-book" },
  { label: "Missioni", href: "/missioni/", icon: "bi-award" },
  { label: "Accademia", href: "/accademia/", icon: "bi-mortarboard" },
  { label: "Biblioteca", href: "/biblioteca/", icon: "bi-archive" },
];

const isActive = (href: string) => href === "/" ? pathname === "/" : pathname === href || pathname.startsWith(href);
---

<nav class="tsbs-mobile-nav" aria-label="Menu principale" data-lang={lang}>
  <ul class="tsbs-mobile-nav__list">
    {mobileItems.map((item) => (
      <li class="tsbs-mobile-nav__item">
        <a
          class={`tsbs-mobile-nav__link ${isActive(item.href) ? "is-active" : ""}`}
          href={item.href}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          <i class={`bi ${item.icon}`} aria-hidden="true"></i>
          <span>{item.label}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<aside class="tsbs-desktop-nav" aria-label="Menu principale" data-lang={lang}>
  <p class="tsbs-desktop-nav__brand">The Secret Bookish Society</p>
  <nav class="tsbs-desktop-nav__menu" aria-label="Menu principale desktop">
    <ul class="tsbs-desktop-nav__list">
      {desktopItems.map((item) => (
        <li class="tsbs-desktop-nav__item">
          <a
            class={`tsbs-desktop-nav__link ${isActive(item.href) ? "is-active" : ""}`}
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            <i class={`bi ${item.icon}`} aria-hidden="true"></i>
            <span>{item.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<style lang="scss">
  .tsbs-mobile-nav,
  .tsbs-desktop-nav {
    --nav-active-color: #546176;
    --nav-muted-color: #adadad;
    --nav-surface: var(--tsbs-color-white);
    --nav-active-surface: var(--tsbs-color-white);
    --nav-border: #ededed;
  }

  .tsbs-mobile-nav {
    position: fixed;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 1030;
    display: block;
    padding: 0.5rem 0.75rem calc(0.5rem + env(safe-area-inset-bottom));
    background: var(--nav-surface);
    border-top: 1px solid var(--nav-border);
  }

  .tsbs-mobile-nav__list,
  .tsbs-desktop-nav__list {
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .tsbs-mobile-nav__list {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    align-items: center;
    gap: 0.25rem;
  }

  .tsbs-mobile-nav__link {
    display: grid;
    justify-items: center;
    gap: 0.125rem;
    min-height: 3.5rem;
    padding: 0.375rem 0.125rem;
    color: var(--nav-muted-color);
    font-size: 0.6875rem;
    font-weight: 500;
    line-height: 1.1;
    text-align: center;
    text-decoration: none;
  }

  .tsbs-mobile-nav__link .bi {
    font-size: 1.375rem;
    line-height: 1;
  }

  .tsbs-mobile-nav__link.is-active {
    color: var(--nav-active-color);
  }

  .tsbs-desktop-nav {
    display: none;
  }

  @media (min-width: 992px) {
    .tsbs-mobile-nav {
      display: none;
    }

    .tsbs-desktop-nav {
      position: fixed;
      top: 0;
      bottom: 0;
      left: 0;
      z-index: 1020;
      display: block;
      width: var(--tsbs-desktop-nav-width);
      background: var(--nav-surface);
      border-right: 1px solid var(--nav-border);
    }

    .tsbs-desktop-nav__brand {
      display: flex;
      align-items: center;
      min-height: 3.75rem;
      padding: 0 1.5rem;
      margin: 0;
      color: var(--nav-active-color);
      font-size: 0.875rem;
      font-weight: 700;
      border-bottom: 1px solid var(--nav-border);
    }

    .tsbs-desktop-nav__menu {
      padding: 1.5rem 1rem;
    }

    .tsbs-desktop-nav__list {
      display: grid;
      gap: 0.375rem;
    }

    .tsbs-desktop-nav__link {
      display: flex;
      align-items: center;
      gap: 0.875rem;
      min-height: 3rem;
      padding: 0.625rem 1.5rem;
      color: var(--nav-muted-color);
      font-size: 0.9375rem;
      font-weight: 500;
      line-height: 1.2;
      text-decoration: none;
      border-radius: 1rem;
    }

    .tsbs-desktop-nav__link .bi {
      width: 1.25rem;
      font-size: 1.25rem;
      line-height: 1;
      text-align: center;
    }

    .tsbs-desktop-nav__link.is-active {
      color: var(--nav-active-color);
      background: var(--nav-active-surface);
      box-shadow: 0 0.75rem 1.875rem rgba(84, 97, 118, 0.08);
    }
  }
</style>
