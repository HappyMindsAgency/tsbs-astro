---
import accademiaIcon from "../assets/accademia-icona-navbar.png";
import atrioIcon from "../assets/atrio-icona-navbar.png";
import bibliotecaIcon from "../assets/biblioteca-icona-navbar.png";
import missioniIcon from "../assets/missioni-icona-navbar.png";
import scrivaniaIcon from "../assets/scrivania-icona-navbar.png";
import navbarLogo from "../assets/tsbs-logo-navbar.png";

const { lang = "it", deactivateAll = false } = Astro.props;

const pathname = Astro.url.pathname;

const mobileItems = [
  { id: "scrivania", label: "Scrivania", href: "/scrivania/", icon: scrivaniaIcon },
  { id: "missioni", label: "Missioni", href: "/missioni/", icon: missioniIcon },
  { id: "atrio", label: "Atrio", href: "/atrio/", icon: atrioIcon, activePaths: ["/epistole/"] },
  { id: "accademia", label: "Accademia", href: "/sala-accademia-arborea/", icon: accademiaIcon, activePaths: ["/sala-accademia-", "/accademia-"] },
  { id: "biblioteca", label: "Biblioteca", href: "/biblioteca/", icon: bibliotecaIcon, activePaths: ["/eventi-biblioteca-classense/"] },
];

const desktopItems = [
  { id: "atrio", label: "Atrio", href: "/atrio/", icon: atrioIcon, activePaths: ["/epistole/"] },
  { id: "scrivania", label: "Scrivania", href: "/scrivania/", icon: scrivaniaIcon },
  { id: "missioni", label: "Missioni", href: "/missioni/", icon: missioniIcon },
  { id: "accademia", label: "Accademia", href: "/sala-accademia-arborea/", icon: accademiaIcon, activePaths: ["/sala-accademia-", "/accademia-"] },
  { id: "biblioteca", label: "Biblioteca", href: "/biblioteca/", icon: bibliotecaIcon, activePaths: ["/eventi-biblioteca-classense/"] },
];

const normalizePath = (path: string) => path.replace(/\/+$/, "") || "/";
const currentPath = normalizePath(pathname);

// Parte dall'URL corrente e risale l'alberatura finche trova una voce presente nel menu.
const getActiveHref = (items: typeof mobileItems) => {
  const itemPaths = new Set(items.map((item) => normalizePath(item.href)));
  const aliasedItem = items.find((item) => item.activePaths?.some((path) => currentPath.startsWith(normalizePath(path))));
  if (aliasedItem) return normalizePath(aliasedItem.href);

  let path = currentPath;

  while (path !== "/") {
    if (itemPaths.has(path)) {
      return path;
    }

    path = normalizePath(path.split("/").slice(0, -1).join("/"));
  }

  return itemPaths.has("/") ? "/" : "";
};

const activeMobileHref = getActiveHref(mobileItems);
const activeDesktopHref = getActiveHref(desktopItems);
const navContextItems = desktopItems.map(({ id, href, activePaths }) => ({ id, href, activePaths }));
---

<nav class="tsbs-mobile-nav" aria-label="Menu principale" data-lang={lang}>
  <ul class="tsbs-mobile-nav__list">
    {mobileItems.map((item) => (
      <li class="tsbs-mobile-nav__item">
        <a
          class={`tsbs-mobile-nav__link ${normalizePath(item.href) === activeMobileHref ? "is-active" : ""} ${deactivateAll ? "pe-none" : ""}`}
          href={item.href}
          data-nav-section={item.id}
          aria-current={normalizePath(item.href) === activeMobileHref ? "page" : undefined}
          aria-disabled={deactivateAll ? "true" : undefined}
        >
          <img
            class="tsbs-mobile-nav__icon"
            src={item.icon.src}
            width={item.icon.width}
            height={item.icon.height}
            alt=""
            aria-hidden="true"
            loading="eager"
            decoding="async"
            style="width: 2rem; height: 2rem; object-fit: contain;"
          />
          <span>{item.label}</span>
        </a>
      </li>
    ))}
    {/* TODO: rimuovere quando il logout sarà integrato nel profilo */}
    <li class="tsbs-mobile-nav__item">
      <button class="tsbs-mobile-nav__link tsbs-mobile-nav__logout" type="button" data-logout-trigger>
        <i class="bi bi-box-arrow-left tsbs-mobile-nav__icon" aria-hidden="true"></i>
        <span>Esci</span>
      </button>
    </li>
  </ul>
</nav>

<aside class="tsbs-desktop-nav" aria-label="Menu principale" data-lang={lang}>
  <p class="tsbs-desktop-nav__brand">
    <img
      class="tsbs-desktop-nav__brand-logo"
      src={navbarLogo.src}
      width={navbarLogo.width}
      height={navbarLogo.height}
      alt="The Secret Bookish Society"
      loading="eager"
      decoding="async"
    />
  </p>
  <nav class="tsbs-desktop-nav__menu" aria-label="Menu principale desktop">
    <ul class="tsbs-desktop-nav__list">
      {desktopItems.map((item) => (
        <li class="tsbs-desktop-nav__item">
          <a
            class={`tsbs-desktop-nav__link ${normalizePath(item.href) === activeDesktopHref ? "is-active" : ""} ${deactivateAll ? "pe-none" : ""}`}
            href={item.href}
            data-nav-section={item.id}
            aria-current={normalizePath(item.href) === activeDesktopHref ? "page" : undefined}
            aria-disabled={deactivateAll ? "true" : undefined}
          >
            <img
              class="tsbs-desktop-nav__icon"
              src={item.icon.src}
              width={item.icon.width}
              height={item.icon.height}
              alt=""
              aria-hidden="true"
              loading="eager"
              decoding="async"
              style="width: 2.1875rem; height: 2.1875rem; object-fit: contain;"
            />
            <span>{item.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>
  <div class="tsbs-desktop-nav__footer">
    <button class="tsbs-desktop-nav__logout" type="button" data-logout-trigger>
      <i class="bi bi-box-arrow-left" aria-hidden="true"></i>
      <span>Esci</span>
    </button>
  </div>
</aside>

<script>
  document.querySelectorAll('[data-logout-trigger]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.assign('/login/');
    });
  });
</script>

<script define:vars={{ navContextItems, deactivateAll }} data-astro-rerun>
  const navContextStorageKey = "tsbs.activeNavContext";
  const navContextLinks = Array.from(document.querySelectorAll("[data-nav-section]"));
  const navIsDeactivated = Boolean(deactivateAll);
  const normalizeNavPath = (path) => path.replace(/\/+$/, "") || "/";
  const navSections = navContextItems.map((item) => ({
    ...item,
    href: normalizeNavPath(item.href),
    activePaths: (item.activePaths || []).map(normalizeNavPath),
  }));
  const validNavSections = new Set(navSections.map((item) => item.id));

  const getNavSectionFromPath = (pathname) => {
    const currentPath = normalizeNavPath(pathname);
    const aliasedItem = navSections.find((item) => item.activePaths.some((path) => currentPath.startsWith(path)));
    if (aliasedItem) return aliasedItem.id;

    let path = currentPath;

    while (path !== "/") {
      const matchedItem = navSections.find((item) => item.href === path);
      if (matchedItem) return matchedItem.id;

      path = normalizeNavPath(path.split("/").slice(0, -1).join("/"));
    }

    return "";
  };

  const setActiveNavSection = (section) => {
    navContextLinks.forEach((link) => {
      const isActive = link.dataset.navSection === section;
      link.classList.toggle("is-active", isActive);

      if (isActive) {
        link.setAttribute("aria-current", "page");
      } else {
        link.removeAttribute("aria-current");
      }
    });
  };

  const getStoredNavSection = () => {
    try {
      const storedSection = sessionStorage.getItem(navContextStorageKey);
      return storedSection && validNavSections.has(storedSection) ? storedSection : "";
    } catch {
      return "";
    }
  };

  const storeNavSection = (section) => {
    if (!validNavSections.has(section)) return;

    try {
      sessionStorage.setItem(navContextStorageKey, section);
    } catch {
      // Se lo storage non e disponibile, la nav resta comunque coerente con l'URL.
    }
  };

  if (!navIsDeactivated) {
    const fallbackSection = getNavSectionFromPath(window.location.pathname);
    const activeSection = getStoredNavSection() || fallbackSection;

    if (activeSection) {
      setActiveNavSection(activeSection);
      storeNavSection(activeSection);
    }

    navContextLinks.forEach((link) => {
      link.addEventListener("click", () => {
        const section = link.dataset.navSection;
        if (!section) return;

        storeNavSection(section);
        setActiveNavSection(section);
      });
    });
  }
</script>

<style lang="scss">
  .tsbs-mobile-nav,
  .tsbs-desktop-nav {
    --nav-active-color: #546176;
    --nav-muted-color: #adadad;
    --nav-surface: var(--tsbs-color-white);
    --nav-active-surface: var(--tsbs-color-white);
    --nav-border: #ededed;
  }

  .tsbs-mobile-nav {
    position: fixed;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 1030;
    display: block;
    min-height: var(--tsbs-mobile-nav-viewport-height);
    padding: 0.5rem 0.75rem calc(0.5rem + env(safe-area-inset-bottom));
    background: var(--nav-surface);
    border-top: 1px solid var(--nav-border);
  }

  .tsbs-mobile-nav__list,
  .tsbs-desktop-nav__list {
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .tsbs-mobile-nav__list {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    align-items: center;
    gap: 0.25rem;
  }

  .tsbs-mobile-nav__link {
    display: grid;
    grid-template-rows: 2rem auto;
    align-content: center;
    justify-items: center;
    gap: 0.1875rem;
    min-height: 3.5rem;
    padding: 0.375rem 0.125rem;
    color: var(--nav-muted-color);
    font-size: 0.6875rem;
    font-weight: 500;
    line-height: 1.1;
    text-align: center;
    text-decoration: none;
  }

  .tsbs-mobile-nav__icon {
    display: block;
    width: 2rem;
    height: 2rem;
    object-fit: contain;
  }

  .tsbs-mobile-nav__link.is-active {
    color: var(--nav-active-color);
  }

  .tsbs-desktop-nav {
    display: none;
  }

  .tsbs-mobile-nav__logout {
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
  }

  .tsbs-mobile-nav__logout .bi {
    display: block;
    font-size: 1.5rem;
    line-height: 1;
  }

  @media (min-width: 992px) {
    .tsbs-mobile-nav {
      display: none;
    }

    .tsbs-desktop-nav {
      position: fixed;
      top: 0;
      bottom: 0;
      left: 0;
      z-index: 1020;
      display: block;
      width: var(--tsbs-desktop-nav-width);
      background: var(--nav-surface);
      border-right: 1px solid var(--nav-border);
    }

    .tsbs-desktop-nav__brand {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 5rem;
      padding: 0.625rem 1.5rem;
      margin: 0;
      border-bottom: 1px solid var(--nav-border);
    }

    .tsbs-desktop-nav__brand-logo {
      width: clamp(4.5rem, 43%, 6rem);
      height: auto;
      max-height: 3.3rem;
      object-fit: contain;
    }

    .tsbs-desktop-nav__menu {
      padding: 1.5rem 1rem;
    }

    .tsbs-desktop-nav__list {
      display: grid;
      gap: 0.375rem;
    }

    .tsbs-desktop-nav__link {
      display: flex;
      align-items: center;
      gap: 0.875rem;
      min-height: 3rem;
      padding: 0.625rem 1.5rem;
      color: var(--nav-muted-color);
      font-size: 0.9375rem;
      font-weight: 500;
      line-height: 1.2;
      text-decoration: none;
      border-radius: 1rem;
    }

    .tsbs-desktop-nav__icon {
      width: 2.1875rem;
      height: 2.1875rem;
      flex: 0 0 2.1875rem;
      object-fit: contain;
    }

    .tsbs-desktop-nav__link.is-active {
      color: var(--nav-active-color);
      background: var(--nav-active-surface);
      box-shadow: 0 0.75rem 1.875rem rgba(84, 97, 118, 0.08);
    }

    .tsbs-desktop-nav__footer {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 1rem;
      border-top: 1px solid var(--nav-border);
    }

    .tsbs-desktop-nav__logout {
      display: flex;
      align-items: center;
      gap: 0.875rem;
      width: 100%;
      min-height: 3rem;
      padding: 0.625rem 1.5rem;
      color: var(--nav-muted-color);
      font-size: 0.9375rem;
      font-weight: 500;
      background: none;
      border: none;
      border-radius: 1rem;
      cursor: pointer;
      text-align: left;
    }

    .tsbs-desktop-nav__logout:hover {
      color: #c0392b;
      background: #fdf2f0;
    }
  }
</style>
