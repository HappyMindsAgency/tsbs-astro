---
interface Props {
	isOpen?: boolean;
	renderHidden?: boolean;
}

const { isOpen = false, renderHidden = false } = Astro.props as Props;
const shouldRender = isOpen || renderHidden;
---

{shouldRender && (
	<div
		class="password-change-toast"
		data-password-change-toast
		data-password-change-status="success"
		hidden={!isOpen}
		role="status"
		aria-live="polite"
		aria-labelledby="password-change-toast-title"
	>
		<section class="password-change-toast__panel">
			<i class="bi bi-check2-circle" aria-hidden="true" data-password-change-icon></i>
			<p id="password-change-toast-title" data-password-change-message>Password aggiornata.</p>
		</section>
	</div>
)}

<script>
	const setupPasswordChangeToast = () => {
		document.querySelectorAll<HTMLElement>('[data-password-change-toast]').forEach((toast) => {
			if (toast.dataset.passwordChangeToastReady === 'true') return;
			toast.dataset.passwordChangeToastReady = 'true';

			const icon = toast.querySelector<HTMLElement>('[data-password-change-icon]');
			const message = toast.querySelector<HTMLElement>('[data-password-change-message]');
			let closeTimer: number | undefined;

			const closeToast = () => {
				toast.hidden = true;
				if (closeTimer) window.clearTimeout(closeTimer);
			};

			const openToast = (event: Event) => {
				if (closeTimer) window.clearTimeout(closeTimer);

				const detail = event instanceof CustomEvent ? event.detail : {};
				const status = detail?.status === 'error' ? 'error' : 'success';

				toast.dataset.passwordChangeStatus = status;
				toast.setAttribute('aria-live', status === 'error' ? 'assertive' : 'polite');

				if (icon) {
					icon.classList.toggle('bi-check2-circle', status === 'success');
					icon.classList.toggle('bi-exclamation-circle', status === 'error');
				}

				if (message) {
					message.textContent = status === 'success' ? 'Password aggiornata.' : 'Cambio password non riuscito.';
				}

				toast.hidden = false;
				closeTimer = window.setTimeout(closeToast, status === 'success' ? 2200 : 2800);
			};

			document.addEventListener('tsbs:password-change-toast-open', openToast);
			document.addEventListener('tsbs:password-change-toast-close', closeToast);
		});
	};

	document.addEventListener('astro:page-load', setupPasswordChangeToast);
	setupPasswordChangeToast();
</script>

<style lang="scss">
	.password-change-toast {
		position: fixed;
		inset: 0;
		z-index: 1230;
		display: grid;
		place-items: center;
		padding: 1.875rem;
		pointer-events: none;
	}

	.password-change-toast[hidden] {
		display: none;
	}

	.password-change-toast__panel {
		display: grid;
		justify-items: center;
		gap: 0.875rem;
		width: min(100%, 22.625rem);
		padding: 1.5rem 1.25rem 1.625rem;
		color: var(--tsbs-theme-accent);
		background: var(--tsbs-color-white);
		border: 1px solid color-mix(in srgb, var(--tsbs-theme-accent) 22%, transparent);
		border-radius: 0.875rem;
		box-shadow: 0 1.25rem 3rem rgba(84, 97, 118, 0.18);
		pointer-events: auto;
	}

	.password-change-toast[data-password-change-status="error"] .password-change-toast__panel {
		color: #8b2f2f;
		border-color: rgba(139, 47, 47, 0.26);
	}

	.password-change-toast__panel .bi {
		display: grid;
		place-items: center;
		width: 3.25rem;
		aspect-ratio: 1;
		color: var(--tsbs-color-white);
		background: var(--tsbs-theme-accent);
		border-radius: 999rem;
		font-size: 1.85rem;
		line-height: 1;
	}

	.password-change-toast[data-password-change-status="error"] .password-change-toast__panel .bi {
		background: #8b2f2f;
	}

	.password-change-toast__panel p {
		margin: 0;
		font-family: var(--tsbs-font-body);
		font-size: 1.125rem;
		font-weight: 800;
		line-height: 1.2;
		text-align: center;
	}

	@media (max-width: 360px) {
		.password-change-toast {
			padding-right: 1rem;
			padding-left: 1rem;
		}
	}

	@media (min-width: 992px) {
		.password-change-toast {
			padding-left: calc(var(--tsbs-desktop-nav-width) + 1.875rem);
		}
	}
</style>
