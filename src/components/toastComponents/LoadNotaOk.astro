---
interface Props {
	isOpen?: boolean;
	renderHidden?: boolean;
}

const { isOpen = false, renderHidden = false } = Astro.props as Props;
const shouldRender = isOpen || renderHidden;
---

{shouldRender && (
	<div
		class="load-note-toast load-note-toast--ok"
		data-load-note-ok
		hidden={!isOpen}
		role="status"
		aria-live="polite"
		aria-labelledby="load-note-ok-title"
	>
		<section class="load-note-toast__panel">
			<i class="bi bi-check2-circle" aria-hidden="true"></i>
			<p id="load-note-ok-title">Nota inviata al Prefetto.</p>
		</section>
	</div>
)}

<script>
	const setupLoadNoteOk = () => {
		document.querySelectorAll<HTMLElement>('[data-load-note-ok]').forEach((toast) => {
			if (toast.dataset.loadNoteOkReady === 'true') return;
			toast.dataset.loadNoteOkReady = 'true';

			let closeTimer: number | undefined;

			const closeToast = () => {
				toast.hidden = true;
				if (closeTimer) window.clearTimeout(closeTimer);
			};

			const openToast = () => {
				if (closeTimer) window.clearTimeout(closeTimer);
				document.dispatchEvent(new CustomEvent('tsbs:load-nota-error-close'));
				toast.hidden = false;
				closeTimer = window.setTimeout(closeToast, 2200);
			};

			document.addEventListener('tsbs:load-nota-ok-open', openToast);
			document.addEventListener('tsbs:load-nota-ok-close', closeToast);
			document.addEventListener('tsbs:load-nota-clear', closeToast);
		});
	};

	document.addEventListener('astro:page-load', setupLoadNoteOk);
	setupLoadNoteOk();
</script>

<style lang="scss">
	.load-note-toast {
		position: fixed;
		inset: 0;
		z-index: 1230;
		display: grid;
		place-items: center;
		padding: 1.875rem;
		pointer-events: none;
	}

	.load-note-toast[hidden] {
		display: none;
	}

	.load-note-toast__panel {
		display: grid;
		justify-items: center;
		gap: 0.875rem;
		width: min(100%, 22.625rem);
		padding: 1.5rem 1.25rem 1.625rem;
		color: var(--tsbs-theme-accent);
		background: var(--tsbs-color-white);
		border: 1px solid color-mix(in srgb, var(--tsbs-theme-accent) 22%, transparent);
		border-radius: 0.875rem;
		box-shadow: 0 1.25rem 3rem rgba(84, 97, 118, 0.18);
		pointer-events: auto;
	}

	.load-note-toast__panel .bi {
		display: grid;
		place-items: center;
		width: 3.25rem;
		aspect-ratio: 1;
		color: var(--tsbs-color-white);
		background: var(--tsbs-theme-accent);
		border-radius: 999rem;
		font-size: 1.85rem;
		line-height: 1;
	}

	.load-note-toast__panel p {
		margin: 0;
		font-family: var(--tsbs-font-body);
		font-size: 1.125rem;
		font-weight: 800;
		line-height: 1.2;
		text-align: center;
	}

	@media (min-width: 992px) {
		.load-note-toast {
			padding-left: calc(var(--tsbs-desktop-nav-width) + 1.875rem);
		}
	}
</style>
