---
interface Props {
	isOpen?: boolean;
	renderHidden?: boolean;
}

const { isOpen = false, renderHidden = false } = Astro.props as Props;
const shouldRender = isOpen || renderHidden;
---

{shouldRender && (
	<div
		class="load-note-toast load-note-toast--ok"
		data-load-note-ok
		hidden={!isOpen}
		role="status"
		aria-live="polite"
		aria-labelledby="load-note-ok-title"
	>
		<section class="load-note-toast__panel">
			<i class="bi bi-check2-circle" aria-hidden="true"></i>
			<p id="load-note-ok-title">Nota inviata al Prefetto.</p>
		</section>
	</div>
)}

<script>
	const setupLoadNoteOk = () => {
		document.querySelectorAll<HTMLElement>('[data-load-note-ok]').forEach((toast) => {
			if (toast.dataset.loadNoteOkReady === 'true') return;
			toast.dataset.loadNoteOkReady = 'true';

			let closeTimer: number | undefined;

			const closeToast = () => {
				toast.hidden = true;
				if (closeTimer) window.clearTimeout(closeTimer);
			};

			const openToast = () => {
				if (closeTimer) window.clearTimeout(closeTimer);
				toast.hidden = false;
				closeTimer = window.setTimeout(closeToast, 2200);
			};

			document.addEventListener('tsbs:load-nota-ok-open', openToast);
		});
	};

	document.addEventListener('astro:page-load', setupLoadNoteOk);
	setupLoadNoteOk();
</script>

<style lang="scss">
	.load-note-toast {
		position: fixed;
		right: 1rem;
		bottom: 1rem;
		z-index: 1230;
		width: min(calc(100vw - 2rem), 22rem);
	}

	.load-note-toast[hidden] {
		display: none;
	}

	.load-note-toast__panel {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 1rem;
		color: var(--tsbs-theme-accent);
		background: var(--tsbs-color-white);
		border: 1px solid color-mix(in srgb, var(--tsbs-theme-accent) 28%, transparent);
		border-radius: 0.5rem;
		box-shadow: 0 1rem 2rem rgba(84, 97, 118, 0.16);
	}

	.load-note-toast__panel .bi {
		font-size: 1.35rem;
		line-height: 1;
	}

	.load-note-toast__panel p {
		margin: 0;
		font-family: var(--tsbs-font-body);
		font-size: 0.95rem;
		font-weight: 800;
		line-height: 1.25;
	}

	@media (min-width: 992px) {
		.load-note-toast {
			right: 1.5rem;
			bottom: 1.5rem;
		}
	}
</style>
