---
const { isOpen = false, theme = '' } = Astro.props;
const toastDismissedKey = 'tsbs.welcomeToastDismissed';
---

{isOpen && (
	<div
		class={`welcome-toast tsbs-toast ${theme}`}
		data-welcome-toast
		data-welcome-toast-dismissed-key={toastDismissedKey}
		role="dialog"
		aria-modal="true"
		aria-labelledby="welcome-toast-title"
	>
		<div class="welcome-toast__backdrop" data-welcome-toast-close></div>
		<div class="welcome-toast__panel">
			<div class="welcome-toast__body">
				<div class="welcome-toast__avatar" aria-hidden="true" data-welcome-toast-avatar>
					<img data-welcome-toast-avatar-img hidden alt="" />
				</div>
				<div class="welcome-toast__content">
					<h2 id="welcome-toast-title" class="welcome-toast__title">
						<span class="welcome-toast__title-light">Benvenut*</span>
						<span class="welcome-toast__title-accent" data-welcome-toast-username>Adepto</span>
					</h2>
					<p>Aenean placerat eros turpis, nec posuere massa fermentum malesuada. Morbi at est et tortor laoreet placerat id in neque. Maecenas vel erat lacinia, sodales ipsum id, porta sapien.</p>
				</div>
			</div>
			<div class="welcome-toast__footer">
				<button class="btn tsbs-cta-primary welcome-toast__button" type="button" data-welcome-toast-close>Inizia</button>
			</div>
		</div>
	</div>
)}

<script>
	const loadWelcomeToastProfilo = async () => {
		try {
			const res = await fetch('/api/user/profilo');
			if (!res.ok) return;
			const profilo = await res.json();

			const nameEl = document.querySelector('[data-welcome-toast-username]');
			if (nameEl instanceof HTMLElement && profilo.username) nameEl.textContent = profilo.username;

			if (profilo.avatarSrc) {
				const img = document.querySelector<HTMLImageElement>('[data-welcome-toast-avatar-img]');
				if (img instanceof HTMLImageElement) {
					img.onerror = () => {
						img.hidden = true;
					};
					img.src = profilo.avatarSrc;
					img.hidden = false;
				}
			}
		} catch {
			// Fallback silenzioso
		}
	};

	const setupWelcomeToast = () => {
		const toast = document.querySelector<HTMLElement>('[data-welcome-toast]');
		if (!toast) return;
		if (toast.dataset.welcomeToastReady === 'true') return;
		toast.dataset.welcomeToastReady = 'true';

		const dismissedKey = toast.dataset.welcomeToastDismissedKey || 'tsbs.welcomeToastDismissed';

		const isDismissed = () => {
			try {
				return window.sessionStorage.getItem(dismissedKey) === 'true';
			} catch {
				return false;
			}
		};

		const markDismissed = () => {
			try {
				window.sessionStorage.setItem(dismissedKey, 'true');
			} catch {
				// Se lo storage non e disponibile, la chiusura resta valida per il DOM corrente.
			}
		};

		if (isDismissed()) {
			toast.hidden = true;
			toast.setAttribute('aria-hidden', 'true');
			return;
		}

		loadWelcomeToastProfilo();

		const closeToast = () => {
			markDismissed();
			toast.hidden = true;
			toast.setAttribute('aria-hidden', 'true');
		};

		toast.querySelectorAll('[data-welcome-toast-close]').forEach((element) => {
			element.addEventListener('click', closeToast);
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') closeToast();
		});
	};

	document.addEventListener('astro:page-load', setupWelcomeToast);
	setupWelcomeToast();
</script>

<style lang="scss">
	.welcome-toast {
		position: fixed;
		inset: 0;
		z-index: 1100;
		display: grid;
		place-items: center;
		padding: 1.75rem;
	}

	.welcome-toast[hidden] {
		display: none;
		pointer-events: none;
	}

	.welcome-toast__backdrop {
		position: absolute;
		inset: 0;
		background: color-mix(in srgb, var(--tsbs-color-white) 62%, transparent);
		backdrop-filter: blur(0.0625rem);
	}

	.welcome-toast__panel {
		position: relative;
		width: min(100%, 23.5rem);
		overflow: hidden;
		background: var(--tsbs-color-white);
		border-radius: 0.875rem;
		box-shadow: 0 1rem 2.5rem color-mix(in srgb, var(--tsbs-theme-accent) 14%, transparent);
	}

	.welcome-toast__body {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: center;
		padding: 2rem 1.875rem 1.5rem;
	}

	.welcome-toast__avatar {
		display: grid;
		place-items: center;
		width: 8.75rem;
		height: 8.75rem;
		color: color-mix(in srgb, var(--tsbs-theme-accent) 54%, var(--tsbs-color-white));
	}

	.welcome-toast__avatar img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.welcome-toast__content {
		width: 100%;
	}

	.welcome-toast__title {
		display: flex;
		flex-wrap: wrap;
		gap: 0 0.35rem;
		margin: 0 0 0.625rem;
		color: var(--tsbs-theme-accent);
		font-family: var(--tsbs-font-heading-academy);
		font-size: 1.25rem;
		font-weight: 700;
		line-height: 1.12;
		letter-spacing: 0;
	}

	.welcome-toast__title-accent {
		color: inherit;
	}

	.welcome-toast__content p {
		margin: 0;
		color: var(--tsbs-theme-body);
		font-size: 1rem;
		line-height: 1.42;
	}

	.welcome-toast__footer {
		padding: 1rem;
		border-top: 1px solid color-mix(in srgb, var(--tsbs-theme-accent) 10%, var(--tsbs-color-white));
	}

	.welcome-toast__button {
		width: 100%;
		padding: 0.875rem 1rem;
		border-radius: 0.375rem;
		font-family: var(--tsbs-font-body);
		font-weight: 700;
	}

	@media (max-width: 360px) {
		.welcome-toast {
			padding-right: 1rem;
			padding-left: 1rem;
		}

		.welcome-toast__body {
			gap: 0.875rem;
			padding-right: 1rem;
			padding-left: 1rem;
		}

		.welcome-toast__avatar {
			width: 7.1875rem;
			height: 7.1875rem;
		}
	}

	@media (min-width: 576px) {
		.welcome-toast__body {
			display: grid;
			grid-template-columns: 7.25rem minmax(0, 1fr);
			gap: 1.25rem;
			align-items: center;
		}

		.welcome-toast__avatar {
			width: 8.5rem;
			height: 8.5rem;
		}
	}

	@media (min-width: 992px) {
		.welcome-toast__panel {
			width: min(100%, 35.5rem);
		}

		.welcome-toast__body {
			grid-template-columns: 8.75rem minmax(0, 1fr);
			gap: 1.75rem;
			padding: 2.75rem 2.5rem 2.25rem;
		}

		.welcome-toast__title {
			margin-bottom: 0.875rem;
		}

		.welcome-toast__footer {
			padding: 1.25rem 1.5rem 1.5rem;
		}

		.welcome-toast__button {
			padding: 1rem 1.25rem;
		}
	}
</style>
