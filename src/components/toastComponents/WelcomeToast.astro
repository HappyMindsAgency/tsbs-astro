---
const { isOpen = false, theme = '', accademia = '', epistolaHref = '/epistole/' } = Astro.props;
const academyName = typeof accademia === 'string' && accademia
	? accademia.charAt(0).toUpperCase() + accademia.slice(1).toLowerCase()
	: '';
---

{isOpen && (
	<div
		class={`welcome-toast ${theme}`}
		data-welcome-toast
		role="dialog"
		aria-modal="true"
		aria-labelledby="welcome-toast-title"
	>
		<div class="welcome-toast__backdrop" data-welcome-toast-close></div>
		<div class="welcome-toast__panel">
			<div class="welcome-toast__body">
				<div class="welcome-toast__avatar" aria-hidden="true" data-welcome-toast-avatar>
					<canvas class="avatar-lottie" data-avatar-lottie data-welcome-toast-avatar-img hidden></canvas>
				</div>
				<div class="welcome-toast__content">
					<h2 id="welcome-toast-title" class="welcome-toast__title">
						Ti diamo il benvenuto nella Accademia {academyName}
					</h2>
					<p>Lo Smistamento ha rivelato la tua via.<br />Da questo momento, il tuo cammino nella Società prosegue sotto il segno di questa Accademia.</p>
					<p>La prima epistola della tua Guida ti attende: aprila e preparati alla prima missione in The Secret Bookish Society.</p>
				</div>
			</div>
			<div class="welcome-toast__footer">
				<a class="btn tsbs-cta-primary welcome-toast__button" href={epistolaHref}>Leggi l’Epistola</a>
			</div>
		</div>
	</div>
)}

<script>
	import { setAvatarLottie } from '../../scripts/avatarLottie';

	const loadWelcomeToastProfilo = async () => {
		try {
			const res = await fetch('/api/user/profilo');
			if (!res.ok) return;
			const profilo = await res.json();

			if (profilo.avatarSrc) {
				const canvas = document.querySelector<HTMLCanvasElement>('[data-welcome-toast-avatar-img]');
				if (canvas instanceof HTMLCanvasElement) {
					canvas.hidden = false;
					setAvatarLottie(canvas, profilo.avatarSrc);
				}
			}
		} catch {
			// Fallback silenzioso
		}
	};

	const setupWelcomeToast = () => {
		const toast = document.querySelector<HTMLElement>('[data-welcome-toast]');
		if (!toast) return;
		if (toast.dataset.welcomeToastReady === 'true') return;
		toast.dataset.welcomeToastReady = 'true';

		const currentUrl = new URL(window.location.href);
		if (currentUrl.searchParams.has('welcome')) {
			currentUrl.searchParams.delete('welcome');
			window.history.replaceState(window.history.state, '', `${currentUrl.pathname}${currentUrl.search}${currentUrl.hash}`);
		}

		loadWelcomeToastProfilo();

		const closeToast = () => {
			toast.hidden = true;
			toast.setAttribute('aria-hidden', 'true');
		};

		toast.querySelectorAll('[data-welcome-toast-close]').forEach((element) => {
			element.addEventListener('click', closeToast);
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') closeToast();
		});
	};

	document.addEventListener('astro:page-load', setupWelcomeToast);
	setupWelcomeToast();
</script>

<style lang="scss">
	.welcome-toast {
		position: fixed;
		inset: 0;
		z-index: 1100;
		display: grid;
		place-items: center;
		padding: 1.75rem;
	}

	.welcome-toast[hidden] {
		display: none;
		pointer-events: none;
	}

	.welcome-toast__backdrop {
		position: absolute;
		inset: 0;
		background: color-mix(in srgb, var(--tsbs-color-white) 62%, transparent);
		backdrop-filter: blur(0.0625rem);
	}

	.welcome-toast__panel {
		position: relative;
		width: min(100%, 23.5rem);
		overflow: hidden;
		background: var(--tsbs-color-white);
		border-radius: 0.875rem;
		box-shadow: 0 1rem 2.5rem color-mix(in srgb, var(--tsbs-theme-accent) 14%, transparent);
	}

	.welcome-toast__body {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: center;
		padding: 2rem 1.875rem 1.5rem;
	}

	.welcome-toast__avatar {
		display: grid;
		place-items: center;
		width: 8.75rem;
		height: 8.75rem;
		color: color-mix(in srgb, var(--tsbs-theme-accent) 54%, var(--tsbs-color-white));
	}

	.welcome-toast__avatar img,
	.welcome-toast__avatar canvas {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.welcome-toast__content {
		width: 100%;
	}

	.welcome-toast__title {
		margin: 0 0 0.625rem;
		color: var(--tsbs-theme-accent);
		font-family: var(--tsbs-font-heading-academy);
		font-size: 1.25rem;
		font-weight: 700;
		line-height: 1.12;
		letter-spacing: 0;
	}

	.welcome-toast__content p {
		margin: 0;
		color: var(--tsbs-theme-body);
		font-size: 1rem;
		line-height: 1.42;
	}

	.welcome-toast__content p + p {
		margin-top: 0.875rem;
	}

	.welcome-toast__footer {
		padding: 1rem;
		border-top: 1px solid color-mix(in srgb, var(--tsbs-theme-accent) 10%, var(--tsbs-color-white));
	}

	.welcome-toast__button {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		padding: 0.875rem 1rem;
		border-radius: 0.375rem;
		font-family: var(--tsbs-font-body);
		font-weight: 700;
	}

	@media (max-width: 360px) {
		.welcome-toast {
			padding-right: 1rem;
			padding-left: 1rem;
		}

		.welcome-toast__body {
			gap: 0.875rem;
			padding-right: 1rem;
			padding-left: 1rem;
		}

		.welcome-toast__avatar {
			width: 7.1875rem;
			height: 7.1875rem;
		}
	}

	@media (min-width: 576px) {
		.welcome-toast__body {
			display: grid;
			grid-template-columns: 7.25rem minmax(0, 1fr);
			gap: 1.25rem;
			align-items: center;
		}

		.welcome-toast__avatar {
			width: 8.5rem;
			height: 8.5rem;
		}
	}

	@media (min-width: 992px) {
		.welcome-toast__panel {
			width: min(100%, 35.5rem);
		}

		.welcome-toast__body {
			grid-template-columns: 8.75rem minmax(0, 1fr);
			gap: 1.75rem;
			padding: 2.75rem 2.5rem 2.25rem;
		}

		.welcome-toast__title {
			margin-bottom: 0.875rem;
		}

		.welcome-toast__footer {
			padding: 1.25rem 1.5rem 1.5rem;
		}

		.welcome-toast__button {
			padding: 1rem 1.25rem;
		}
	}
</style>
