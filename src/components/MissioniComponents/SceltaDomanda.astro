---
import TestPassed from '../toastComponents/TestPassed.astro';
import TestNotPassed from '../toastComponents/TestNotPassed.astro';

const { missione = null, questions: providedQuestions = [], lang = 'it', slugMis = '' } = Astro.props;

const fallbackQuestions = [
	{
		question: 'Scegli una sola risposta',
		answers: [
			{ label: 'Risposta A', description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut' },
			{ label: 'Risposta B', description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut' },
			{ label: 'Risposta C', description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut' },
			{ label: 'Risposta D', description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut' },
		],
	},
	{
		question: 'Scegli una seconda risposta',
		answers: [
			{ label: 'Risposta B', description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut' },
			{ label: 'Risposta C', description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut' },
			{ label: 'Risposta A', description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut' },
			{ label: 'Risposta D', description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut' },
		],
	},
	{
		question: 'Scegli una terza risposta',
		answers: [
			{ label: 'Risposta D', description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut' },
			{ label: 'Risposta B', description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut' },
			{ label: 'Risposta C', description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut' },
			{ label: 'Risposta A', description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut' },
		],
	},
];

const questions = providedQuestions.length > 0 ? providedQuestions : fallbackQuestions;
const firstQuestion = questions[0];
const title = firstQuestion.question;
const eyebrow = missione?.titolo || 'NOME DELLA MISSIONE';
---

<article class="mission-proof-question choice-question" data-choice-question data-lang={lang} aria-label="Prova missione">
	<header class="mission-proof-question__header">
		<div class="container-xl tsbs-app-container mission-proof-question__header-content">
			<p class="mission-proof-question__eyebrow">{eyebrow}</p>
			<h1 class="mission-proof-question__title mission-component-title">{title}</h1>
		</div>
	</header>

	<div class="container-xl tsbs-app-container mission-proof-question__panel choice-question__panel">
		<form class="choice-question__form" data-choice-question-form>
			<fieldset class="choice-question__fieldset">
				<legend data-choice-question-title>Scegli una sola risposta</legend>

				<div class="choice-question__answers" data-choice-question-answers>
					{firstQuestion.answers.map((answer, index) => (
						<label class="choice-question__answer" for={`mission-answer-0-${index}`}>
							<input id={`mission-answer-0-${index}`} type="radio" name="risposta" value={answer.label} />
							<span class="choice-question__answer-label">{answer.label}</span>
							{answer.description && <span class="choice-question__answer-description">{answer.description}</span>}
						</label>
					))}
				</div>
			</fieldset>

			<button class="btn tsbs-cta-primary mission-proof-question__cta choice-question__cta" type="submit" data-choice-question-submit hidden>
				Avanti →
			</button>
		</form>
	</div>

	<TestPassed renderHidden={true} />
	<TestNotPassed renderHidden={true} buttonHref="/missioni/" />
</article>

<script define:vars={{ questions, slugMis }}>
	const setupChoiceQuestion = () => {
		const root = document.querySelector('[data-choice-question]');
		if (!root) return;

		const form = root.querySelector('[data-choice-question-form]');
		const title = root.querySelector('[data-choice-question-title]');
		const answers = root.querySelector('[data-choice-question-answers]');
		const submit = root.querySelector('[data-choice-question-submit]');
		const passedToast = root.querySelector('.test-result-toast--passed');
		const notPassedToast = root.querySelector('.test-result-toast--not-passed');

		if (!form || !title || !answers || !submit || !passedToast || !notPassedToast) return;

		let currentQuestionIndex = 0;
		const submittedAnswers = new Array(questions.length).fill('');

		const getSelectedAnswer = () => answers.querySelector('input[name="risposta"]:checked')?.value ?? '';
		const hasSelectedAnswer = () => Boolean(getSelectedAnswer());

		const showResultToast = (passed) => {
			passedToast.hidden = !passed;
			notPassedToast.hidden = passed;
		};

		const validateMissionProof = async () => {
			submit.disabled = true;

			try {
				const response = await fetch(`/api/missioni/${slugMis}/prova`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({
						answers: submittedAnswers.map((answer, questionIndex) => ({ questionIndex, answer })),
					}),
				});
				const payload = await response.json().catch(() => null);

				showResultToast(response.ok && payload?.passed === true);
			} catch {
				showResultToast(false);
			} finally {
				submit.disabled = false;
			}
		};

		const renderQuestion = () => {
			const currentQuestion = questions[currentQuestionIndex];
			const isLastQuestion = currentQuestionIndex === questions.length - 1;

			const headerTitle = root.querySelector('.mission-proof-question__title');
			if (headerTitle) headerTitle.textContent = currentQuestion.question;
			title.textContent = 'Scegli una sola risposta';
			answers.replaceChildren(
				...currentQuestion.answers.map((answer, answerIndex) => {
					const id = `mission-answer-${currentQuestionIndex}-${answerIndex}`;
					const label = document.createElement('label');
					const input = document.createElement('input');
					const answerLabel = document.createElement('span');

					label.className = 'choice-question__answer';
					label.setAttribute('for', id);
					input.id = id;
					input.type = 'radio';
					input.name = 'risposta';
					input.value = answer.label;
					answerLabel.className = 'choice-question__answer-label';
					answerLabel.textContent = answer.label;
					label.append(input, answerLabel);

					if (answer.description) {
						const answerDescription = document.createElement('span');
						answerDescription.className = 'choice-question__answer-description';
						answerDescription.textContent = answer.description;
						label.append(answerDescription);
					}

					return label;
				}),
			);
			submit.innerHTML = isLastQuestion
				? '<span>Concludi la prova</span><i class="bi bi-stars choice-question__complete-icon" aria-hidden="true"></i>'
				: 'Avanti →';
			submit.hidden = true;
		};

		answers.addEventListener('change', () => {
			submit.hidden = !hasSelectedAnswer();
		});

		form.addEventListener('submit', (event) => {
			event.preventDefault();

			if (!hasSelectedAnswer()) return;
			submittedAnswers[currentQuestionIndex] = getSelectedAnswer();

			if (currentQuestionIndex < questions.length - 1) {
				currentQuestionIndex += 1;
				renderQuestion();
				return;
			}

			validateMissionProof();
		});

		renderQuestion();
	};

	document.addEventListener('astro:page-load', setupChoiceQuestion);
	setupChoiceQuestion();
</script>

<style lang="scss">
	.choice-question__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}

	.choice-question__complete-icon {
		color: var(--tsbs-color-white);
		font-size: 1.125rem;
		line-height: 1;
	}

</style>
