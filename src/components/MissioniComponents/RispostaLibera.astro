---
import { marked } from 'marked';
import TestPassed from '../toastComponents/TestPassed.astro';
import TestNotPassed from '../toastComponents/TestNotPassed.astro';

const { missione = null, questions: providedQuestions = [], lang = 'it', slugMis = '' } = Astro.props;

const fallbackQuestions = [
	{
		question: 'Descrizione dell’azione da compiere',
		answers: [{ label: 'Risposta libera' }],
	},
];

const questions = providedQuestions.length > 0 ? providedQuestions : fallbackQuestions;
const firstQuestion = questions[0];
const title = firstQuestion.question;
const eyebrow = missione?.titolo || '';
const quote = missione?.quiz?.descrizione?.trim() || '';
const openQuoteLinksInNewTab = (html: string) =>
	html.replace(/<a\s(?![^>]*\btarget=)/g, '<a target="_blank" rel="noopener noreferrer" ');
const rawQuoteContent = quote ? marked.parse(quote, { async: false }) : '';
const quoteContent = slugMis === 'missione-01-il-varco' ? openQuoteLinksInNewTab(rawQuoteContent) : rawQuoteContent;

const answerLabel = 'Risposta libera';
const hasMultipleQuestions = questions.length > 1;
// Missione 1: la prova raccoglie il numero tessera e lo mette in verifica
// (nessun trofeo immediato, la missione resta in corso).
const isLibraryCardMission = slugMis === 'missione-01-il-varco';
---

<article class="mission-proof-question free-answer-mission" data-free-answer-mission data-lang={lang} aria-label="Prova missione">
	<header class="mission-proof-question__header">
		<div class="container-xl tsbs-app-container mission-proof-question__header-content">
			<p class="mission-proof-question__eyebrow">{eyebrow}</p>
			{console.log("Title:", title)}
			{console.log("FirstQuestion:", firstQuestion.question)}
			<h1 class="mission-proof-question__title mission-component-title">{title}</h1>
		</div>
	</header>

	<div class="container-xl tsbs-app-container mission-proof-question__panel free-answer-mission__panel">
		{quote && (
			<blockquote class="free-answer-mission__quote" set:html={quoteContent} />
		)}

		<form class="free-answer-mission__form" data-free-answer-form>
			<div class="free-answer-mission__field">
				<div class="mission-proof-question__prompt-row">
					<label for="mission-free-answer" data-free-answer-instruction>{firstQuestion.question}</label>

					{hasMultipleQuestions && (
						<div class="mission-proof-question__step-controls" data-free-answer-step-controls>
							<button class="btn mission-proof-question__back" type="button" data-free-answer-back disabled aria-label="Torna alla domanda precedente">
								<i class="bi bi-arrow-left-circle-fill" aria-hidden="true"></i>
							</button>
							<p class="mission-proof-question__progress" data-free-answer-progress aria-live="polite">
								Step 1/{questions.length}
							</p>
						</div>
					)}
				</div>
				<!-- <textarea
					id="mission-free-answer"
					name="risposta-libera"
					rows="8"
					placeholder="Inserisci qui la tua risposta"
					aria-label={answerLabel}
					data-free-answer-input
				></textarea> -->
				<input
					id="mission-free-answer"
					name="risposta-libera"
					type="text"
					class="form-control"
					placeholder="Inserisci qui la tua risposta"
					aria-label={answerLabel}
					data-free-answer-input
				/>
			</div>

			<div class="mission-proof-question__actions">
				<button class="btn tsbs-cta-primary mission-proof-question__cta free-answer-mission__cta" type="submit" data-free-answer-submit disabled>
					Avanti →
				</button>
			</div>

			{isLibraryCardMission && (
				<p class="library-card-error" data-library-card-error role="alert" hidden></p>
			)}
		</form>
	</div>

	{isLibraryCardMission ? (
		<div class="library-card-result" data-library-card-result hidden role="dialog" aria-modal="true" aria-labelledby="library-card-result-title">
			<div class="library-card-result__backdrop" data-library-card-result-close></div>
			<section class="library-card-result__panel">
				<div class="library-card-result__icon" aria-hidden="true">
					<i class="bi bi-hourglass-split"></i>
				</div>
				<h2 id="library-card-result-title">Tessera inviata. È in attesa di verifica da parte della redazione.</h2>
				<a class="btn tsbs-cta-primary library-card-result__button" href="/missioni/">Torna alle missioni</a>
			</section>
		</div>
	) : (
		<>
			<TestPassed renderHidden={true} />
			<TestNotPassed renderHidden={true} buttonHref="/missioni/" />
		</>
	)}
</article>

<script define:vars={{ questions, slugMis }}>
	const setupFreeAnswerMission = () => {
		const root = document.querySelector('[data-free-answer-mission]');
		if (!root || root.dataset.freeAnswerMissionReady === 'true') return;
		root.dataset.freeAnswerMissionReady = 'true';

		const form = root.querySelector('[data-free-answer-form]');
		const instruction = root.querySelector('[data-free-answer-instruction]');
		const input = root.querySelector('[data-free-answer-input]');
		const submit = root.querySelector('[data-free-answer-submit]');
		const back = root.querySelector('[data-free-answer-back]');
		const progress = root.querySelector('[data-free-answer-progress]');
		const passedToast = root.querySelector('.test-result-toast--passed');
		const notPassedToast = root.querySelector('.test-result-toast--not-passed');

		const isLibraryCardMission = slugMis === 'missione-01-il-varco';
		const libraryCardResult = root.querySelector('[data-library-card-result]');
		const libraryCardError = root.querySelector('[data-library-card-error]');

		// Le missioni standard usano i toast esito; la M1 (tessera) usa il proprio pannello.
		if (!form || !instruction || !input || !submit) return;
		if (!isLibraryCardMission && (!passedToast || !notPassedToast)) return;

		let currentPromptIndex = 0;
		const submittedAnswers = new Array(questions.length).fill('');

		const hasAnswer = () => input.value.trim().length > 0;

		const showResultToast = (passed) => {
			if (passedToast) passedToast.hidden = !passed;
			if (notPassedToast) notPassedToast.hidden = passed;
		};

		// Missione 1: la risposta del server riguarda l'invio tessera in verifica,
		// non il superamento di un quiz. Mostra il pannello di conferma o l'errore inline.
		const handleLibraryCardResponse = (ok, message) => {
			if (ok) {
				if (libraryCardError) libraryCardError.hidden = true;
				if (libraryCardResult) libraryCardResult.hidden = false;
				return;
			}
			if (libraryCardError) {
				libraryCardError.textContent = message || 'Non è stato possibile inviare la tessera. Riprova.';
				libraryCardError.hidden = false;
			}
		};

		const validateMissionProof = async () => {
			submit.disabled = true;

			try {
				const response = await fetch(`/api/missioni/${slugMis}/prova`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({
						answers: submittedAnswers.map((answer, questionIndex) => ({ questionIndex, answer })),
					}),
				});
				const payload = await response.json().catch(() => null);

				if (isLibraryCardMission) {
					handleLibraryCardResponse(response.ok && payload?.success === true, payload?.message);
					return;
				}

				const passed = response.ok && payload?.passed === true;
				const trofei = Array.isArray(payload?.trofeiSbloccati) ? payload.trofeiSbloccati : [];

				// Trofeo confermato dal server: la modale trofeo sostituisce il toast esito.
				if (passed && trofei.length > 0) {
					document.dispatchEvent(new CustomEvent('tsbs:trofei-sbloccati', { detail: { trofei } }));
				} else {
					showResultToast(passed);
				}
			} catch {
				if (isLibraryCardMission) {
					handleLibraryCardResponse(false);
				} else {
					showResultToast(false);
				}
			} finally {
				submit.disabled = false;
			}
		};

		const renderPrompt = () => {
			const currentPrompt = questions[currentPromptIndex];
			const isLastPrompt = currentPromptIndex === questions.length - 1;
			const savedAnswer = submittedAnswers[currentPromptIndex] || '';

			const headerTitle = root.querySelector('.mission-proof-question__title');
			if (headerTitle) headerTitle.textContent = currentPrompt.question;
			instruction.textContent = currentPrompt.question;
			input.value = savedAnswer;
			input.setAttribute('placeholder', 'Inserisci qui la tua risposta');
			submit.innerHTML = isLastPrompt
				? '<span>Concludi la prova</span><i class="bi bi-stars free-answer-mission__complete-icon" aria-hidden="true"></i>'
				: 'Avanti →';
			submit.disabled = !hasAnswer();

			if (back) back.disabled = currentPromptIndex === 0;
			if (progress) progress.textContent = `Step ${currentPromptIndex + 1}/${questions.length}`;
		};

		input.addEventListener('input', () => {
			submit.disabled = !hasAnswer();
			if (libraryCardError) libraryCardError.hidden = true;
		});

		if (libraryCardResult) {
			libraryCardResult.querySelectorAll('[data-library-card-result-close]').forEach((element) => {
				element.addEventListener('click', () => {
					libraryCardResult.hidden = true;
				});
			});
		}

		if (back) {
			back.addEventListener('click', () => {
				if (currentPromptIndex === 0) return;
				submittedAnswers[currentPromptIndex] = input.value.trim();
				currentPromptIndex -= 1;
				renderPrompt();
			});
		}

		form.addEventListener('submit', (event) => {
			event.preventDefault();

			if (!hasAnswer()) return;
			submittedAnswers[currentPromptIndex] = input.value.trim();

			if (currentPromptIndex < questions.length - 1) {
				currentPromptIndex += 1;
				renderPrompt();
				return;
			}

			validateMissionProof();
		});

		renderPrompt();
	};

	document.addEventListener('astro:page-load', setupFreeAnswerMission);
	setupFreeAnswerMission();
</script>

<style lang="scss">
	.free-answer-mission__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}

	.free-answer-mission__complete-icon {
		color: var(--tsbs-color-white);
		font-size: 1.125rem;
		line-height: 1;
	}

	.library-card-error {
		margin: 0.75rem 0 0;
		color: #c0392b;
		font-size: 0.875rem;
		line-height: 1.35;
	}

	.library-card-result {
		position: fixed;
		inset: 0;
		z-index: 1200;
		display: grid;
		align-items: center;
		justify-items: center;
		padding: 1.75rem;
	}

	.library-card-result__backdrop {
		position: absolute;
		inset: 0;
		background: color-mix(in srgb, var(--tsbs-color-surface) 68%, transparent);
		backdrop-filter: grayscale(0.7) blur(0.0625rem);
	}

	.library-card-result__panel {
		position: relative;
		display: grid;
		justify-items: center;
		gap: 1.25rem;
		width: min(100%, 23.4375rem);
		padding: 1.75rem 1.5rem;
		text-align: center;
		background: var(--tsbs-color-white);
		border-radius: 0.75rem;
		box-shadow: 0 1.25rem 3rem color-mix(in srgb, var(--tsbs-theme-accent) 20%, transparent);
	}

	.library-card-result__icon {
		display: grid;
		place-items: center;
		color: var(--tsbs-theme-accent);
	}

	.library-card-result__icon .bi {
		font-size: 3.5rem;
		line-height: 1;
	}

	.library-card-result__panel h2 {
		margin: 0;
		color: var(--tsbs-color-heading);
		font-family: var(--tsbs-font-body);
		font-size: 1rem;
		font-weight: 400;
		line-height: 1.3;
	}

	.library-card-result__button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		min-height: 3rem;
		font-weight: 800;
		border-radius: 0.25rem;
	}

	@media (min-width: 992px) {
		.library-card-result {
			padding-left: calc(var(--tsbs-desktop-nav-width) + 1.75rem);
		}
	}

</style>
