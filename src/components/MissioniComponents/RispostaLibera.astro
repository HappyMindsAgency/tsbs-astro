---
import { marked } from 'marked';
import TestPassed from '../toastComponents/TestPassed.astro';
import TestNotPassed from '../toastComponents/TestNotPassed.astro';

const { missione = null, questions: providedQuestions = [], lang = 'it', slugMis = '' } = Astro.props;

const fallbackQuestions = [
	{
		question: 'Descrizione dell’azione da compiere',
		answers: [{ label: 'Risposta libera' }],
	},
];

const questions = providedQuestions.length > 0 ? providedQuestions : fallbackQuestions;
const firstQuestion = questions[0];
const title = firstQuestion.question;
const eyebrow = missione?.titolo || 'NOME DELLA MISSIONE';
const quote = missione?.quiz?.descrizione?.trim() || '';
const quoteContent = quote ? marked.parse(quote, { async: false }) : '';

const answerLabel = 'Risposta libera';
const hasMultipleQuestions = questions.length > 1;
---

<article class="mission-proof-question free-answer-mission" data-free-answer-mission data-lang={lang} aria-label="Prova missione">
	<header class="mission-proof-question__header">
		<div class="container-xl tsbs-app-container mission-proof-question__header-content">
			<p class="mission-proof-question__eyebrow">{eyebrow}</p>
			<h1 class="mission-proof-question__title mission-component-title">{title}</h1>
		</div>
	</header>

	<div class="container-xl tsbs-app-container mission-proof-question__panel free-answer-mission__panel">
		{quote && (
			<blockquote class="free-answer-mission__quote" set:html={quoteContent} />
		)}

		<form class="free-answer-mission__form" data-free-answer-form>
			<div class="free-answer-mission__field">
				<div class="mission-proof-question__prompt-row">
					<label for="mission-free-answer" data-free-answer-instruction>{firstQuestion.question}</label>

					{hasMultipleQuestions && (
						<div class="mission-proof-question__step-controls" data-free-answer-step-controls>
							<button class="btn mission-proof-question__back" type="button" data-free-answer-back disabled aria-label="Torna alla domanda precedente">
								<i class="bi bi-arrow-left-circle-fill" aria-hidden="true"></i>
							</button>
							<p class="mission-proof-question__progress" data-free-answer-progress aria-live="polite">
								1/{questions.length}
							</p>
						</div>
					)}
				</div>
				<textarea
					id="mission-free-answer"
					name="risposta-libera"
					rows="8"
					placeholder="Inserisci qui la tua risposta"
					aria-label={answerLabel}
					data-free-answer-input
				></textarea>
			</div>

			<div class="mission-proof-question__actions">
				<button class="btn tsbs-cta-primary mission-proof-question__cta free-answer-mission__cta" type="submit" data-free-answer-submit disabled>
					Avanti →
				</button>
			</div>
		</form>
	</div>

	<TestPassed renderHidden={true} />
	<TestNotPassed renderHidden={true} buttonHref="/missioni/" />
</article>

<script define:vars={{ questions, slugMis }}>
	const setupFreeAnswerMission = () => {
		const root = document.querySelector('[data-free-answer-mission]');
		if (!root) return;

		const form = root.querySelector('[data-free-answer-form]');
		const instruction = root.querySelector('[data-free-answer-instruction]');
		const input = root.querySelector('[data-free-answer-input]');
		const submit = root.querySelector('[data-free-answer-submit]');
		const back = root.querySelector('[data-free-answer-back]');
		const progress = root.querySelector('[data-free-answer-progress]');
		const passedToast = root.querySelector('.test-result-toast--passed');
		const notPassedToast = root.querySelector('.test-result-toast--not-passed');

		if (!form || !instruction || !input || !submit || !passedToast || !notPassedToast) return;

		let currentPromptIndex = 0;
		const submittedAnswers = new Array(questions.length).fill('');

		const hasAnswer = () => input.value.trim().length > 0;

		const showResultToast = (passed) => {
			passedToast.hidden = !passed;
			notPassedToast.hidden = passed;
		};

		const validateMissionProof = async () => {
			submit.disabled = true;

			try {
				const response = await fetch(`/api/missioni/${slugMis}/prova`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({
						answers: submittedAnswers.map((answer, questionIndex) => ({ questionIndex, answer })),
					}),
				});
				const payload = await response.json().catch(() => null);

				showResultToast(response.ok && payload?.passed === true);
			} catch {
				showResultToast(false);
			} finally {
				submit.disabled = false;
			}
		};

		const renderPrompt = () => {
			const currentPrompt = questions[currentPromptIndex];
			const isLastPrompt = currentPromptIndex === questions.length - 1;
			const savedAnswer = submittedAnswers[currentPromptIndex] || '';

			const headerTitle = root.querySelector('.mission-proof-question__title');
			if (headerTitle) headerTitle.textContent = currentPrompt.question;
			instruction.textContent = currentPrompt.question;
			input.value = savedAnswer;
			input.setAttribute('placeholder', 'Inserisci qui la tua risposta');
			submit.innerHTML = isLastPrompt
				? '<span>Concludi la prova</span><i class="bi bi-stars free-answer-mission__complete-icon" aria-hidden="true"></i>'
				: 'Avanti →';
			submit.disabled = !hasAnswer();

			if (back) back.disabled = currentPromptIndex === 0;
			if (progress) progress.textContent = `${currentPromptIndex + 1}/${questions.length}`;
		};

		input.addEventListener('input', () => {
			submit.disabled = !hasAnswer();
		});

		if (back) {
			back.addEventListener('click', () => {
				if (currentPromptIndex === 0) return;
				submittedAnswers[currentPromptIndex] = input.value.trim();
				currentPromptIndex -= 1;
				renderPrompt();
			});
		}

		form.addEventListener('submit', (event) => {
			event.preventDefault();

			if (!hasAnswer()) return;
			submittedAnswers[currentPromptIndex] = input.value.trim();

			if (currentPromptIndex < questions.length - 1) {
				currentPromptIndex += 1;
				renderPrompt();
				return;
			}

			validateMissionProof();
		});

		renderPrompt();
	};

	document.addEventListener('astro:page-load', setupFreeAnswerMission);
	setupFreeAnswerMission();
</script>

<style lang="scss">
	.free-answer-mission__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}

	.free-answer-mission__complete-icon {
		color: var(--tsbs-color-white);
		font-size: 1.125rem;
		line-height: 1;
	}

</style>
