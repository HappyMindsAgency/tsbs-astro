---
import TestNotPassed from '../toastComponents/TestNotPassed.astro';
import TestPassed from '../toastComponents/TestPassed.astro';

const { missione = null, lang = 'it', slugMis = '' } = Astro.props;

const title =
	missione?.titolo ||
	missione?.nome ||
	missione?.title ||
	'Lorem ipsum dolor sit amet, consectetur adipiscing elit.';

const eyebrow =
	missione?.nomeMissione ||
	missione?.label ||
	'NOME DELLA MISSIONE';

const quote =
	missione?.citazione ||
	missione?.quote ||
	missione?.descrizioneBreve ||
	'Phasellus accumsan, felis sed dictum gravida, est leo congue mauris, nec luctus sem nisi a ante. Aenean quis facilisis augue, eget ornare odio. Proin non arcu vel erat finibus venenatis.';

const answerLabel = missione?.prova?.labelRisposta || 'Risposta libera';
const prompts = [
	{
		instruction: 'Descrizione dell’azione da compiere',
		placeholder: 'Inserisci qui la tua risposta',
	},
	{
		instruction: 'Descrizione della seconda azione da compiere',
		placeholder: 'Inserisci qui la tua seconda risposta',
	},
	{
		instruction: 'Descrizione della terza azione da compiere',
		placeholder: 'Inserisci qui la tua terza risposta',
	},
];

const firstPrompt = prompts[0];
---

<article class="mission-proof-question free-answer-mission" data-free-answer-mission data-lang={lang} aria-label="Prova missione">
	<header class="mission-proof-question__header">
		<div class="container-xl tsbs-app-container mission-proof-question__header-content">
			<p class="mission-proof-question__eyebrow">{eyebrow}</p>
			<h1 class="mission-proof-question__title mission-component-title">{title}</h1>
		</div>
	</header>

	<div class="container-xl tsbs-app-container mission-proof-question__panel free-answer-mission__panel">
		<blockquote class="free-answer-mission__quote">
			<p>{quote}</p>
		</blockquote>

		<form class="free-answer-mission__form" data-free-answer-form>
			<div class="free-answer-mission__field">
				<label for="mission-free-answer" data-free-answer-instruction>{firstPrompt.instruction}</label>
				<textarea
					id="mission-free-answer"
					name="risposta-libera"
					rows="8"
					placeholder={firstPrompt.placeholder}
					aria-label={answerLabel}
					data-free-answer-input
				></textarea>
			</div>

			<button class="btn tsbs-cta-primary mission-proof-question__cta free-answer-mission__cta" type="submit" data-free-answer-submit hidden>
				Avanti →
			</button>
		</form>
	</div>

	<TestNotPassed renderHidden={true} />
</article>

<script define:vars={{ prompts }}>
	const setupFreeAnswerMission = () => {
		const root = document.querySelector('[data-free-answer-mission]');
		if (!root) return;

		const form = root.querySelector('[data-free-answer-form]');
		const instruction = root.querySelector('[data-free-answer-instruction]');
		const input = root.querySelector('[data-free-answer-input]');
		const submit = root.querySelector('[data-free-answer-submit]');
		const toast = root.querySelector('[data-test-result-toast]');

		if (!form || !instruction || !input || !submit || !toast) return;

		let currentPromptIndex = 0;

		const hasAnswer = () => input.value.trim().length > 0;

		const renderPrompt = () => {
			const currentPrompt = prompts[currentPromptIndex];
			const isLastPrompt = currentPromptIndex === prompts.length - 1;

			instruction.textContent = currentPrompt.instruction;
			input.value = '';
			input.setAttribute('placeholder', currentPrompt.placeholder);
			submit.innerHTML = isLastPrompt
				? '<span>Concludi la prova</span><i class="bi bi-stars free-answer-mission__complete-icon" aria-hidden="true"></i>'
				: 'Avanti →';
			submit.hidden = true;
		};

		input.addEventListener('input', () => {
			submit.hidden = !hasAnswer();
		});

		form.addEventListener('submit', (event) => {
			event.preventDefault();

			if (!hasAnswer()) return;

			if (currentPromptIndex < prompts.length - 1) {
				currentPromptIndex += 1;
				renderPrompt();
				return;
			}

			toast.hidden = false;
		});

		renderPrompt();
	};

	document.addEventListener('astro:page-load', setupFreeAnswerMission);
	setupFreeAnswerMission();
</script>

<style lang="scss">
	.free-answer-mission__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}

	.free-answer-mission__complete-icon {
		color: var(--tsbs-color-white);
		font-size: 1.125rem;
		line-height: 1;
	}

</style>
