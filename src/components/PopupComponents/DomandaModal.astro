---
interface Answer {
	label: string;
	description: string;
}

interface Props {
	isOpen?: boolean;
	question?: string;
	answers?: Answer[];
	buttonLabel?: string;
}

const {
	isOpen = false,
	question = 'Scegli una sola risposta',
	answers = [
		{ label: 'Risposta A', description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut' },
		{ label: 'Risposta B', description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut' },
		{ label: 'Risposta C', description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut' },
		{ label: 'Risposta D', description: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut' },
	],
	buttonLabel = 'Conferma',
} = Astro.props as Props;
---

<div
	class="question-modal"
	data-question-modal
	hidden={!isOpen}
	role="dialog"
	aria-modal="true"
	aria-labelledby="question-modal-title"
>
	<div class="question-modal__backdrop" data-question-modal-close></div>

	<section class="question-modal__panel" aria-describedby="question-modal-copy">
		<button class="question-modal__close" type="button" data-question-modal-close aria-label="Chiudi">
			<i class="bi bi-x-lg" aria-hidden="true"></i>
		</button>

		<form class="question-modal__form" data-question-modal-form>
			<fieldset class="question-modal__fieldset">
				<legend id="question-modal-title">{question}</legend>
				<p class="visually-hidden" id="question-modal-copy">Seleziona una risposta per confermare il libro letto.</p>

				<div class="question-modal__answers">
					{answers.map((answer, index) => (
						<label class="question-modal__answer" for={`question-modal-answer-${index}`}>
							<input id={`question-modal-answer-${index}`} type="radio" name="domanda-modal-risposta" value={answer.label} />
							<span class="question-modal__answer-label">{answer.label}</span>
							<span class="question-modal__answer-description">{answer.description}</span>
						</label>
					))}
				</div>
			</fieldset>

			<button class="btn tsbs-cta-primary question-modal__cta" type="submit" data-question-modal-submit hidden>
				{buttonLabel}
			</button>
		</form>
	</section>
</div>

<script>
	const setupQuestionModal = () => {
		document.querySelectorAll<HTMLElement>('[data-question-modal]').forEach((modal) => {
			if (modal.dataset.questionModalReady === 'true') return;
			modal.dataset.questionModalReady = 'true';

			const form = modal.querySelector<HTMLFormElement>('[data-question-modal-form]');
			const submit = modal.querySelector<HTMLButtonElement>('[data-question-modal-submit]');
			const answersContainer = modal.querySelector<HTMLElement>('.question-modal__answers');
			const closeControls = modal.querySelectorAll<HTMLElement>('[data-question-modal-close]');
			let activeInput: HTMLInputElement | null = null;
			let previousFocus: HTMLElement | null = null;

			if (!form || !submit || !answersContainer) return;

			const getAnswerInputs = () => modal.querySelectorAll<HTMLInputElement>('input[name="domanda-modal-risposta"]');

			const resetAnswers = () => {
				getAnswerInputs().forEach((answer) => {
					answer.checked = false;
				});
				submit.hidden = true;
			};

			// Risposte dinamiche: usate dalla sfida lettura per proporre gli
			// estratti del giorno generati dal server.
			const renderAnswers = (answers: Array<{ label?: string; description?: string }>) => {
				answersContainer.replaceChildren(
					...answers.map((answer, index) => {
						const id = `question-modal-answer-${index}`;
						const label = document.createElement('label');
						const input = document.createElement('input');

						label.className = 'question-modal__answer';
						label.setAttribute('for', id);
						input.id = id;
						input.type = 'radio';
						input.name = 'domanda-modal-risposta';
						input.value = String(index);
						label.append(input);

						if (answer.label) {
							const answerLabel = document.createElement('span');
							answerLabel.className = 'question-modal__answer-label';
							answerLabel.textContent = answer.label;
							label.append(answerLabel);
						}

						if (answer.description) {
							const answerDescription = document.createElement('span');
							answerDescription.className = 'question-modal__answer-description';
							answerDescription.textContent = answer.description;
							label.append(answerDescription);
						}

						return label;
					}),
				);
			};

			const closeModal = ({ undoSelection = true }: { undoSelection?: boolean } = {}) => {
				modal.hidden = true;
				delete modal.dataset.questionModalVariant;

				if (undoSelection && activeInput) {
					activeInput.checked = false;
				}

				resetAnswers();
				activeInput = null;

				if (previousFocus) {
					previousFocus.focus();
				}
			};

			const openModal = (input: HTMLInputElement | null, answers?: Array<{ label?: string; description?: string }>, variant = '') => {
				activeInput = input || null;
				previousFocus = document.activeElement instanceof HTMLElement ? document.activeElement : null;
				if (variant) {
					modal.dataset.questionModalVariant = variant;
				} else {
					delete modal.dataset.questionModalVariant;
				}

				if (Array.isArray(answers) && answers.length > 0) {
					renderAnswers(answers);
				}

				resetAnswers();
				modal.hidden = false;

				const closeButton = modal.querySelector<HTMLButtonElement>('.question-modal__close');
				if (closeButton) {
					closeButton.focus();
				}
			};

			document.addEventListener('tsbs:question-modal-open', (event) => {
				if (!(event instanceof CustomEvent)) return;

				const input = event.detail?.input instanceof HTMLInputElement ? event.detail.input : null;
				openModal(input, event.detail?.answers, String(event.detail?.variant ?? ''));
			});

			closeControls.forEach((control) => {
				control.addEventListener('click', () => closeModal());
			});

			// Delegazione: le risposte possono essere rigenerate dinamicamente.
			answersContainer.addEventListener('change', () => {
				submit.hidden = !modal.querySelector('input[name="domanda-modal-risposta"]:checked');
			});

			form.addEventListener('submit', (event) => {
				event.preventDefault();

				const selected = modal.querySelector<HTMLInputElement>('input[name="domanda-modal-risposta"]:checked');
				if (!selected) return;

				// Notifica la pagina ospite della risposta confermata (es. sfida lettura).
				document.dispatchEvent(
					new CustomEvent('tsbs:question-modal-submit', {
						detail: { value: selected.value, input: activeInput },
					}),
				);

				closeModal({ undoSelection: false });
			});

			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape' && !modal.hidden) {
					closeModal();
				}
			});
		});
	};

	document.addEventListener('astro:page-load', setupQuestionModal);
	setupQuestionModal();
</script>

<style lang="scss">
	.question-modal {
		--question-modal-accent: var(--tsbs-theme-accent);
		position: fixed;
		inset: 0;
		z-index: 1080;
		display: grid;
		align-items: end;
		padding: 1rem;
	}

	.question-modal[hidden] {
		display: none;
	}

	.question-modal__backdrop {
		position: absolute;
		inset: 0;
		background: color-mix(in srgb, var(--tsbs-color-heading) 56%, transparent);
	}

	.question-modal__panel {
		position: relative;
		z-index: 1;
		width: min(100%, 42rem);
		max-height: min(42rem, calc(100dvh - 2rem));
		overflow-y: auto;
		justify-self: center;
		padding: 2.75rem 1.25rem 1.5rem;
		background: var(--tsbs-color-surface);
		border: 1px solid color-mix(in srgb, var(--question-modal-accent) 18%, var(--tsbs-color-white));
		border-radius: 0.875rem;
		box-shadow: 0 1.25rem 3rem color-mix(in srgb, var(--question-modal-accent) 20%, transparent);
	}

	.question-modal__close {
		position: absolute;
		top: 0.875rem;
		right: 0.875rem;
		display: inline-grid;
		place-items: center;
		width: 2.25rem;
		height: 2.25rem;
		padding: 0;
		color: var(--tsbs-color-white);
		background: var(--question-modal-accent);
		border: 1px solid var(--question-modal-accent);
		border-radius: 999rem;
	}

	.question-modal__close:hover {
		color: var(--tsbs-color-white);
		background: var(--tsbs-theme-cta-hover-bg);
		border-color: var(--tsbs-theme-cta-hover-border);
	}

	.question-modal__close:focus-visible {
		outline: 0.1875rem solid var(--tsbs-color-focus);
		outline-offset: 0.1875rem;
	}

	.question-modal__form,
	.question-modal__fieldset,
	.question-modal__answers {
		display: grid;
	}

	.question-modal__form {
		gap: 2rem;
	}

	.question-modal__fieldset {
		gap: 2rem;
		padding: 0;
		margin: 0;
		border: 0;
	}

	.question-modal__fieldset legend {
		float: none;
		padding: 0 2.25rem 0.75rem 0;
		margin: 0;
		color: var(--tsbs-color-heading);
		font-size: 1rem;
		font-weight: 400;
		line-height: 1.35;
	}

	.question-modal__answers {
		justify-items: center;
		gap: 1rem;
	}

	.question-modal__answer {
		position: relative;
		display: grid;
		align-content: center;
		place-items: center;
		gap: 0.375rem;
		width: min(100%, 17.875rem);
		min-height: 5.5rem;
		padding: 1rem;
		color: var(--tsbs-color-heading);
		text-align: center;
		cursor: pointer;
		background: #cfcfcf;
		border: 1px solid transparent;
		border-radius: var(--tsbs-radius-md);
	}

	.question-modal__answer input {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		margin: 0;
		cursor: pointer;
		opacity: 0;
	}

	.question-modal__answer span {
		position: relative;
		z-index: 1;
		color: inherit;
	}

	.question-modal__answer-label {
		font-size: 1.375rem;
		font-weight: 400;
		line-height: 1.1;
	}

	.question-modal__answer-description {
		font-size: 0.875rem;
		font-weight: 400;
		line-height: 1.25;
	}

	.question-modal__answer:has(input:checked) {
		color: var(--tsbs-color-white);
		background: var(--question-modal-accent);
	}

	.question-modal__answer:has(input:focus-visible) {
		outline: 0.1875rem solid var(--tsbs-color-focus);
		outline-offset: 0.1875rem;
	}

	:global(.question-modal[data-question-modal-variant="reading-challenge"] .question-modal__answers) {
		display: grid;
		justify-items: stretch;
		gap: 1.25rem;
	}

	:global(.question-modal[data-question-modal-variant="reading-challenge"] .question-modal__answer) {
		position: relative;
		display: grid;
		grid-template-columns: 1.125rem minmax(0, 1fr);
		align-items: start;
		gap: 0.75rem;
		width: 100%;
		min-height: 0;
		padding: 0;
		color: #666666;
		text-align: left;
		cursor: pointer;
		background: transparent;
		border: 0;
		border-radius: 0;
	}

	:global(.question-modal[data-question-modal-variant="reading-challenge"] .question-modal__answer input) {
		position: static;
		width: 1rem;
		height: 1rem;
		margin: 0.1875rem 0 0;
		cursor: pointer;
		opacity: 1;
		accent-color: var(--question-modal-accent);
	}

	:global(.question-modal[data-question-modal-variant="reading-challenge"] .question-modal__answer span) {
		position: static;
		z-index: auto;
		color: inherit;
	}

	:global(.question-modal[data-question-modal-variant="reading-challenge"] .question-modal__answer-description) {
		font-size: 1rem;
		font-weight: 400;
		line-height: 1.5;
	}

	:global(.question-modal[data-question-modal-variant="reading-challenge"] .question-modal__answer:has(input:checked)) {
		color: var(--tsbs-color-heading);
		background: transparent;
	}

	:global(.question-modal[data-question-modal-variant="reading-challenge"] .question-modal__answer:has(input:focus-visible)) {
		outline: 0.1875rem solid var(--tsbs-color-focus);
		outline-offset: 0.25rem;
		border-radius: 0.25rem;
	}

	.question-modal__cta {
		justify-self: center;
		width: min(100%, 20.4375rem);
		min-height: 3rem;
		padding: 0.875rem 1.5rem;
		color: var(--tsbs-color-white);
		font-family: var(--tsbs-font-body);
		font-weight: 800;
		line-height: 1;
		border-radius: var(--tsbs-radius-sm);
	}

	@media (min-width: 768px) {
		.question-modal {
			align-items: center;
			padding: 2rem;
		}

		.question-modal__panel {
			padding: 3rem 2.5rem 2.5rem;
		}

		.question-modal__form {
			gap: 2.5rem;
		}

		.question-modal__answers {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 1.25rem;
		}

		.question-modal__answer {
			width: 100%;
		}

		:global(.question-modal[data-question-modal-variant="reading-challenge"] .question-modal__answers) {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			column-gap: 2rem;
			row-gap: 1.5rem;
		}
	}

	@media (min-width: 992px) {
		.question-modal {
			padding-left: calc(var(--tsbs-desktop-nav-width) + 2rem);
		}
	}
</style>
