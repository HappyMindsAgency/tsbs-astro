---
import arboreaBanner from '../../assets/Arborea-accademia-stendardo-the-secret-bookish-society.png';
import arcadiaBanner from '../../assets/Arcadia-accademia-stendardo-the-secret-bookish-society.png';
import armoniaBanner from '../../assets/Armonia-accademia-stendardo-the-secret-bookish-society.png';
import astrariaBanner from '../../assets/Astraria-accademia-stendardo-the-secret-bookish-society.png';

type AcademyKey = 'astraria' | 'arcadia' | 'armonia' | 'arborea';

const academyLabels: Record<AcademyKey, string> = {
	astraria: 'Astraria',
	arcadia: 'Arcadia',
	armonia: 'Armonia',
	arborea: 'Arborea',
};

const academyBanners = {
	astraria: astrariaBanner,
	arcadia: arcadiaBanner,
	armonia: armoniaBanner,
	arborea: arboreaBanner,
};

const academyResultCopy: Partial<Record<AcademyKey, string>> = {
	astraria:
		"C’è una luce che brilla solo nell’oscurità. Benvenuto tra chi sa leggere tra le righe e oltre le stelle.\n\nAstraria è il rifugio dei notturni e degli visionari. Qui si esplora l'invisibile: il lato onirico della Biblioteca, i messaggi cifrati, ciò che è rimasto non detto. Non cerchiamo risposte ovvie, ma domande che aprano nuovi mondi nel silenzio della mezzanotte.\n\nTi attendono decifrazioni di segni invisibili e sfide da superare. Dovrai spingerti dove gli altri vedono solo ombre, usando la tua intuizione per sollevare il velo sui segreti più profondi e silenziosi che la Biblioteca sussurra solo a chi sa ascoltare.",
	arcadia:
		"La tua ambizione ha trovato il suo specchio.\nBenvenuto dove la parola è potere e la forma è sostanza.\n\nSei nel cuore nobile della Società segreta. Arcadia custodisce il rigore del pensiero classico e la precisione del linguaggio. Qui studiare non è solo apprendere, è dominare la complessità per distinguersi dalla massa.\n\nTi attendono prove di rango e sfide di logica testuale. Sarai chiamato a conquistare la verità celata tra le righe, dimostrando che la tua mente possiede il rigore necessario per ordinare il caos e reclamare il tuo posto tra i custodi dell'eccellenza.",
	armonia:
		"Le pagine si animano solo quando vengono condivise. Unisciti al coro che trasforma il silenzio in musica.\n\nIn Armonia, il sapere non è mai un atto isolato. Ci ispiriamo agli artisti e ai viaggiatori, che hanno trovato in Classense una scintilla creativa. Crediamo nel dialogo, nella bellezza degli incontri e nella capacità della letteratura di unire anime diverse in un’unica visione.\n\nTi attendono incontri inaspettati e creazioni corali. Ogni enigma sarà l'occasione per riallacciare un dialogo interrotto con i membri passati della società segreta, trasformando la tua ricerca in un ponte vibrante tra la storia e il presente della Biblioteca.",
	arborea:
		'Ascolta il respiro dei chiostri.\nSei a casa, custode di tutto ciò che cresce e resiste al tempo.\n\nArborea è il legame indissolubile tra la Biblioteca e la sua terra. Come le piccole anime che abitano i nostri cortili, impariamo la pazienza. Il tuo ruolo è proteggere la fragilità della materia, dai libri antichi alle pinete storiche, curando le radici che alimentano il presente.\n\nTi attendono atti di protezione e indagini sul campo. Sarai chiamato a presidiare il patrimonio della Classense, rintracciando le storie che hanno messo radici tra questi chiostri e assicurandoti che nessun frammento del nostro passato vada perduto o dimenticato.',
};

const fallbackResultCopy =
	'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Morbi at est et tortor laoreet placerat id in neque.';

const normalizeAcademy = (value: unknown): AcademyKey | null => {
	if (typeof value !== 'string') {
		return null;
	}

	const normalized = value.toLowerCase().trim();
	return normalized in academyLabels ? normalized as AcademyKey : null;
};

const { academy, lang = 'it' } = Astro.props;
const currentAcademy = normalizeAcademy(academy);
if (!currentAcademy) {
	throw new Error('Missing valid academy for sorting result');
}
const academyName = academyLabels[currentAcademy];
const academyBanner = academyBanners[currentAcademy];
// Avatar animato dell'accademia (loop): file in public/animation/, prefisso = accademia.
const academyAvatarLottie = `/animation/${currentAcademy}-accademyavatar.lottie`;
const resultCopy = academyResultCopy[currentAcademy] ?? fallbackResultCopy;
const avatarChoiceUrl = '/test-smistamento/scegli-avatar/';
const confirmHref = `${avatarChoiceUrl}?academy=${encodeURIComponent(currentAcademy)}`;
const chooseHref = `/test-smistamento/?step=conferma-accademia&academy=${encodeURIComponent(currentAcademy)}`;
---

<section class="sorting-result-page" data-academy={currentAcademy} data-lang={lang} aria-labelledby="sorting-result-title">
	<article class="sorting-result">
		<div class="sorting-result__visual" aria-hidden="true">
			<img
				class="sorting-result__banner"
				src={academyBanner.src}
				width={academyBanner.width}
				height={academyBanner.height}
				alt=""
				loading="eager"
			/>

			<canvas
				class="sorting-result__avatar"
				data-avatar-lottie
				data-avatar-lottie-src={academyAvatarLottie}
				aria-hidden="true"
			></canvas>
		</div>

		<div class="sorting-result__panel">
			<h1 id="sorting-result-title">
				<span class="sorting-result__title-light">Benvenut* in</span>
				<span class="sorting-result__title-bold">Accademia {academyName}</span>
			</h1>
			<div class="sorting-result__copy">
				{
					resultCopy.split('\n\n').map((paragraph) => (
						<p>
							{paragraph.split('\n').map((line, lineIndex, lines) => (
								<>
									{line}
									{lineIndex < lines.length - 1 && <br />}
								</>
							))}
						</p>
					))
				}
			</div>

			<div class="sorting-result__actions">
				<button
					type="button"
					class="btn tsbs-cta-primary mission-proof-question__cta sorting-result__button"
					data-confirm-result-academy={currentAcademy}
					data-confirm-result-href={confirmHref}
				>Entra in {academyName}</button>
				<a class="sorting-result__link" href={chooseHref}>
					<span>Vuoi seguire un’altra via?</span>
					<strong>Cambia Accademia</strong>
				</a>
			</div>
		</div>
	</article>
</section>

<style lang="scss">
	.sorting-result-page {
		--sorting-result-accent: var(--tsbs-theme-accent);
		--sorting-result-muted: var(--tsbs-color-body);
		--sorting-result-soft: color-mix(in srgb, var(--sorting-result-accent) 13%, var(--tsbs-color-surface));
		--sorting-result-photo-bg: #ffffff;
		--sorting-result-line: color-mix(in srgb, var(--sorting-result-accent) 18%, var(--tsbs-color-white));
		--sorting-result-panel: var(--tsbs-color-white);
		--sorting-result-shadow: 0 1.125rem 3rem color-mix(in srgb, var(--sorting-result-accent) 14%, transparent);
		--sorting-result-visual-height: clamp(7.5rem, 22svh, 10.75rem);
		--sorting-result-banner-height: clamp(8rem, 22svh, 10.75rem);
		--sorting-result-panel-width: 100%;
		--sorting-result-cta-width: min(100%, 20.5rem);
		--sorting-result-cta-height: clamp(2.625rem, 7svh, 3.25rem);
		--sorting-result-cta-gap: clamp(0.5rem, 1.8svh, 0.875rem);

		display: grid;
		place-items: stretch center;
		min-height: 100vh;
		min-height: 100svh;
		overflow: visible;
		padding: 0;
		color: var(--sorting-result-muted);
		background-color: var(--sorting-result-photo-bg);
		background-image:
			var(--tsbs-page-pattern-overlay),
			var(--tsbs-page-pattern-image);
		background-repeat: repeat;
		background-position: top left;
		background-size: var(--tsbs-page-pattern-size);
	}

	.sorting-result {
		position: relative;
		display: grid;
		grid-template-rows: var(--sorting-result-visual-height) auto;
		align-content: center;
		width: 100%;
		min-height: 100vh;
		min-height: 100svh;
		overflow: visible;
		background-color: var(--sorting-result-photo-bg);
		background-image:
			var(--tsbs-page-pattern-overlay),
			var(--tsbs-page-pattern-image);
		background-repeat: repeat;
		background-position: top left;
		background-size: var(--tsbs-page-pattern-size);
		border: 0;
		border-radius: 0;
		box-shadow: none;
	}

	.sorting-result__visual {
		position: relative;
		z-index: 4;
		min-height: var(--sorting-result-visual-height);
		overflow: visible;
		pointer-events: none;
	}

	.sorting-result__banner {
		position: absolute;
		bottom: -1.125rem;
		left: 50%;
		z-index: 4;
		width: auto;
		height: var(--sorting-result-banner-height);
		filter: none;
		transform: translateX(-50%);
	}

	.sorting-result__avatar {
		position: absolute;
		right: clamp(1rem, 7vw, 2rem);
		bottom: -0.25rem;
		z-index: 5;
		width: clamp(8rem, 40vw, 10rem);
		/* canvas non ha aspect-ratio intrinseco: lo forziamo quadrato */
		/* ponytail: avatar assunto quadrato; se non lo è, regola qui */
		aspect-ratio: 1 / 1;
		height: auto;
		pointer-events: none;
	}

	.sorting-result__panel {
		position: relative;
		z-index: 3;
		display: grid;
		gap: clamp(0.5rem, 1.8svh, 0.875rem);
		align-content: start;
		width: 100%;
		min-height: 0;
		padding: clamp(0.75rem, 2.2svh, 1.25rem) 1.5rem calc(clamp(0.75rem, 2svh, 1.125rem) + env(safe-area-inset-bottom));
		overflow: visible;
		background: var(--sorting-result-panel);
		border-radius: 1.25rem 1.25rem 0 0;
	}

	.sorting-result__eyebrow {
		margin: 0;
		color: color-mix(in srgb, var(--sorting-result-accent) 78%, var(--tsbs-color-body));
		font-size: 0.75rem;
		font-weight: 700;
		line-height: 1.2;
		text-transform: uppercase;
	}

	.sorting-result__panel h1 {
		margin: 0;
		color: var(--sorting-result-accent);
		font-family: var(--tsbs-font-heading-academy);
		font-size: clamp(1.45rem, 5.2svh, 2rem);
		font-weight: 300;
		line-height: 1.06;
		letter-spacing: 0;
	}

	.sorting-result__title-light,
	.sorting-result__title-bold {
		display: block;
		color: var(--sorting-result-accent);
	}

	.sorting-result__title-light {
		font-weight: 300;
	}

	.sorting-result__title-bold {
		font-weight: 700;
	}

	.sorting-result__copy {
		display: grid;
		gap: clamp(0.45rem, 1.5svh, 0.875rem);
	}

	.sorting-result__copy p {
		margin: 0;
		color: var(--tsbs-color-heading);
		font-size: clamp(0.875rem, 1.9svh, 1rem);
		line-height: 1.3;
	}

	.sorting-result__actions {
		display: grid;
		gap: var(--sorting-result-cta-gap);
		justify-items: center;
		justify-self: center;
		width: var(--sorting-result-cta-width);
		margin-top: clamp(0rem, 0.8svh, 0.375rem);
	}

	.sorting-result__button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: var(--sorting-result-cta-height);
		min-height: var(--sorting-result-cta-height);
		padding: 0.75rem 1rem;
	}

	.sorting-result__link {
		display: grid;
		gap: 0.125rem;
		color: color-mix(in srgb, var(--sorting-result-accent) 80%, var(--tsbs-color-heading));
		font-size: clamp(0.8125rem, 1.75svh, 0.9375rem);
		font-weight: 600;
		line-height: 1.25;
		text-align: center;
		text-decoration: none;
	}

	.sorting-result__link:hover,
	.sorting-result__link:focus-visible {
		color: var(--tsbs-theme-cta-hover-bg);
		text-decoration: underline;
		text-underline-offset: 0.18em;
	}

	.sorting-result__link strong {
		font-weight: 800;
	}

	@media (max-width: 374.98px) {
		.sorting-result__panel {
			padding-right: 1rem;
			padding-left: 1rem;
		}
	}

	@media (min-width: 576px) and (max-width: 767.98px) {
		.sorting-result-page {
			--sorting-result-banner-height: clamp(12.5rem, 28svh, 15.5rem);
			--sorting-result-panel-width: min(44rem, calc(100vw - clamp(2rem, 8vw, 4rem)));
			--sorting-result-panel-top: clamp(14.25rem, 33svh, 17.25rem);
			--sorting-result-panel-padding-top: clamp(3rem, 6svh, 4.25rem);
			--sorting-result-avatar-width: clamp(9rem, 26vw, 12rem);
			--sorting-result-avatar-right: clamp(1.5rem, 4vw, 2.5rem);
			--sorting-result-avatar-top-offset: clamp(-6.25rem, -12svh, -5rem);
			--sorting-result-cta-width: min(100%, 18rem);
			--sorting-result-cta-height: clamp(2.5rem, 4.8svh, 2.75rem);
			--sorting-result-cta-gap: clamp(0.375rem, 1.2svh, 0.625rem);

			place-items: center;
		}

		.sorting-result {
			display: block;
			width: 100%;
			min-height: 100vh;
			min-height: 100svh;
			padding-top: var(--sorting-result-panel-top);
			padding-bottom: clamp(0.75rem, 1.8svh, 1.25rem);
			overflow: visible;
			background-color: var(--sorting-result-photo-bg);
			background-image:
				var(--tsbs-page-pattern-overlay),
				var(--tsbs-page-pattern-image);
			background-repeat: repeat;
			background-position: top left;
			background-size: var(--tsbs-page-pattern-size);
		}

		.sorting-result__visual {
			position: fixed;
			inset: 0;
			z-index: 4;
			min-height: 100%;
			overflow: visible;
			pointer-events: none;
		}

		.sorting-result__banner {
			position: absolute;
			top: clamp(1.5rem, 4.4svh, 2.5rem);
			left: 50%;
			width: auto;
			height: var(--sorting-result-banner-height);
			filter: none;
			transform: translateX(-50%);
		}

		.sorting-result__avatar {
			position: absolute;
			top: calc(var(--sorting-result-panel-top) + var(--sorting-result-avatar-top-offset));
			right: calc((100vw - var(--sorting-result-panel-width)) / 2 + var(--sorting-result-avatar-right));
			width: var(--sorting-result-avatar-width);
			transform: none;
		}

		.sorting-result__panel {
			position: relative;
			left: auto;
			width: var(--sorting-result-panel-width);
			align-content: start;
			justify-items: center;
			min-height: auto;
			max-height: none;
			padding: var(--sorting-result-panel-padding-top) clamp(1.75rem, 5vw, 3rem) clamp(0.875rem, 2svh, 1.375rem);
			text-align: center;
			border-radius: 1.25rem;
			margin: 0 auto;
			transform: none;
		}

		.sorting-result__panel h1 {
			max-width: 22rem;
			font-size: clamp(1.65rem, 3.8svh, 2.1rem);
		}

		.sorting-result__copy {
			gap: clamp(0.375rem, 1.15svh, 0.625rem);
			max-width: 35rem;
		}

		.sorting-result__copy p {
			font-size: clamp(0.9375rem, 1.95svh, 1rem);
			line-height: 1.3;
		}

		.sorting-result__button {
			width: var(--sorting-result-cta-width);
			justify-self: center;
		}

		.sorting-result__actions {
			width: var(--sorting-result-cta-width);
			justify-items: stretch;
		}

		.sorting-result__link {
			font-size: clamp(0.75rem, 1.5svh, 0.875rem);
			text-align: center;
		}
	}

	@media (min-width: 768px) {
		.sorting-result-page {
			--sorting-result-banner-height: clamp(18rem, 37svh, 25.5rem);
			--sorting-result-panel-width: min(82rem, calc(100vw - 8rem));
			--sorting-result-panel-top: clamp(16.5rem, 38svh, 24rem);
			--sorting-result-panel-padding-top: clamp(4.5rem, 8.5svh, 7.75rem);
			--sorting-result-avatar-width: clamp(13rem, 22vw, 19rem);
			--sorting-result-avatar-right: clamp(3rem, 5.5vw, 4.75rem);
			--sorting-result-avatar-top-offset: clamp(-10rem, -17svh, -8.25rem);
			--sorting-result-cta-width: 20rem;
			--sorting-result-cta-height: clamp(2.625rem, 5.2svh, 3rem);
			--sorting-result-cta-gap: clamp(0.5rem, 1.6svh, 0.875rem);

			place-items: center;
			padding: 0;
		}

		.sorting-result {
			display: block;
			width: 100%;
			min-height: 100vh;
			min-height: 100svh;
			padding-top: var(--sorting-result-panel-top);
			padding-bottom: clamp(0.75rem, 2.2svh, 2rem);
			overflow: visible;
			background-color: var(--sorting-result-photo-bg);
			background-image:
				var(--tsbs-page-pattern-overlay),
				var(--tsbs-page-pattern-image);
			background-repeat: repeat;
			background-position: top left;
			background-size: var(--tsbs-page-pattern-size);
		}

		.sorting-result__visual {
			position: fixed;
			inset: 0;
			z-index: 4;
			min-height: 100%;
			overflow: visible;
			pointer-events: none;
		}

		.sorting-result__banner {
			position: absolute;
			top: clamp(0.75rem, 3svh, 2.5rem);
			left: 50%;
			width: auto;
			height: var(--sorting-result-banner-height);
			filter: none;
			transform: translateX(-50%);
		}

		.sorting-result__avatar {
			position: absolute;
			top: calc(var(--sorting-result-panel-top) + var(--sorting-result-avatar-top-offset));
			right: calc((100vw - var(--sorting-result-panel-width)) / 2 + var(--sorting-result-avatar-right));
			width: var(--sorting-result-avatar-width);
			transform: none;
		}

		.sorting-result__panel {
			position: relative;
			left: auto;
			width: var(--sorting-result-panel-width);
			align-content: start;
			justify-items: center;
			min-height: auto;
			max-height: none;
			padding: var(--sorting-result-panel-padding-top) clamp(3rem, 7vw, 6rem) clamp(1.375rem, 3svh, 2.75rem);
			text-align: center;
			border-radius: 1.25rem;
			margin: 0 auto;
			transform: none;
		}

		.sorting-result__button {
			width: min(100%, 20rem);
			justify-self: center;
		}

		.sorting-result__actions {
			width: min(100%, 20rem);
			justify-items: stretch;
		}

		.sorting-result__link {
			text-align: center;
		}

		.sorting-result__panel h1 {
			max-width: 24rem;
			font-size: clamp(1.625rem, 3.8svh, 2.25rem);
		}

	}

	@media (min-width: 1200px) {
		.sorting-result-page {
			--sorting-result-banner-height: clamp(20rem, 37svh, 27rem);
			--sorting-result-panel-padding-top: clamp(5.5rem, 8.5svh, 8rem);
			--sorting-result-avatar-width: clamp(18rem, 25vw, 30rem);
			--sorting-result-avatar-right: clamp(2.5rem, 3.8vw, 4rem);
			--sorting-result-avatar-top-offset: clamp(-16rem, -29svh, -10rem);
		}
	}
</style>

<script>
	import { initAvatarLotties } from '../../scripts/avatarLottie';
	initAvatarLotties();
	document.addEventListener('astro:page-load', () => initAvatarLotties());

	document.querySelectorAll<HTMLButtonElement>('[data-confirm-result-academy]').forEach((btn) => {
		btn.addEventListener('click', async () => {
			const accademia = btn.dataset.confirmResultAcademy;
			const href = btn.dataset.confirmResultHref;
			if (!accademia || !href) return;

			btn.disabled = true;

			try {
				const response = await fetch('/api/user/accademia', {
					method: 'PUT',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ accademia }),
				});

				if (!response.ok) throw new Error(`HTTP ${response.status}`);
			} catch {
				btn.disabled = false;
				return;
			}

			window.location.assign(href);
		});
	});
</script>
