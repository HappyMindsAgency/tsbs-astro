---
import welcomeAcademyAvatar from '../../assets/benvenuto-accademia-avatar.png';
import arboreaBanner from '../../assets/Arborea-accademia-stendardo-the-secret-bookish-society.png';
import arcadiaBanner from '../../assets/Arcadia-accademia-stendardo-the-secret-bookish-society.png';
import armoniaBanner from '../../assets/Armonia-accademia-stendardo-the-secret-bookish-society.png';
import astrariaBanner from '../../assets/Astraria-accademia-stendardo-the-secret-bookish-society.png';

type AcademyKey = 'astraria' | 'arcadia' | 'armonia' | 'arborea';

const academyLabels: Record<AcademyKey, string> = {
	astraria: 'Astraria',
	arcadia: 'Arcadia',
	armonia: 'Armonia',
	arborea: 'Arborea',
};

const academyBanners = {
	astraria: astrariaBanner,
	arcadia: arcadiaBanner,
	armonia: armoniaBanner,
	arborea: arboreaBanner,
};

const normalizeAcademy = (value: unknown): AcademyKey => {
	if (typeof value !== 'string') {
		return 'arborea';
	}

	const normalized = value.toLowerCase().trim();
	return normalized in academyLabels ? normalized as AcademyKey : 'arborea';
};

const { academy = 'arborea', lang = 'it' } = Astro.props;
const currentAcademy = normalizeAcademy(academy);
const academyName = academyLabels[currentAcademy];
const academyBanner = academyBanners[currentAcademy];
const avatarChoiceUrl = '/test-smistamento/scegli-avatar/';
const confirmHref = `${avatarChoiceUrl}?academy=${encodeURIComponent(currentAcademy)}`;
const chooseHref = `/test-smistamento/?step=conferma-accademia&academy=${encodeURIComponent(currentAcademy)}`;
---

<section class="sorting-result-page" data-academy={currentAcademy} data-lang={lang} aria-labelledby="sorting-result-title">
	<article class="sorting-result">
		<div class="sorting-result__visual" aria-hidden="true">
			<img
				class="sorting-result__banner"
				src={academyBanner.src}
				width={academyBanner.width}
				height={academyBanner.height}
				alt=""
				loading="eager"
			/>

			<img
				class="sorting-result__avatar"
				src={welcomeAcademyAvatar.src}
				width={welcomeAcademyAvatar.width}
				height={welcomeAcademyAvatar.height}
				alt=""
				loading="eager"
			/>
		</div>

		<div class="sorting-result__panel">
			<h1 id="sorting-result-title">
				<span class="sorting-result__title-light">Benvenut* in</span>
				<span class="sorting-result__title-bold">Accademia {academyName}</span>
			</h1>
			<p class="fw-bold">
				Lorem ipsum dolor sit amet, consectetur adipiscing elit. Morbi at est et tortor laoreet placerat id in neque.
			</p>

			<div class="sorting-result__actions">
				<button
					type="button"
					class="btn tsbs-cta-primary mission-proof-question__cta sorting-result__button"
					data-confirm-result-academy={currentAcademy}
					data-confirm-result-href={confirmHref}
				>Conferma</button>
				<a class="sorting-result__link" href={chooseHref}>oppure Scegli l’Accademia</a>
			</div>
		</div>
	</article>
</section>

<style lang="scss">
	.sorting-result-page {
		--sorting-result-accent: var(--tsbs-theme-accent);
		--sorting-result-muted: var(--tsbs-color-body);
		--sorting-result-soft: color-mix(in srgb, var(--sorting-result-accent) 13%, var(--tsbs-color-surface));
		--sorting-result-photo-bg: #ffffff;
		--sorting-result-line: color-mix(in srgb, var(--sorting-result-accent) 18%, var(--tsbs-color-white));
		--sorting-result-panel: var(--tsbs-color-white);
		--sorting-result-shadow: 0 1.125rem 3rem color-mix(in srgb, var(--sorting-result-accent) 14%, transparent);
		--sorting-result-visual-height: clamp(22rem, 118vw, 29rem);
		--sorting-result-banner-height: clamp(20rem, 108vw, 26.5rem);
		--sorting-result-panel-width: 100%;
		--sorting-result-cta-width: min(100%, 20.5rem);
		--sorting-result-cta-height: clamp(3rem, 12vw, 3.5rem);
		--sorting-result-cta-gap: clamp(0.75rem, 3.2vw, 1rem);

		display: grid;
		place-items: stretch center;
		min-height: 100vh;
		min-height: 100svh;
		padding: 0;
		color: var(--sorting-result-muted);
		background-color: var(--sorting-result-photo-bg);
		background-image:
			var(--tsbs-page-pattern-overlay),
			var(--tsbs-page-pattern-image);
		background-repeat: repeat;
		background-position: top left;
		background-size: var(--tsbs-page-pattern-size);
	}

	.sorting-result {
		position: relative;
		display: grid;
		grid-template-rows: var(--sorting-result-visual-height) auto;
		align-content: start;
		width: 100%;
		min-height: 100vh;
		min-height: 100svh;
		overflow: hidden;
		background-color: var(--sorting-result-photo-bg);
		background-image:
			var(--tsbs-page-pattern-overlay),
			var(--tsbs-page-pattern-image);
		background-repeat: repeat;
		background-position: top left;
		background-size: var(--tsbs-page-pattern-size);
		border: 0;
		border-radius: 0;
		box-shadow: none;
	}

	.sorting-result__visual {
		position: relative;
		z-index: 4;
		min-height: var(--sorting-result-visual-height);
		overflow: visible;
		pointer-events: none;
	}

	.sorting-result__banner {
		position: absolute;
		bottom: -1.125rem;
		left: 50%;
		z-index: 4;
		width: auto;
		height: var(--sorting-result-banner-height);
		filter:
			brightness(0.68)
			drop-shadow(0 1rem 1.25rem color-mix(in srgb, var(--sorting-result-accent) 22%, transparent));
		transform: translateX(-50%);
	}

	.sorting-result__avatar {
		position: absolute;
		right: clamp(1.75rem, 11vw, 3.25rem);
		bottom: -1rem;
		z-index: 5;
		width: clamp(5rem, 24vw, 6.25rem);
		height: auto;
		pointer-events: none;
	}

	.sorting-result__panel {
		position: relative;
		z-index: 3;
		display: grid;
		gap: 0.875rem;
		width: 100%;
		min-height: max(0px, calc(100svh - var(--sorting-result-visual-height)));
		padding: 2.25rem 1.5rem calc(1.75rem + env(safe-area-inset-bottom));
		background: var(--sorting-result-panel);
		border-radius: 1.25rem 1.25rem 0 0;
	}

	.sorting-result__eyebrow {
		margin: 0;
		color: color-mix(in srgb, var(--sorting-result-accent) 78%, var(--tsbs-color-body));
		font-size: 0.75rem;
		font-weight: 700;
		line-height: 1.2;
		text-transform: uppercase;
	}

	.sorting-result__panel h1 {
		margin: 0;
		color: var(--sorting-result-accent);
		font-family: var(--tsbs-font-heading-academy);
		font-size: clamp(1.75rem, 8vw, 2.25rem);
		font-weight: 300;
		line-height: 1.06;
		letter-spacing: 0;
	}

	.sorting-result__title-light,
	.sorting-result__title-bold {
		display: block;
		color: var(--sorting-result-accent);
	}

	.sorting-result__title-light {
		font-weight: 300;
	}

	.sorting-result__title-bold {
		font-weight: 700;
	}

	.sorting-result__panel p:not(.sorting-result__eyebrow) {
		margin: 0;
		color: var(--tsbs-color-heading);
		font-size: 0.9375rem;
		line-height: 1.35;
	}

	.sorting-result__actions {
		display: grid;
		gap: var(--sorting-result-cta-gap);
		justify-items: center;
		justify-self: center;
		width: var(--sorting-result-cta-width);
		margin-top: 0.375rem;
	}

	.sorting-result__button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		height: var(--sorting-result-cta-height);
		min-height: var(--sorting-result-cta-height);
		padding: 0.75rem 1rem;
	}

	.sorting-result__link {
		color: color-mix(in srgb, var(--sorting-result-accent) 80%, var(--tsbs-color-heading));
		font-size: 0.9375rem;
		font-weight: 600;
		line-height: 1.25;
		text-align: center;
		text-decoration: none;
	}

	.sorting-result__link:hover,
	.sorting-result__link:focus-visible {
		color: var(--tsbs-theme-cta-hover-bg);
		text-decoration: underline;
		text-underline-offset: 0.18em;
	}

	@media (max-width: 374.98px) {
		.sorting-result__panel {
			padding-right: 1rem;
			padding-left: 1rem;
		}
	}

	@media (min-width: 768px) {
		.sorting-result-page {
			--sorting-result-banner-height: 27.5rem;
			--sorting-result-panel-width: min(69rem, calc(100vw - 12rem));
			--sorting-result-panel-top: clamp(22rem, 40vh, 27rem);
			--sorting-result-panel-padding-top: clamp(8rem, 7vw, 8.25rem);
			--sorting-result-avatar-width: clamp(6.25rem, 8vw, 8.75rem);
			--sorting-result-avatar-right: clamp(3rem, 5.5vw, 4.75rem);
			--sorting-result-avatar-top-offset: clamp(-11.5rem, -22vh, -10.5rem);
			--sorting-result-cta-width: 20rem;
			--sorting-result-cta-height: 3rem;
			--sorting-result-cta-gap: 0.875rem;

			place-items: center;
			padding: 0;
		}

		.sorting-result {
			display: block;
			width: 100%;
			min-height: 100vh;
			min-height: 100svh;
			overflow: hidden;
			background-color: var(--sorting-result-photo-bg);
			background-image:
				var(--tsbs-page-pattern-overlay),
				var(--tsbs-page-pattern-image);
			background-repeat: repeat;
			background-position: top left;
			background-size: var(--tsbs-page-pattern-size);
		}

		.sorting-result__visual {
			position: fixed;
			inset: 0;
			z-index: 4;
			min-height: 100%;
			overflow: visible;
			pointer-events: none;
		}

		.sorting-result__avatar {
			position: absolute;
			top: calc(var(--sorting-result-panel-top) + var(--sorting-result-avatar-top-offset));
			right: calc((100vw - var(--sorting-result-panel-width)) / 2 + var(--sorting-result-avatar-right));
			width: var(--sorting-result-avatar-width);
			transform: none;
		}

		.sorting-result__banner {
			position: absolute;
			top: clamp(1.25rem, 4.5vh, 3rem);
			left: 50%;
			width: auto;
			height: var(--sorting-result-banner-height);
			filter: brightness(0.68);
			transform: translateX(-50%);
		}

		.sorting-result__panel {
			position: absolute;
			right: auto;
			top: var(--sorting-result-panel-top);
			bottom: auto;
			left: 50%;
			width: var(--sorting-result-panel-width);
			align-content: start;
			justify-items: center;
			min-height: auto;
			padding: var(--sorting-result-panel-padding-top) clamp(3rem, 7vw, 6rem) clamp(2.75rem, 4vw, 4rem);
			text-align: center;
			border-radius: 1.25rem;
			transform: translateX(-50%);
		}

		.sorting-result__button {
			width: min(100%, 20rem);
			justify-self: center;
		}

		.sorting-result__actions {
			width: min(100%, 20rem);
			justify-items: stretch;
		}

		.sorting-result__link {
			text-align: center;
		}

		.sorting-result__panel h1 {
			max-width: 24rem;
			font-size: clamp(1.875rem, 2.35vw, 2.25rem);
		}

		.sorting-result__panel p:not(.sorting-result__eyebrow) {
			max-width: 49rem;
		}
	}

	@media (min-width: 1200px) {
		.sorting-result-page {
			--sorting-result-banner-height: 27rem;
			--sorting-result-panel-padding-top: 8rem;
			--sorting-result-avatar-width: clamp(7.75rem, 7vw, 8.75rem);
			--sorting-result-avatar-right: clamp(3.5rem, 4.8vw, 5rem);
			--sorting-result-avatar-top-offset: clamp(-11.75rem, -18vh, -10.5rem);
		}
	}
</style>

<script>
	document.querySelectorAll<HTMLButtonElement>('[data-confirm-result-academy]').forEach((btn) => {
		btn.addEventListener('click', async () => {
			const accademia = btn.dataset.confirmResultAcademy;
			const href = btn.dataset.confirmResultHref;
			if (!accademia || !href) return;

			btn.disabled = true;

			try {
				await fetch('/api/user/accademia', {
					method: 'PUT',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ accademia }),
				});
			} catch {
				// best-effort: la navigazione procede comunque
			}

			window.location.assign(href);
		});
	});
</script>
