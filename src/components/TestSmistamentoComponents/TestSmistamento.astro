---
import smistamentoPattern from '../../assets/smistamento-pattern-the-secret-bookish-society.png';

const { lang = 'it' } = Astro.props;
---

<article class="mission-proof-question choice-question sorting-test" data-sorting-test data-lang={lang} aria-label="Test di smistamento">
	<header
		class="mission-proof-question__header"
		style={`background-color: var(--tsbs-color-neutral); background-image: url(${smistamentoPattern.src}); background-repeat: no-repeat; background-position: center; background-size: cover;`}
	>
		<div class="container-xl tsbs-app-container mission-proof-question__header-content">
			<p class="mission-proof-question__eyebrow">Test di smistamento</p>
			<h1 class="mission-proof-question__title mission-component-title">Dove ti porterà la tua natura?</h1>
		</div>
	</header>

	<div class="container-xl tsbs-app-container mission-proof-question__panel choice-question__panel">

		<!-- Stato: caricamento -->
		<div class="sorting-test__loading" data-sorting-loading aria-live="polite">
			<p>Caricamento domande…</p>
		</div>

		<!-- Stato: errore -->
		<div class="sorting-test__error" data-sorting-error hidden aria-live="assertive">
			<p>Non è stato possibile caricare il test. Ricarica la pagina per riprovare.</p>
		</div>

		<!-- Stato: quiz attivo -->
		<div class="choice-question__form sorting-test__form" data-sorting-form hidden>
			<fieldset class="choice-question__fieldset">
				<legend data-sorting-question-text></legend>

				<p class="sorting-test__progress" data-sorting-progress></p>

				<div class="choice-question__answers" data-sorting-answers></div>
			</fieldset>

			<button
				type="button"
				class="btn tsbs-cta-primary mission-proof-question__cta choice-question__cta sorting-test__cta"
				data-sorting-next
				disabled
			>
				Prosegui
			</button>
		</div>
	</div>
</article>

<style lang="scss">
	.sorting-test {
		--mission-proof-question-accent: var(--tsbs-color-neutral);
		--mission-proof-question-header: var(--tsbs-color-neutral);
		--tsbs-theme-cta-bg: var(--tsbs-global-cta-var1-bg);
		--tsbs-theme-cta-border: var(--tsbs-global-cta-var1-border);
		--tsbs-theme-cta-hover-bg: var(--tsbs-global-cta-var1-hover-bg);
		--tsbs-theme-cta-hover-border: var(--tsbs-global-cta-var1-hover-border);
		--tsbs-theme-cta-active-bg: var(--tsbs-global-cta-var1-active-bg);
		--tsbs-theme-cta-active-border: var(--tsbs-global-cta-var1-active-border);
		--tsbs-theme-cta-focus-bg: var(--tsbs-global-cta-var1-focus-bg);
		--tsbs-theme-cta-focus-border: var(--tsbs-global-cta-var1-focus-border);
	}

	.sorting-test__form {
		gap: 3rem;
	}

	.sorting-test__progress {
		margin: 0;
		color: var(--tsbs-theme-body);
		font-size: 0.875rem;
		line-height: 1.4;
	}

	.sorting-test .choice-question__fieldset {
		gap: 1.25rem;
	}

	.sorting-test .choice-question__answer {
		background: var(--tsbs-color-neutral-accent);
	}

	.sorting-test .choice-question__answer:has(input:checked) {
		background: var(--tsbs-color-neutral);
	}

	.sorting-test__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}

	.sorting-test__loading,
	.sorting-test__error {
		padding: 3rem 0;
		text-align: center;
		color: var(--tsbs-theme-body);
	}

	.sorting-test__error {
		color: var(--tsbs-color-danger, #c0392b);
	}
</style>

<script>
	// Mapping: indice risposta (0-based) → slug accademia
	// Risposta 0 → Arcadia, 1 → Astraria, 2 → Armonia, 3 → Arborea
	const ACCADEMIA_BY_ANSWER_INDEX: Record<number, string> = {
		0: 'arcadia',
		1: 'astraria',
		2: 'armonia',
		3: 'arborea',
	};

	async function initSortingTest() {
		const article = document.querySelector<HTMLElement>('[data-sorting-test]');
		if (!article) return;

		const loadingEl = article.querySelector<HTMLElement>('[data-sorting-loading]');
		const errorEl = article.querySelector<HTMLElement>('[data-sorting-error]');
		const formEl = article.querySelector<HTMLElement>('[data-sorting-form]');
		const questionTextEl = article.querySelector<HTMLElement>('[data-sorting-question-text]');
		const progressEl = article.querySelector<HTMLElement>('[data-sorting-progress]');
		const answersEl = article.querySelector<HTMLElement>('[data-sorting-answers]');
		const nextBtn = article.querySelector<HTMLButtonElement>('[data-sorting-next]');

		if (!loadingEl || !errorEl || !formEl || !questionTextEl || !progressEl || !answersEl || !nextBtn) return;

		// Carica le domande dall'API
		let domande: Array<{ domanda: string; risposte: Array<{ risposta: string }> }> = [];

		try {
			const res = await fetch('/api/quiz/smistamento');
			if (!res.ok) throw new Error(`HTTP ${res.status}`);
			const data = await res.json();
			domande = data.domande ?? [];
		} catch {
			loadingEl.hidden = true;
			errorEl.hidden = false;
			return;
		}

		if (domande.length === 0) {
			loadingEl.hidden = true;
			errorEl.hidden = false;
			return;
		}

		// Contatori: quante volte è stato scelto ogni indice di risposta
		const punteggi: number[] = [0, 0, 0, 0];
		let domandaCorrente = 0;

		function renderDomanda(index: number) {
			const d = domande[index];
			questionTextEl!.textContent = d.domanda;
			progressEl!.textContent = `Domanda ${index + 1} di ${domande.length}`;

			answersEl!.innerHTML = '';
			d.risposte.forEach((risposta, rIdx) => {
				const id = `sorting-answer-${index}-${rIdx}`;
				const label = document.createElement('label');
				label.className = 'choice-question__answer';
				label.htmlFor = id;

				const input = document.createElement('input');
				input.id = id;
				input.type = 'radio';
				input.name = 'risposta-smistamento';
				input.value = String(rIdx);

				const spanLabel = document.createElement('span');
				spanLabel.className = 'choice-question__answer-label';
				// Etichetta A/B/C/D
				spanLabel.textContent = String.fromCharCode(65 + rIdx);

				const spanDesc = document.createElement('span');
				spanDesc.className = 'choice-question__answer-description';
				spanDesc.textContent = risposta.risposta;

				label.appendChild(input);
				label.appendChild(spanLabel);
				label.appendChild(spanDesc);
				answersEl!.appendChild(label);

				input.addEventListener('change', () => {
					nextBtn!.disabled = false;
				});
			});

			nextBtn!.disabled = true;
			nextBtn!.textContent = index === domande.length - 1 ? 'Scopri la tua Accademia' : 'Prosegui';
		}

		nextBtn.addEventListener('click', () => {
			// Registra la risposta scelta
			const selected = answersEl!.querySelector<HTMLInputElement>('input[type="radio"]:checked');
			if (!selected) return;

			const answerIndex = parseInt(selected.value, 10);
			if (!isNaN(answerIndex) && answerIndex >= 0 && answerIndex <= 3) {
				punteggi[answerIndex]++;
			}

			domandaCorrente++;

			if (domandaCorrente < domande.length) {
				renderDomanda(domandaCorrente);
			} else {
				// Calcola l'accademia vincente
				const maxPunteggio = Math.max(...punteggi);
				const indiceVincente = punteggi.indexOf(maxPunteggio);
				const accademia = ACCADEMIA_BY_ANSWER_INDEX[indiceVincente] ?? 'arcadia';

				window.location.href = `/test-smistamento/benvenuto-accademia-${accademia}/`;
			}
		});

		// Mostra il quiz
		loadingEl.hidden = true;
		formEl.hidden = false;
		renderDomanda(0);
	}

	// Astro View Transitions: ri-inizializza ad ogni navigazione di pagina
	document.addEventListener('astro:page-load', initSortingTest);
</script>
