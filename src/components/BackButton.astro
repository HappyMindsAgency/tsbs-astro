---
interface Props {
	href: string;
	label?: string;
	/** Mostra anche il testo accanto all'icona (default: solo icona) */
	withText?: boolean;
	icon?: string;
	class?: string;
}

const {
	href,
	label = 'Indietro',
	withText = false,
	icon = 'bi-arrow-left',
	class: className = '',
} = Astro.props;
---

<a
	class:list={['tsbs-back-button', { 'tsbs-back-button--text': withText }, className]}
	href={href}
	aria-label={label}
	title={label}
>
	<i class={`bi ${icon}`} aria-hidden="true"></i>
	{withText && <span>{label}</span>}
</a>

<style>
	.tsbs-back-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex: 0 0 auto;
		width: 2.75rem;
		height: 2.75rem;
		color: var(--tsbs-color-white);
		font-size: 1.25rem;
		line-height: 1;
		text-decoration: none;
		background: rgba(255, 255, 255, 0.18);
		border: 1px solid rgba(255, 255, 255, 0.55);
		border-radius: 50%;
		transition: background 0.15s ease, color 0.15s ease;
	}

	.tsbs-back-button--text {
		gap: 0.5rem;
		width: auto;
		padding: 0 1rem;
		font-size: 1rem;
		font-weight: 600;
		border-radius: var(--tsbs-radius-md);
	}

	.tsbs-back-button:hover,
	.tsbs-back-button:focus {
		color: var(--profile-current-academy-accent);
		background: var(--tsbs-color-white);
		border-color: var(--tsbs-color-white);
	}
</style>
