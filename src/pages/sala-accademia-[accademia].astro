---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import arcadiaBanner from '../assets/Arcadia-accademia-stendardo-the-secret-bookish-society.png';
import arcadiaLogo from '../assets/Arcadia-logo-the-secret-bookish-society.png';
import arboreaBanner from '../assets/Arborea-accademia-stendardo-the-secret-bookish-society.png';
import arboreaLogo from '../assets/Arborea-logo-the-secret-bookish-society.png';
import armoniaBanner from '../assets/Armonia-accademia-stendardo-the-secret-bookish-society.png';
import armoniaLogo from '../assets/Armonia-logo-the-secret-bookish-society.png';
import astrariaBanner from '../assets/Astraria-accademia-stendardo-the-secret-bookish-society.png';
import astrariaLogo from '../assets/Astraria-logo-the-secret-bookish-society.png';
import trophyIcon from '../assets/trofei-icona-scrivania.png';
import { getAcademyMembersCount, getAcademyRanking } from '../lib/strapi/accademie';
import { getGrimorioChronicleMeta, getGrimorioExcerpt, getGrimorioNotePubbliche, getGrimorioPublicNoteHref } from '../lib/strapi/grimorio';
import { resolveUserAcademy } from '../lib/theme';

const { lang = 'it' } = Astro.props;
const { accademia = 'arborea' } = Astro.params;

const jwt = Astro.cookies.get('jwt')?.value;
if (!jwt) return Astro.redirect('/');

const userAcademy = await resolveUserAcademy(jwt);

// Redirect se l'utente tenta di accedere alla sala di un'altra accademia
if (accademia !== userAcademy) {
	return Astro.redirect(`/sala-accademia-${userAcademy}/`, 302);
}

type AcademyKey = 'arcadia' | 'arborea' | 'armonia' | 'astraria';

const fallbackAcademy: AcademyKey = 'arborea';

const academies: Record<AcademyKey, {
	name: string;
	description: string;
	logo: ImageMetadata;
	banner: ImageMetadata;
}> = {
	arcadia: {
		name: 'Arcadia',
		description: 'Arcadia misura il proprio valore attraverso parola, studio e precisione. Ogni risultato rafforza il prestigio dell’Accademia e la sua voce all’interno della Società.',
		logo: arcadiaLogo,
		banner: arcadiaBanner,
	},
	arborea: {
		name: 'Arborea',
		description: 'Arborea procede come ciò che mette radici: con cura e attenzione. Ogni passo nutre la memoria dell’Accademia e la fa crescere nel tempo.',
		logo: arboreaLogo,
		banner: arboreaBanner,
	},
	armonia: {
		name: 'Armonia',
		description: 'Armonia cresce dove le voci si incontrano. Ogni missione completata, ogni contributo condiviso, aggiunge forza al coro dell’Accademia.',
		logo: armoniaLogo,
		banner: armoniaBanner,
	},
	astraria: {
		name: 'Astraria',
		description: 'Nel silenzio della notte, Astraria avanza con costanza. Ogni missione compiuta è  un segno lasciato tra stelle e memoria.',
		logo: astrariaLogo,
		banner: astrariaBanner,
	},
};

const isAcademyKey = (value: string): value is AcademyKey => value in academies;
const academyKey = isAcademyKey(userAcademy) ? userAcademy : fallbackAcademy;
const academy = academies[academyKey];
const rankingHref = '/classifica-generale/';
const academyMembersCount = await getAcademyMembersCount(academyKey);
const academyMembersLabel = `${academyMembersCount} ${academyMembersCount === 1 ? 'Adepto' : 'Adepti'}`;
const rankingRows = await getAcademyRanking(academyKey, jwt);
const chronicleRows = await getGrimorioNotePubbliche(lang, academyKey);
---

<Layout lang={lang} theme={`theme-${academyKey}`} accademia={academyKey}>
	<Nav lang={lang} />

	<main class={`tsbs-app-shell academy-page theme-${academyKey}`} data-academy={academyKey}>
		<section class="academy-hero" aria-labelledby="academy-title">
			<img class="academy-hero__crest academy-hero__crest--left" src={academy.banner.src} alt="" aria-hidden="true" />

			<div class="academy-hero__content">
				<div class="academy-hero__icon" aria-hidden="true">
					<img
						src={academy.logo.src}
						width={academy.logo.width}
						height={academy.logo.height}
						alt=""
						loading="eager"
						decoding="async"
					/>
				</div>

				<div class="academy-hero__mobile-crest">
					<img src={academy.banner.src} alt="" aria-hidden="true" />
					<span class="academy-hero__mobile-logo" aria-hidden="true">
						<img
							src={academy.logo.src}
							width={academy.logo.width}
							height={academy.logo.height}
							alt=""
							loading="eager"
							decoding="async"
						/>
					</span>
					<div class="academy-hero__mobile-copy">
						<h1 id="academy-title">{academy.name}</h1>
						<p>{academy.description}</p>
						<p class="academy-members">
							<i class="bi bi-people" aria-hidden="true"></i>
							<span>{academyMembersLabel}</span>
						</p>
					</div>
				</div>

				<div class="academy-hero__desktop-copy">
					<h1>{academy.name}</h1>
					<p>{academy.description}</p>
					<p class="academy-members">
						<i class="bi bi-people" aria-hidden="true"></i>
						<span>{academyMembersLabel}</span>
					</p>
				</div>
			</div>

			<img class="academy-hero__crest academy-hero__crest--right" src={academy.banner.src} alt="" aria-hidden="true" />
		</section>

		<div class="container-xl tsbs-app-container academy-content">
			<section class="academy-section" aria-labelledby="academy-ranking-title">
				<div class="academy-section__head">
					<h2 id="academy-ranking-title" class="tsbs-section-title">Classifica</h2>
					<a class="missions-load-more academy-ranking-more academy-section__link--desktop" href={rankingHref}>
						<span>Guarda tutta la classifica</span>
						<i class="bi bi-arrow-right" aria-hidden="true"></i>
					</a>
				</div>

				<div class="academy-ranking-list">
					{rankingRows.map((row) => (
						<a class={`academy-ranking-card ${row.current ? 'is-current' : ''}`} href={row.href}>
							<div class="academy-ranking-card__position">
								{row.medal ? (
									<img
										class={`academy-ranking-card__medal-icon is-${row.medal}`}
										src={trophyIcon.src}
										width={trophyIcon.width}
										height={trophyIcon.height}
										alt=""
										aria-hidden="true"
										loading="lazy"
										decoding="async"
									/>
								) : (
									<span>{row.position}</span>
								)}
								<span class={`academy-ranking-card__roman ${row.medal ? `is-${row.medal}` : ''}`}>{row.medal ? row.position : ''}</span>
							</div>
							<div class="academy-ranking-card__avatar" aria-hidden="true">
								{row.avatarSrc ? (
									<img src={row.avatarSrc} alt="" loading="lazy" decoding="async" />
								) : (
									row.initials
								)}
							</div>
							<p class="academy-ranking-card__name">{row.name}</p>
							<p class="academy-ranking-card__points">
								<strong>{row.points}</strong>
								<i class="bi bi-trophy" aria-hidden="true"></i>
							</p>
						</a>
					))}
				</div>

				<a class="missions-load-more academy-ranking-more academy-section__link--mobile" href={rankingHref}>
					<span>Guarda tutta la classifica</span>
					<i class="bi bi-arrow-right" aria-hidden="true"></i>
				</a>
			</section>

			<section class="academy-section academy-chronicles" aria-labelledby="academy-chronicles-title">
				<h2 id="academy-chronicles-title" class="tsbs-section-title">Cronache della Società</h2>

				<div class="academy-chronicles-list">
					{chronicleRows.map((note, index) => (
						<a class={`academy-note-card ${index > 1 ? 'is-hidden' : ''}`} href={getGrimorioPublicNoteHref(note)} data-academy-note-card>
							<div>
								<p class="academy-note-card__meta">{getGrimorioChronicleMeta(note)}</p>
								<h3>{note.titolo}</h3>
								<p>{getGrimorioExcerpt(note.contenuto)}</p>
							</div>
							<i class="bi bi-chevron-right" aria-hidden="true"></i>
						</a>
					))}
				</div>

				{chronicleRows.length > 2 && (
					<button class="missions-load-more academy-load-more" type="button" data-load-more aria-controls="academy-chronicles-title">
						<span>Carica altro</span>
						<i class="bi bi-arrow-right" aria-hidden="true"></i>
					</button>
				)}
			</section>
		</div>
	</main>

	<script>
		const academyLoadMore = document.querySelector<HTMLButtonElement>('.academy-load-more[data-load-more]');
		const academyHiddenCards = document.querySelectorAll<HTMLElement>('[data-academy-note-card].is-hidden');

		if (academyLoadMore && academyHiddenCards.length === 0) {
			academyLoadMore.hidden = true;
		}

		academyLoadMore?.addEventListener('click', () => {
			document.querySelectorAll<HTMLElement>('[data-academy-note-card].is-hidden').forEach((card) => {
				card.classList.remove('is-hidden');
			});

			academyLoadMore.hidden = true;
			academyLoadMore.dataset.expanded = 'true';
		});
	</script>
</Layout>
