---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';

const { lang = 'it' } = Astro.props;

const academies = [
	{
		name: 'Astraria',
		theme: 'astraria',
		text: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.',
	},
	{
		name: 'Arcadia',
		theme: 'arcadia',
		text: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.',
	},
	{
		name: 'Armonia',
		theme: 'armonia',
		text: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.',
	},
	{
		name: 'Arborea',
		theme: 'arborea',
		text: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.',
	},
];
---

<Layout lang={lang}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell missions-shell biblioteca-academies-page">
		<header class="missions-header biblioteca-academies-header">
			<h1>Le Accademie</h1>
		</header>

		<section class="container-xl tsbs-app-container biblioteca-academies-content" aria-labelledby="biblioteca-academies-title">
			<h2 id="biblioteca-academies-title" class="visually-hidden">Le Accademie</h2>

			<p class="biblioteca-academies-intro">
				Sed bibendum nunc eget nunc iaculis sollicitudin. Pellentesque lacinia ultrices tempus. Vivamus vel libero eget mauris placerat rhoncus et ac ex.
			</p>

			<div class="biblioteca-academies-list" aria-label="Elenco Accademie">
				{academies.map((academy) => (
					<article class={`biblioteca-academy-card is-${academy.theme}`}>
						<span class="biblioteca-academy-card__icon" aria-hidden="true">
							<i class="bi bi-image"></i>
						</span>
						<div class="biblioteca-academy-card__copy">
							<h3>{academy.name}</h3>
							<p>{academy.text}</p>
						</div>
					</article>
				))}
			</div>
		</section>
	</main>
</Layout>
