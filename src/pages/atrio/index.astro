---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import ImpostazioniLogoutModal from '../../components/PopupComponents/ImpostazioniLogoutModal.astro';
import WelcomeToast from '../../components/toastComponents/WelcomeToast.astro';
import { resolveUserContext } from '../../lib/theme';
import { getEventiClassense, CLASSENSE_CALENDARIO_URL } from '../../lib/classense';
import { getFirstIncompleteMissionCards } from '../../lib/filtri/missioni';
import {
	getMembroMissioniByJwt,
	getMissioniAttive,
	getPartecipazioniMissioneByJwt,
} from '../../lib/strapi/missioni';
const { lang = 'it' } = Astro.props;

if (!Astro.cookies.has('jwt')) {
	return Astro.redirect('/');
}

const jwt = Astro.cookies.get('jwt')?.value;
const [
	{ theme, accademia },
	eventiClassense,
	missioniAttive,
	partecipazioniMissione,
	membroMissioni,
] = await Promise.all([
	resolveUserContext(jwt),
	getEventiClassense(),
	getMissioniAttive(lang),
	jwt ? getPartecipazioniMissioneByJwt(jwt, lang) : Promise.resolve([]),
	jwt ? getMembroMissioniByJwt(jwt) : Promise.resolve(null),
]);

const WELCOME_EPISTOLA_BY_ACADEMY = {
	arborea: 'arborea-corrado-ricci-al-raggiungimento-del-livello-2-iniziato',
	arcadia: 'arcadia-santi-muratori-al-raggiungimento-del-livello-2-iniziato',
	armonia: 'armonia-barbara-longhi-al-raggiungimento-del-livello-2-iniziato',
	astraria: 'astraria-maria-ponti-pasolini-al-raggiungimento-del-livello-2-iniziato',
};

const welcomeEpistolaSlug = WELCOME_EPISTOLA_BY_ACADEMY[accademia];
const featuredEpistleHref = welcomeEpistolaSlug ? `/epistole/${welcomeEpistolaSlug}/` : '/epistole/';
const featuredNoteHref = '/scrivania/grimorio/nuova/';
const testSmistamentoCompletato = Boolean(membroMissioni?.accademia);
const taskCards = getFirstIncompleteMissionCards(
	missioniAttive,
	partecipazioniMissione,
	membroMissioni?.livello ?? null,
	testSmistamentoCompletato,
	2,
);

---
<Layout lang={lang} theme={theme} accademia={accademia}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell dashboard-shell">
		<header class="dashboard-header">
			<div class="dashboard-profile">
				<div class="dashboard-avatar-wrap">
					<div class="dashboard-avatar" aria-hidden="true" data-atrio-avatar>
						<img data-atrio-avatar-img hidden alt="" />
					</div>
				</div>
				<div>
					<div class="dashboard-username-row">
						<span class="dashboard-username" data-atrio-username>—</span>
						<button class="dashboard-profile-menu-button" type="button" aria-label="Apri menu profilo" data-atrio-profile-menu-open>
							<i class="bi bi-chevron-down" aria-hidden="true"></i>
						</button>
					</div>
					<p class="dashboard-rank" data-atrio-livello>—</p>
				</div>
			</div>
		</header>

		<section class="tsbs-card dashboard-epistle" aria-labelledby="epistle-title">
			<div class="dashboard-epistle__content">
				<p class="dashboard-eyebrow">EPISTOLE</p>
				<h1 id="epistle-title">Una nuova Epistola ti attende</h1>
				<p>La Società ha lasciato un nuovo messaggio per te. Leggilo con attenzione: potrebbe contenere il prossimo passo da seguire.</p>
				<a class="btn tsbs-cta-primary dashboard-button" href={featuredEpistleHref}>Leggi l'Epistola</a>
			</div>
		</section>
		<a class="dashboard-inline-link dashboard-epistle-link tsbs-accent-link" href="/epistole/">Apri l’Archivio delle Epistole →</a>

		<section class="dashboard-section" aria-labelledby="tasks-title">
			<div class="dashboard-section__head">
				<h2 id="tasks-title" class="tsbs-section-title">Completa le Missioni</h2>
				<a class="tsbs-accent-link" href="/missioni/?tab=disponibili">Vedi tutti →</a>
			</div>
			{taskCards.length > 0 ? (
				<div class="dashboard-task-grid">
					{taskCards.map((task) => (
						<a class="tsbs-card dashboard-task mission-card-link" href={task.href}>
							<div class="dashboard-task__header">
								<div>
									<h3 class="tsbs-accent-title">{task.title}</h3>
									<p>{task.description}</p>
								</div>
							</div>
							<div class="tsbs-progress tsbs-progress-accent dashboard-progress" aria-label={`Progresso ${task.meta}`}>
								<span style={`width: ${task.progress}%`}></span>
							</div>
							<p class="dashboard-progress-label">{task.meta}</p>
						</a>
					))}
				</div>
			) : (
				<p class="missions-empty-message">nessuna missione disponibile</p>
			)}
		</section>

		<section class="dashboard-section dashboard-grimoire" aria-labelledby="grimoire-title">
			<div class="dashboard-section__head dashboard-section__head--desktop">
				<h2 id="grimoire-title" class="tsbs-section-title">Grimorio</h2>
				<a class="dashboard-grimoire__desktop-link tsbs-accent-link" href="/scrivania/grimorio/">Consulta il tuo Grimorio →</a>
			</div>
			<a class="tsbs-note-pad" href={featuredNoteHref} aria-label="Apri nota del Grimorio">
				<span class="tsbs-note-pad__action" aria-hidden="true">
					<i class="bi bi-plus-circle-fill" aria-hidden="true"></i>
				</span>
				<h2>Titolo della nota</h2>
				<p>Scrivi qui le tue annotazioni</p>
				<div class="tsbs-note-pad__lines" aria-hidden="true">
					<span></span>
					<span></span>
					<span></span>
					<span></span>
				</div>
			</a>
			<a class="dashboard-inline-link dashboard-grimoire__link tsbs-accent-link mt-2 d-lg-none" href="/scrivania/grimorio/">Vai al tuo grimorio →</a>
		</section>

		{eventiClassense.length > 0 && (
			<section class="dashboard-section dashboard-events" aria-labelledby="events-title">
				<div class="dashboard-section__head">
					<h2 id="events-title" class="tsbs-section-title">Incontri e raduni</h2>
					<a class="tsbs-accent-link" href={CLASSENSE_CALENDARIO_URL} target="_blank" rel="noopener noreferrer">Apri il calendario →</a>
				</div>
				<div class="dashboard-event-grid">
					{eventiClassense.map((evento) => (
						<a class="dashboard-event-card" href={evento.link} target="_blank" rel="noopener noreferrer">
							<div class="dashboard-event-card__media">
								<img
									src={evento.immagine}
									alt={evento.titolo}
									class="dashboard-event-card__img"
									loading="lazy"
									decoding="async"
								/>
							</div>
							<div class="dashboard-event-card__body">
								<h3 class="tsbs-accent-title">{evento.titolo}</h3>
							</div>
						</a>
					))}
				</div>
			</section>
		)}
	</main>
	<ImpostazioniLogoutModal renderHidden={true} />
	<WelcomeToast isOpen={true} />
</Layout>

<script>
	const setupAtrioProfileMenu = () => {
		document.querySelectorAll<HTMLElement>('[data-atrio-profile-menu-open]').forEach((trigger) => {
			if (trigger.dataset.atrioProfileMenuReady === 'true') return;
			trigger.dataset.atrioProfileMenuReady = 'true';

			trigger.addEventListener('click', () => {
				document.dispatchEvent(new CustomEvent('tsbs:settings-logout-modal-open'));
			});
		});
	};

	const loadAtrioHeader = async () => {
		try {
			const res = await fetch('/api/user/profilo');
			if (!res.ok) return;
			const profilo = await res.json();

			const username = document.querySelector('[data-atrio-username]');
			const livello = document.querySelector('[data-atrio-livello]');

			if (username instanceof HTMLElement && profilo.username) username.textContent = profilo.username;
			if (livello instanceof HTMLElement && profilo.livello) livello.textContent = profilo.livello;

			if (profilo.avatarSrc) {
				const img = document.querySelector<HTMLImageElement>('[data-atrio-avatar-img]');
				if (img instanceof HTMLImageElement) {
					img.onerror = () => {
						img.hidden = true;
					};
					img.src = profilo.avatarSrc;
					img.hidden = false;
				}
			}
		} catch {
			// Fallback silenzioso: rimangono i placeholder
		}
	};

	setupAtrioProfileMenu();
	loadAtrioHeader();
	document.addEventListener('astro:page-load', setupAtrioProfileMenu);
	document.addEventListener('astro:page-load', loadAtrioHeader);
</script>
