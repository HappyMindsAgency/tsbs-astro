---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import WelcomeToast from '../../components/toastComponents/WelcomeToast.astro';
const { lang = 'it' } = Astro.props;

const tasks = [
	{ title: 'Lorem ipsum dolor', progress: 65 },
	{ title: 'Lorem ipsum dolor', progress: 65 },
];

const events = [
	{ date: '12 FEB', time: '18:00', title: 'Lorem ipsum dolor sit amet' },
	{ date: '21 MAR', time: '18:00', title: 'Lorem ipsum dolor sit amet' },
	{ date: '05 APR', time: '19:30', title: 'Lorem ipsum dolor sit amet' },
	{ date: '18 APR', time: '17:00', title: 'Lorem ipsum dolor sit amet' },
];

const featuredNoteHref = '/scrivania/grimorio/titolo-della-nota/';

---
<Layout lang={lang}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell dashboard-shell">
		<header class="dashboard-header">
			<div class="dashboard-profile">
				<div class="dashboard-avatar" aria-hidden="true" data-atrio-avatar>
					<i class="bi bi-eyeglasses" data-atrio-avatar-fallback></i>
					<img data-atrio-avatar-img hidden alt="" />
				</div>
				<div>
					<p class="dashboard-username" data-atrio-username>—</p>
					<p class="dashboard-rank" data-atrio-livello>—</p>
				</div>
			</div>
			<a class="dashboard-menu-button" href="/profilo/impostazioni/" aria-label="Profilo e impostazioni">
				<i class="bi bi-list" aria-hidden="true"></i>
			</a>
		</header>

		<section class="tsbs-card dashboard-epistle" aria-labelledby="epistle-title">
			<div class="dashboard-epistle__content">
				<p class="dashboard-eyebrow">L'EPISTOLA</p>
				<h1 id="epistle-title">Lorem ipsum dolor</h1>
				<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Phasellus dignissim magna at magna finibus...</p>
				<a class="dashboard-inline-link dashboard-epistle-link-desktop tsbs-accent-link d-none d-lg-inline" href="/epistole/">Riepilogo epistole →</a>
				<a class="btn tsbs-cta-primary dashboard-button" href="/epistole/">Leggi Epistola</a>
			</div>
		</section>
		<a class="dashboard-inline-link dashboard-epistle-link tsbs-accent-link d-lg-none" href="/epistole/">Riepilogo epistole →</a>

		<section class="dashboard-section" aria-labelledby="tasks-title">
			<div class="dashboard-section__head">
				<h2 id="tasks-title" class="tsbs-section-title">Incarichi ordine</h2>
				<a class="tsbs-accent-link" href="/missioni/">Vedi tutti →</a>
			</div>
			<div class="dashboard-task-grid">
				{tasks.map((task) => (
					<article class="tsbs-card dashboard-task">
						<div class="dashboard-task__header">
							<div>
								<h3 class="tsbs-accent-title">{task.title}</h3>
								<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
							</div>
						</div>
						<div class="tsbs-progress tsbs-progress-accent dashboard-progress" aria-label={`Progresso ${task.progress}%`}>
							<span style={`width: ${task.progress}%`}></span>
						</div>
						<p class="dashboard-progress-label">{task.progress}%</p>
					</article>
				))}
			</div>
		</section>

		<section class="dashboard-section dashboard-grimoire" aria-labelledby="grimoire-title">
			<div class="dashboard-section__head dashboard-section__head--desktop">
				<h2 id="grimoire-title" class="tsbs-section-title">Grimorio</h2>
				<a class="dashboard-grimoire__desktop-link tsbs-accent-link" href="/scrivania/grimorio/">Vai al tuo grimorio →</a>
			</div>
			<a class="tsbs-note-pad" href={featuredNoteHref} aria-label="Apri nota del Grimorio">
				<span class="tsbs-note-pad__action" aria-hidden="true">
					<i class="bi bi-plus-circle-fill" aria-hidden="true"></i>
				</span>
				<h2>Titolo della nota</h2>
				<p>Scrivi qui le tue annotazioni da Adepto</p>
				<div class="tsbs-note-pad__lines" aria-hidden="true">
					<span></span>
					<span></span>
					<span></span>
					<span></span>
				</div>
			</a>
			<a class="dashboard-inline-link dashboard-grimoire__link tsbs-accent-link mt-2 d-lg-none" href="/scrivania/grimorio/">Vai al tuo grimorio →</a>
		</section>

		<section class="dashboard-section dashboard-events" aria-labelledby="events-title">
			<div class="dashboard-section__head">
				<h2 id="events-title" class="tsbs-section-title">Eventi</h2>
				<a class="tsbs-accent-link" href="/eventi-biblioteca-classense/">Vedi tutti →</a>
			</div>
			<div class="dashboard-event-grid">
				{events.map((event) => (
					<article class="dashboard-event-card">
						<div class="dashboard-event-card__media" aria-hidden="true">
							<i class="bi bi-image"></i>
						</div>
						<div class="dashboard-event-card__body">
							<p>{event.date} • {event.time}</p>
							<h3 class="tsbs-accent-title">{event.title}</h3>
						</div>
					</article>
				))}
			</div>
		</section>
	</main>
	<WelcomeToast isOpen={true} />
</Layout>

<script>
	const loadAtrioHeader = async () => {
		try {
			const res = await fetch('/api/user/profilo');
			if (!res.ok) return;
			const profilo = await res.json();

			const username = document.querySelector('[data-atrio-username]');
			const livello = document.querySelector('[data-atrio-livello]');

			if (username instanceof HTMLElement && profilo.username) username.textContent = profilo.username;
			if (livello instanceof HTMLElement && profilo.livello) livello.textContent = profilo.livello;

			if (profilo.avatarSrc) {
				const fallback = document.querySelector('[data-atrio-avatar-fallback]');
				const img = document.querySelector<HTMLImageElement>('[data-atrio-avatar-img]');
				if (fallback instanceof HTMLElement) fallback.hidden = true;
				if (img instanceof HTMLImageElement) {
					img.src = profilo.avatarSrc;
					img.hidden = false;
				}
			}
		} catch {
			// Fallback silenzioso: rimangono i placeholder
		}
	};

	loadAtrioHeader();
	document.addEventListener('astro:page-load', loadAtrioHeader);
</script>
