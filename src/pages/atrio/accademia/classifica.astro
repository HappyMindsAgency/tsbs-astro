---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';

const { lang = 'it' } = Astro.props;
const profileHref = '/atrio/scrivania/utenti-preferiti/esploso-profilo-utente/';

const rankingRows = [
	{ position: '24', initials: 'Tu', name: 'Adepto Mario', points: 24, current: true },
	{ position: 'I', medal: 'gold', initials: 'G', name: 'Adepto 1', points: 50 },
	{ position: 'II', medal: 'silver', initials: 'L', name: 'Adepto 2', points: 45 },
	{ position: 'III', medal: 'bronze', initials: 'S', name: 'Adepto 3', points: 43 },
	{ position: '4', initials: 'M', name: 'Adepto 4', points: 39 },
	{ position: '5', initials: 'G', name: 'Adepto 5', points: 37 },
	{ position: '6', initials: 'G', name: 'Adepto 6', points: 35 },
	{ position: '7', initials: 'L', name: 'Adepto 7', points: 32 },
	{ position: '8', initials: 'L', name: 'Adepto 8', points: 31 },
	{ position: '9', initials: 'S', name: 'Adepto 9', points: 30 },
	{ position: '10', initials: 'S', name: 'Adepto 10', points: 30 },
	{ position: '11', initials: 'M', name: 'Adepto 11', points: 30 },
	{ position: '12', initials: 'M', name: 'Adepto 12', points: 29 },
	{ position: '13', initials: 'L', name: 'Adepto 13', points: 28 },
	{ position: '14', initials: 'G', name: 'Adepto 14', points: 27 },
];
---

<Layout lang={lang}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell academy-page academy-ranking-page">
		<header class="missions-header academy-ranking-header">
			<h1>Classifica</h1>
		</header>

		<div class="container-xl tsbs-app-container academy-ranking-page__content">
			<p class="academy-ranking-intro">Aenean placerat eros turpis, nec posuere massa fermentum malesuada. Morbi at est et tortor laoreet placerat id in neque. Maecenas vel erat lacinia, sodales ipsum id.</p>

			<section class="academy-section" aria-labelledby="academy-ranking-title">
				<h2 id="academy-ranking-title" class="tsbs-section-title">Classifica</h2>

				<div class="academy-ranking-list">
					{rankingRows.map((row, index) => (
						<a class={`academy-ranking-card ${row.current ? 'is-current' : ''} ${index > 12 ? 'is-hidden' : ''}`} href={profileHref} data-academy-ranking-card>
							<div class="academy-ranking-card__position">
								{row.medal ? (
									<i class={`bi bi-award-fill is-${row.medal}`} aria-hidden="true"></i>
								) : (
									<span>{row.position}</span>
								)}
								<span class="academy-ranking-card__roman">{row.medal ? row.position : ''}</span>
							</div>
							<div class="academy-ranking-card__avatar" aria-hidden="true">{row.initials}</div>
							<p class="academy-ranking-card__name">{row.name}</p>
							<p class="academy-ranking-card__points">
								<strong>{row.points}</strong>
								<i class="bi bi-trophy" aria-hidden="true"></i>
							</p>
						</a>
					))}
				</div>

				<div class="academy-ranking-load-more-row d-lg-flex justify-content-lg-end">
					<button class="missions-load-more academy-ranking-load-more" type="button" data-ranking-load-more aria-controls="academy-ranking-title">
						<span>Carica altro</span>
						<i class="bi bi-arrow-right" aria-hidden="true"></i>
					</button>
				</div>
			</section>
		</div>
	</main>

	<script>
		const rankingLoadMore = document.querySelector<HTMLButtonElement>('[data-ranking-load-more]');
		const hiddenRankingCards = document.querySelectorAll<HTMLElement>('[data-academy-ranking-card].is-hidden');

		if (rankingLoadMore && hiddenRankingCards.length === 0) {
			rankingLoadMore.hidden = true;
		}

		rankingLoadMore?.addEventListener('click', () => {
			document.querySelectorAll<HTMLElement>('[data-academy-ranking-card].is-hidden').forEach((card) => {
				card.classList.remove('is-hidden');
			});

			rankingLoadMore.hidden = true;
			rankingLoadMore.dataset.expanded = 'true';
		});
	</script>
</Layout>
