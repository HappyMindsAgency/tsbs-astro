---
import Layout from '../../../../layouts/Layout.astro';
import Nav from '../../../../components/Nav.astro';

const { lang = 'it' } = Astro.props;

const favoriteUsers = [
	{ position: 'I', medal: 'gold', initials: 'M', name: 'Adepto 21', points: 24, academy: 'arcadia' },
	{ position: 'II', medal: 'silver', initials: 'S', name: 'Adepto 7', points: 43, academy: 'arborea' },
	{ position: 'III', medal: 'bronze', initials: 'L', name: 'Adepto 8', points: 31, academy: 'armonia' },
	{ position: '12', initials: 'M', name: 'Adepto 12', points: 29, academy: 'astraria' },
];
---

<Layout lang={lang}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell academy-page academy-ranking-page profile-favorites-page">
		<header class="missions-header academy-ranking-header">
			<h1>Utenti preferiti</h1>
		</header>

		<div class="container-xl tsbs-app-container academy-ranking-page__content">
			<section class="academy-section" aria-label="Utenti preferiti">
				<div class="academy-ranking-list">
					{favoriteUsers.map((row) => (
						<article class={`academy-ranking-card is-academy-${row.academy}`}>
							<div class="academy-ranking-card__position">
								{row.medal ? (
									<i class={`bi bi-award-fill is-${row.medal}`} aria-hidden="true"></i>
								) : (
									<span>{row.position}</span>
								)}
								<span class="academy-ranking-card__roman">{row.medal ? row.position : ''}</span>
							</div>
							<div class="academy-ranking-card__avatar" aria-hidden="true">{row.initials}</div>
							<p class="academy-ranking-card__name">{row.name}</p>
							<p class="academy-ranking-card__points">
								<strong>{row.points}</strong>
								<i class="bi bi-trophy" aria-hidden="true"></i>
							</p>
						</article>
					))}
				</div>
			</section>
		</div>
	</main>
</Layout>
