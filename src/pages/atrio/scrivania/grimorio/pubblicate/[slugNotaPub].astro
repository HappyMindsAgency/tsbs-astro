---
import Layout from '../../../../../layouts/Layout.astro';
import Nav from '../../../../../components/Nav.astro';

const { lang = 'it' } = Astro.props;
---

<Layout lang={lang}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell missions-shell note-page">
		<header class="missions-header">
			<h1>Nota</h1>
		</header>

		<div class="container-xl tsbs-app-container note-page__content">
			<section class="note-editor note-editor--published" aria-labelledby="published-note-title">
				<div class="note-editor__head">
					<h2 id="published-note-title" class="note-editor__title note-editor__title--static">Titolo della nota</h2>
					<button class="note-editor__icon-button" type="button" aria-label="Elimina nota" data-note-delete>
						<i class="bi bi-trash" aria-hidden="true"></i>
					</button>
				</div>

				<div class="note-editor__body note-editor__body--published">
					<p>
						Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer pretium, nunc sed fermentum
						vehicula, libero sapien gravida ante, vitae cursus magna mi non lorem. Sed porta, augue non
						commodo volutpat, ipsum risus gravida neque, sit amet dictum arcu massa vitae lectus.
					</p>
					<p>
						Curabitur vel nibh at lorem posuere dignissim. Vestibulum ante ipsum primis in faucibus orci
						luctus et ultrices posuere cubilia curae; Donec posuere velit vitae sem facilisis, sed
						consequat lorem efficitur.
					</p>
				</div>
			</section>
		</div>
	</main>

	<script>
		const deleteButton = document.querySelector<HTMLButtonElement>('[data-note-delete]');

		deleteButton?.addEventListener('click', () => {
			window.confirm('Eliminare questa nota?');
		});
	</script>
</Layout>
