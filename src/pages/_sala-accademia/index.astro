---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import arboreaBanner from '../../assets/Arborea-accademia-stendardo-the-secret-bookish-society.png';
import arboreaLogo from '../../assets/Arborea-logo-the-secret-bookish-society.png';
import trophyIcon from '../../assets/trofei-icona-scrivania.png';
import { getAcademyMembersCount, getAcademyRanking } from '../../lib/strapi/accademie';

const { lang = 'it' } = Astro.props;
const jwt = Astro.cookies.get('jwt')?.value;
const academyMembersCount = await getAcademyMembersCount('arborea');
const academyMembersLabel = `${academyMembersCount} ${academyMembersCount === 1 ? 'Adepto' : 'Adepti'}`;
const rankingRows = await getAcademyRanking('arborea', jwt);

const chronicleRows = [
	{ meta: 'OGGI • ADEPTO 3' },
	{ meta: 'IERI • ADEPTO 15' },
	{ meta: 'LUN • ADEPTO 8' },
];
---

<Layout lang={lang}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell academy-page">
		<section class="academy-hero" aria-labelledby="academy-title">
			<img class="academy-hero__crest academy-hero__crest--left" src={arboreaBanner.src} alt="" aria-hidden="true" />

			<div class="academy-hero__content">
				<div class="academy-hero__icon" aria-hidden="true">
					<img
						src={arboreaLogo.src}
						width={arboreaLogo.width}
						height={arboreaLogo.height}
						alt=""
						loading="eager"
						decoding="async"
					/>
				</div>

				<div class="academy-hero__mobile-crest">
					<img src={arboreaBanner.src} alt="" aria-hidden="true" />
					<span class="academy-hero__mobile-logo" aria-hidden="true">
						<img
							src={arboreaLogo.src}
							width={arboreaLogo.width}
							height={arboreaLogo.height}
							alt=""
							loading="eager"
							decoding="async"
						/>
					</span>
					<div class="academy-hero__mobile-copy">
						<h1 id="academy-title">Arborea</h1>
						<p>Aenean placerat eros turpis, nec posuere massa fermentum malesuada. Morbi at est et tortor laoreet placerat id in neque. Maecenas vel erat lacinia, sodales ipsum id.</p>
						<p class="academy-members">
							<i class="bi bi-people" aria-hidden="true"></i>
							<span>{academyMembersLabel}</span>
						</p>
					</div>
				</div>

				<div class="academy-hero__desktop-copy">
					<h1>Arborea</h1>
					<p>Aenean placerat eros turpis, nec posuere massa fermentum malesuada. Morbi at est et tortor laoreet placerat id in neque. Maecenas vel erat lacinia, sodales ipsum id.</p>
					<p class="academy-members">
						<i class="bi bi-people" aria-hidden="true"></i>
						<span>{academyMembersLabel}</span>
					</p>
				</div>
			</div>

			<img class="academy-hero__crest academy-hero__crest--right" src={arboreaBanner.src} alt="" aria-hidden="true" />
		</section>

		<div class="container-xl tsbs-app-container academy-content">
			<section class="academy-section" aria-labelledby="academy-ranking-title">
				<div class="academy-section__head">
					<h2 id="academy-ranking-title" class="tsbs-section-title">Classifica</h2>
					<a class="missions-load-more academy-ranking-more academy-section__link--desktop" href="/sala-accademia/classifica-generale/">
						<span>Guarda tutta la classifica</span>
						<i class="bi bi-arrow-right" aria-hidden="true"></i>
					</a>
				</div>

				<div class="academy-ranking-list">
					{rankingRows.map((row) => (
						<a class={`academy-ranking-card ${row.current ? 'is-current' : ''}`} href={row.href}>
							<div class="academy-ranking-card__position">
								{row.medal ? (
									<img
										class={`academy-ranking-card__medal-icon is-${row.medal}`}
										src={trophyIcon.src}
										width={trophyIcon.width}
										height={trophyIcon.height}
										alt=""
										aria-hidden="true"
										loading="lazy"
										decoding="async"
									/>
								) : (
									<span>{row.position}</span>
								)}
								<span class={`academy-ranking-card__roman ${row.medal ? `is-${row.medal}` : ''}`}>{row.medal ? row.position : ''}</span>
							</div>
							<div class="academy-ranking-card__avatar" aria-hidden="true">{row.initials}</div>
							<p class="academy-ranking-card__name">{row.name}</p>
							<p class="academy-ranking-card__points">
								<strong>{row.points}</strong>
								<i class="bi bi-trophy" aria-hidden="true"></i>
							</p>
						</a>
					))}
				</div>

				<a class="missions-load-more academy-ranking-more academy-section__link--mobile" href="/sala-accademia/classifica-generale/">
					<span>Guarda tutta la classifica</span>
					<i class="bi bi-arrow-right" aria-hidden="true"></i>
				</a>
			</section>

			<section class="academy-section academy-chronicles" aria-labelledby="academy-chronicles-title">
				<h2 id="academy-chronicles-title" class="tsbs-section-title">Cronache della Società</h2>

				<div class="academy-chronicles-list">
					{chronicleRows.map((row, index) => (
						<article class={`academy-note-card ${index > 1 ? 'is-hidden' : ''}`} data-academy-note-card>
							<div>
								<p class="academy-note-card__meta">{row.meta}</p>
								<h3>Titolo della nota</h3>
								<p>Adepti della Civetta, la Sala Dantesca richiede la vostra attenzione. Nuovi indizi sono apparsi...</p>
							</div>
							<i class="bi bi-chevron-right" aria-hidden="true"></i>
						</article>
					))}
				</div>

				<button class="missions-load-more academy-load-more" type="button" data-load-more aria-controls="academy-chronicles-title">
					<span>Carica altro</span>
					<i class="bi bi-arrow-right" aria-hidden="true"></i>
				</button>
			</section>
		</div>
	</main>

	<script>
		const academyLoadMore = document.querySelector<HTMLButtonElement>('.academy-load-more[data-load-more]');
		const academyHiddenCards = document.querySelectorAll<HTMLElement>('[data-academy-note-card].is-hidden');

		if (academyLoadMore && academyHiddenCards.length === 0) {
			academyLoadMore.hidden = true;
		}

		academyLoadMore?.addEventListener('click', () => {
			document.querySelectorAll<HTMLElement>('[data-academy-note-card].is-hidden').forEach((card) => {
				card.classList.remove('is-hidden');
			});

			academyLoadMore.hidden = true;
			academyLoadMore.dataset.expanded = 'true';
		});
	</script>
</Layout>
