---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import AvatarProfiloModal from '../../../components/PopupComponents/AvatarProfiloModal.astro';
import avatar01 from '../../../assets/Avatar_01_tartaruga.svg';

const { lang = 'it' } = Astro.props;
if (!Astro.cookies.has('jwt')) {
	return Astro.redirect('/');
}
---

<Layout lang={lang} theme="theme-neutral">
	<Nav lang={lang} />
	<main class="tsbs-app-shell profile-settings-page">
		<div class="container-xl tsbs-app-container profile-settings">
			<header class="profile-settings__header" aria-labelledby="profile-settings-title">
				<p class="profile-settings__eyebrow">Profilo e impostazioni</p>
				<div class="profile-settings__heading">
					<div>
						<h1 id="profile-settings-title">Il tuo profilo</h1>
						<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
					</div>
					<a class="profile-settings__back-link" href="/atrio/">
						<i class="bi bi-arrow-left" aria-hidden="true"></i>
						<span>Indietro</span>
					</a>
				</div>
			</header>

			<div class="profile-settings__layout">
				<aside class="profile-settings__summary" aria-labelledby="profile-summary-title">
					<div class="profile-settings__avatar">
						<img
							src={avatar01.src}
							width={avatar01.width}
							height={avatar01.height}
							alt=""
							loading="eager"
							decoding="async"
							data-profile-avatar-current
						/>
						<button class="profile-settings__avatar-edit" type="button" data-avatar-profile-modal-open aria-label="Scegli nuovo avatar">
							<i class="bi bi-pencil" aria-hidden="true"></i>
						</button>
					</div>
					<div>
						<h2 id="profile-summary-title" data-profile-username>—</h2>
						<p data-profile-livello>—</p>
					</div>
					<dl class="profile-settings__meta">
						<div>
							<dt>Accademia</dt>
							<dd data-profile-accademia>—</dd>
						</div>
						<div>
							<dt>Email</dt>
							<dd data-profile-email>—</dd>
						</div>
					</dl>
				</aside>

				<form class="profile-settings__form" action="#" method="post">
					<section class="profile-settings-card" aria-labelledby="username-title">
						<div class="profile-settings-card__head">
							<span class="profile-settings-card__icon" aria-hidden="true">
								<i class="bi bi-person"></i>
							</span>
							<div>
								<h2 id="username-title">Scegli nuovo username</h2>
								<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
							</div>
						</div>
						<div class="profile-settings-fields">
							<label>
								<span>Nuovo username</span>
								<input name="username" type="text" autocomplete="username" value="" data-profile-username-input />
							</label>
						</div>
					</section>

					<section class="profile-settings-card" aria-labelledby="password-title">
						<div class="profile-settings-card__head">
							<span class="profile-settings-card__icon" aria-hidden="true">
								<i class="bi bi-shield-lock"></i>
							</span>
							<div>
								<h2 id="password-title">Reimposta password</h2>
								<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
							</div>
						</div>
						<div class="profile-settings-fields profile-settings-fields--password">
							<label>
								<span>Password attuale</span>
								<input name="current-password" type="password" autocomplete="current-password" />
							</label>
							<label>
								<span>Nuova password</span>
								<input name="new-password" type="password" autocomplete="new-password" />
							</label>
							<label>
								<span>Conferma password</span>
								<input name="confirm-password" type="password" autocomplete="new-password" />
							</label>
						</div>
						<p class="profile-settings-fields__error" data-password-error hidden></p>
					</section>

					<div class="profile-settings-actions">
						<a class="btn tsbs-cta-primary-soft profile-settings-actions__button" href="/atrio/">Annulla</a>
						<button class="btn tsbs-cta-primary profile-settings-actions__button" type="submit">Salva modifiche</button>
					</div>
				</form>
			</div>
		</div>
	</main>

	<AvatarProfiloModal renderHidden />
</Layout>

<script>
	// --- Caricamento dati utente corrente ---

	const loadProfilo = async () => {
		try {
			const res = await fetch('/api/user/profilo');
			if (!res.ok) return;
			const profilo = await res.json();

			const set = (sel: string, val: string | null) => {
				const el = document.querySelector(sel);
				if (el instanceof HTMLElement && val) el.textContent = val;
			};

			set('[data-profile-username]', profilo.username);
			set('[data-profile-livello]', profilo.livello);
			set('[data-profile-accademia]', profilo.accademia);
			set('[data-profile-email]', profilo.email);

			const usernameInput = document.querySelector<HTMLInputElement>('[data-profile-username-input]');
			if (usernameInput && profilo.username) usernameInput.value = profilo.username;

			if (profilo.avatarSrc) {
				const img = document.querySelector<HTMLImageElement>('[data-profile-avatar-current]');
				if (img) img.src = profilo.avatarSrc;
			}
		} catch {
			// Dati non disponibili: la pagina resta con i placeholder
		}
	};

	loadProfilo();
	document.addEventListener('astro:page-load', loadProfilo);

	const setupProfileAvatarPicker = () => {
		const openControls = document.querySelectorAll<HTMLElement>('[data-avatar-profile-modal-open]');
		const currentAvatar = document.querySelector<HTMLImageElement>('[data-profile-avatar-current]');

		openControls.forEach((control) => {
			if (control.dataset.avatarProfileOpenReady === 'true') return;
			control.dataset.avatarProfileOpenReady = 'true';

			control.addEventListener('click', () => {
				document.dispatchEvent(new CustomEvent('tsbs:avatar-profile-modal-open'));
			});
		});

		document.addEventListener('tsbs:avatar-profile-change', (event) => {
			if (!(event instanceof CustomEvent) || !currentAvatar) return;

			const src = event.detail?.src;
			if (typeof src === 'string' && src.length > 0) {
				currentAvatar.src = src;
			}
		});
	};

	document.addEventListener('astro:page-load', setupProfileAvatarPicker);
	setupProfileAvatarPicker();

	// --- Cambio password ---

	const setupPasswordChange = () => {
		const form = document.querySelector<HTMLFormElement>('.profile-settings__form');
		if (!form) return;

		// Guardia contro doppia inizializzazione (astro:page-load + chiamata diretta)
		if (form.dataset.passwordChangeReady === 'true') return;
		form.dataset.passwordChangeReady = 'true';

		const currentPwInput = form.querySelector<HTMLInputElement>('[name="current-password"]');
		const newPwInput = form.querySelector<HTMLInputElement>('[name="new-password"]');
		const confirmPwInput = form.querySelector<HTMLInputElement>('[name="confirm-password"]');
		const errorEl = document.querySelector<HTMLElement>('[data-password-error]');
		const submitBtn = form.querySelector<HTMLButtonElement>('[type="submit"]');

		if (!currentPwInput || !newPwInput || !confirmPwInput) return;

		const showError = (message: string) => {
			if (!errorEl) return;
			errorEl.textContent = message;
			errorEl.hidden = false;
		};

		const clearError = () => {
			if (!errorEl) return;
			errorEl.textContent = '';
			errorEl.hidden = true;
		};

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			clearError();

			const currentPassword = currentPwInput.value.trim();
			const password = newPwInput.value;
			const passwordConfirmation = confirmPwInput.value;

			// Se tutti e tre i campi sono vuoti non fare nulla (il form gestisce anche altri pannelli)
			if (!currentPassword && !password && !passwordConfirmation) return;

			// Validazione client-side
			if (!currentPassword || !password || !passwordConfirmation) {
				showError('Compila tutti i campi per cambiare la password.');
				return;
			}
			if (password !== passwordConfirmation) {
				showError('La nuova password e la conferma non coincidono.');
				return;
			}
			if (password.length < 8) {
				showError('La nuova password deve contenere almeno 8 caratteri.');
				return;
			}

			if (submitBtn) submitBtn.disabled = true;

			try {
				const res = await fetch('/api/auth/change-password', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ currentPassword, password, passwordConfirmation }),
				});

				const data = await res.json();

				if (!res.ok) {
					showError(data.message ?? 'Errore durante il cambio password.');
					return;
				}

				// Successo: svuota i campi
				currentPwInput.value = '';
				newPwInput.value = '';
				confirmPwInput.value = '';
			} catch {
				showError('Errore di rete. Riprova più tardi.');
			} finally {
				if (submitBtn) submitBtn.disabled = false;
			}
		});
	};

	document.addEventListener('astro:page-load', setupPasswordChange);
	setupPasswordChange();
</script>

<style lang="scss">
	.profile-settings-page {
		--profile-current-academy-accent: var(--tsbs-color-arborea);

		min-height: 100vh;
		min-height: 100dvh;
		background-color: var(--tsbs-color-surface);
		background-image: none;
	}

	.profile-settings {
		display: grid;
		gap: 1.5rem;
	}

	.profile-settings__header {
		display: grid;
		gap: 0.75rem;
	}

	.profile-settings__eyebrow {
		margin: 0;
		color: var(--tsbs-color-neutral-accent);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.profile-settings__heading {
		display: grid;
		gap: 1rem;
	}

	.profile-settings__heading h1,
	.profile-settings__heading p {
		margin: 0;
	}

	.profile-settings__heading h1 {
		font-size: clamp(2rem, 8vw, 3rem);
	}

	.profile-settings__heading p {
		max-width: 38rem;
		color: var(--tsbs-color-body);
	}

	.profile-settings__back-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		width: fit-content;
		min-height: 2.75rem;
		padding: 0.625rem 0.875rem;
		color: var(--tsbs-color-white);
		text-decoration: none;
		background: var(--profile-current-academy-accent);
		border: 1px solid var(--profile-current-academy-accent);
		border-radius: var(--tsbs-radius-md);
	}

	.profile-settings__back-link:hover,
	.profile-settings__back-link:focus {
		color: var(--tsbs-theme-cta-hover-color);
		background: var(--tsbs-theme-cta-hover-bg);
		border-color: var(--tsbs-theme-cta-hover-border);
	}

	.profile-settings__layout,
	.profile-settings__form {
		display: grid;
		gap: 1rem;
	}

	.profile-settings__summary,
	.profile-settings-card {
		background: var(--tsbs-color-white);
		border: 1px solid color-mix(in srgb, var(--tsbs-color-neutral) 14%, var(--tsbs-color-white));
		border-radius: var(--tsbs-radius-md);
	}

	.profile-settings__summary {
		display: grid;
		gap: 1rem;
		align-content: start;
		min-width: 0;
		padding: 1.25rem;
	}

	.profile-settings__avatar {
		position: relative;
		display: grid;
		place-items: center;
		width: 5rem;
		aspect-ratio: 1;
		color: var(--tsbs-color-neutral);
		background: var(--tsbs-color-neutral-soft);
		border: 0.125rem solid var(--profile-current-academy-accent);
		border-radius: 50%;
	}

	.profile-settings__avatar img {
		width: 82%;
		height: 82%;
		object-fit: contain;
		transform: scale(1.18);
	}

	.profile-settings__avatar-edit {
		position: absolute;
		right: -0.25rem;
		bottom: -0.25rem;
		display: grid;
		place-items: center;
		width: 1.75rem;
		aspect-ratio: 1;
		color: var(--tsbs-color-white);
		background: var(--tsbs-color-neutral);
		border: 1px solid var(--tsbs-color-white);
		border-radius: 50%;
		box-shadow: 0 0.25rem 0.75rem rgba(41, 31, 24, 0.16);
	}

	.profile-settings__avatar-edit .bi {
		font-size: 0.75rem;
		line-height: 1;
	}

	.profile-settings__avatar-edit:hover {
		background: var(--tsbs-global-cta-var1-hover-bg);
	}

	.profile-settings__avatar-edit:focus-visible {
		outline: 0.1875rem solid var(--tsbs-color-focus);
		outline-offset: 0.1875rem;
	}

	.profile-settings__summary h2,
	.profile-settings__summary p,
	.profile-settings__meta,
	.profile-settings__meta dd {
		margin: 0;
	}

	.profile-settings__summary h2 {
		min-width: 0;
		font-size: 1.5rem;
		overflow-wrap: anywhere;
	}

	.profile-settings__summary p {
		font-style: italic;
	}

	.profile-settings__meta {
		display: grid;
		gap: 0.875rem;
		min-width: 0;
		padding-top: 0.5rem;
	}

	.profile-settings__meta div {
		display: grid;
		gap: 0.125rem;
		min-width: 0;
	}

	.profile-settings__meta dt {
		color: var(--tsbs-color-neutral);
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.profile-settings__meta dd {
		min-width: 0;
		max-width: 100%;
		overflow-wrap: anywhere;
		word-break: break-word;
	}

	.profile-settings-card {
		display: grid;
		gap: 1.25rem;
		padding: 1.25rem;
	}

	.profile-settings-card__head {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: 0.875rem;
		align-items: start;
	}

	.profile-settings-card__icon {
		display: grid;
		place-items: center;
		width: 2.75rem;
		aspect-ratio: 1;
		color: var(--tsbs-color-neutral);
		background: var(--tsbs-color-neutral-soft);
		border-radius: 50%;
	}

	.profile-settings-card h2,
	.profile-settings-card p {
		margin: 0;
	}

	.profile-settings-card h2 {
		font-size: 1.25rem;
	}

	.profile-settings-card p {
		color: var(--tsbs-color-body);
		font-size: 0.9375rem;
	}

	.profile-settings-fields {
		display: grid;
		gap: 1rem;
	}

	.profile-settings-fields label {
		display: grid;
		gap: 0.375rem;
	}

	.profile-settings-fields span {
		color: var(--tsbs-color-heading);
		font-weight: 600;
	}

	.profile-settings-fields input {
		min-height: 3rem;
		width: 100%;
		padding: 0.625rem 0.75rem;
		color: var(--tsbs-color-text);
		background: #ffffff;
		border: 1px solid color-mix(in srgb, var(--tsbs-color-neutral) 18%, var(--tsbs-color-white));
		border-radius: var(--tsbs-radius-sm);
	}

	.profile-settings-academies {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
	}

	.profile-settings-academy {
		position: relative;
		display: grid;
		min-height: 3rem;
		cursor: pointer;
	}

	.profile-settings-academy input {
		position: absolute;
		inset: 0;
		opacity: 0;
		cursor: pointer;
	}

	.profile-settings-academy span {
		display: grid;
		place-items: center;
		padding: 0.625rem;
		color: var(--tsbs-color-neutral);
		font-weight: 600;
		text-align: center;
		background: var(--tsbs-color-neutral-soft);
		border: 1px solid transparent;
		border-radius: var(--tsbs-radius-sm);
	}

	.profile-settings-academy input:checked + span {
		color: var(--tsbs-color-white);
		background: var(--profile-academy-accent);
	}

	.profile-settings-academy input:focus-visible + span {
		outline: 0.1875rem solid var(--tsbs-color-focus);
		outline-offset: 0.1875rem;
	}

	.profile-settings-fields__error {
		margin: 0;
		color: #991b1b;
		font-size: 0.875rem;
	}

	.profile-settings-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: center;
	}

	.profile-settings-actions__button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 8.25rem;
		min-height: 3rem;
		padding: 0.75rem 1rem;
		font-family: var(--tsbs-font-body);
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.2;
		border-radius: 0.3125rem;
	}

	@media (min-width: 768px) {
		.profile-settings__heading {
			grid-template-columns: minmax(0, 1fr) auto;
			align-items: start;
		}
	}

	@media (min-width: 992px) {
		.profile-settings {
			gap: 2rem;
			padding-top: 3rem;
		}

		.profile-settings__layout {
			grid-template-columns: minmax(16rem, 20rem) minmax(0, 1fr);
			grid-template-areas:
				"summary username"
				"summary password"
				". actions";
			align-items: stretch;
			gap: 1.5rem;
		}

		.profile-settings__form {
			display: contents;
		}

		.profile-settings__form .profile-settings-card:nth-of-type(1) {
			grid-area: username;
		}

		.profile-settings__form .profile-settings-card:nth-of-type(2) {
			grid-area: password;
		}

		.profile-settings__summary,
		.profile-settings-card {
			padding: 1.5rem;
		}

		.profile-settings__summary {
			grid-area: summary;
			position: sticky;
			top: 2rem;
			align-self: stretch;
		}

		.profile-settings-actions {
			grid-area: actions;
		}

		.profile-settings-fields--password {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
</style>
