---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import AvatarProfiloModal from '../../../components/PopupComponents/AvatarProfiloModal.astro';
import avatar01 from '../../../assets/Avatar_01_tartaruga.svg';
import { resolveUserContext } from '../../../lib/theme';

const { lang = 'it' } = Astro.props;
if (!Astro.cookies.has('jwt')) {
	return Astro.redirect('/');
}


const { theme, accademia } = await resolveUserContext(Astro.cookies.get('jwt')?.value);
---

<Layout lang={lang} theme={theme} accademia={accademia}>
	<Nav lang={lang} />
	<main class="tsbs-app-shell profile-settings-page">
		<div class="container-xl tsbs-app-container profile-settings">
			<header class="profile-settings__header" aria-labelledby="profile-settings-title">
				<p class="profile-settings__eyebrow">Profilo e impostazioni</p>
				<div class="profile-settings__heading">
					<div>
						<h1 id="profile-settings-title">Il tuo profilo</h1>
						<p class="d-none">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
					</div>
					<a class="profile-settings__back-link" href="/atrio/">
						<i class="bi bi-arrow-left" aria-hidden="true"></i>
						<span>Indietro</span>
					</a>
				</div>
			</header>

			<div class="profile-settings__layout">
				<aside class="profile-settings__summary" aria-labelledby="profile-summary-title">
					<div class="profile-settings__avatar">
						<img
							src={avatar01.src}
							width={avatar01.width}
							height={avatar01.height}
							alt=""
							loading="eager"
							decoding="async"
							data-profile-avatar-current
						/>
						<button class="profile-settings__avatar-edit" type="button" data-avatar-profile-modal-open aria-label="Scegli nuovo avatar">
							<i class="bi bi-pencil" aria-hidden="true"></i>
						</button>
					</div>
					<div>
						<h2 id="profile-summary-title" data-profile-username>—</h2>
						<p data-profile-livello>—</p>
					</div>
					<dl class="profile-settings__meta">
						<div>
							<dt>Accademia</dt>
							<dd data-profile-accademia>—</dd>
						</div>
						<div>
							<dt>Email</dt>
							<dd data-profile-email>—</dd>
						</div>
					</dl>
				</aside>

				<form class="profile-settings__form" action="#" method="post">
					<section class="profile-settings-card" aria-labelledby="username-title">
						<div class="profile-settings-card__head">
							<span class="profile-settings-card__icon" aria-hidden="true">
								<i class="bi bi-person"></i>
							</span>
							<div>
								<h2 id="username-title">Scegli nuovo username</h2>
								<p class="d-none">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
							</div>
						</div>
						<div class="profile-settings-fields">
							<label>
								<span>Nuovo username</span>
								<input name="username" type="text" autocomplete="username" value="" data-profile-username-input />
							</label>
						</div>
					</section>

					<section class="profile-settings-card" aria-labelledby="password-title">
						<div class="profile-settings-card__head">
							<span class="profile-settings-card__icon" aria-hidden="true">
								<i class="bi bi-shield-lock"></i>
							</span>
							<div>
								<h2 id="password-title">Reimposta password</h2>
								<p class="d-none">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
							</div>
						</div>
						<div class="profile-settings-fields profile-settings-fields--password">
							<label>
								<span>Password attuale</span>
								<input name="current-password" type="password" autocomplete="current-password" />
							</label>
							<label>
								<span>Nuova password</span>
								<input name="new-password" type="password" autocomplete="new-password" />
							</label>
							<label>
								<span>Conferma password</span>
								<input name="confirm-password" type="password" autocomplete="new-password" />
							</label>
						</div>
						<p class="profile-settings-fields__error" data-password-error hidden></p>
					</section>

					<div class="profile-settings-actions">
						<p class="profile-settings-actions__feedback" data-settings-feedback hidden></p>
					<a class="btn tsbs-cta-primary-soft profile-settings-actions__button" href="/atrio/">Annulla</a>
					<button class="btn tsbs-cta-primary profile-settings-actions__button" type="submit">Salva impostazioni</button>
				</div>
				</form>

				<!-- Sezione tessera Biblioteca Classense (fuori dal form principale) -->
				<section class="profile-settings-card profile-tessera-card" aria-labelledby="tessera-title" data-tessera-section>
					<div class="profile-settings-card__head">
						<span class="profile-settings-card__icon" aria-hidden="true">
							<i class="bi bi-credit-card-2-front"></i>
						</span>
						<div>
							<h2 id="tessera-title">Tessera Biblioteca Classense</h2>
							<p>Inserisci il numero della tua tessera per sbloccare contenuti esclusivi e ricevere un trofeo speciale.</p>
						</div>
					</div>

					<!-- Stato: nessuna / rifiutata (campo attivo) -->
					<div class="profile-tessera-state" data-tessera-state="nessuna" hidden>
						<div class="profile-settings-fields">
							<label for="tessera-input">
								<span>Numero tessera (14 cifre)</span>
								<input
									id="tessera-input"
									name="tessera"
									type="text"
									inputmode="numeric"
									pattern="\d{14}"
									maxlength="14"
									autocomplete="off"
									placeholder="Es. 12345678901234"
									data-tessera-input
								/>
							</label>
						</div>
						<p class="profile-tessera-error" data-tessera-error hidden></p>
						<div class="profile-tessera-actions">
							<button class="btn tsbs-cta-primary profile-tessera-actions__submit" type="button" data-tessera-submit>
								<span data-tessera-btn-label>Invia per la verifica</span>
								<span data-tessera-btn-loading hidden>
									<span class="tessera-spinner" aria-hidden="true"></span>
									Invio in corso…
								</span>
							</button>
						</div>
					</div>

					<!-- Stato: in_verifica -->
					<div class="profile-tessera-state" data-tessera-state="in_verifica" hidden>
						<div class="profile-tessera-status profile-tessera-status--pending">
							<i class="bi bi-hourglass-split" aria-hidden="true"></i>
							<div>
								<p class="profile-tessera-status__title">In attesa di verifica</p>
								<p class="profile-tessera-status__desc">
									Il numero <strong data-tessera-numero-display></strong> è stato inviato alla Redazione.
									Riceverai una conferma non appena la verifica sarà completata.
								</p>
							</div>
						</div>
					</div>

					<!-- Stato: verificata -->
					<div class="profile-tessera-state" data-tessera-state="verificata" hidden>
						<div class="profile-tessera-status profile-tessera-status--verified">
							<i class="bi bi-patch-check-fill" aria-hidden="true"></i>
							<div>
								<p class="profile-tessera-status__title">Tessera verificata — trofeo assegnato!</p>
								<p class="profile-tessera-status__desc">
									Il numero <strong data-tessera-numero-display></strong> è stato verificato correttamente.
									Il trofeo è disponibile nella tua collezione.
								</p>
							</div>
						</div>
					</div>
				</section>
			</div>

			<div class="profile-settings-danger">
				<p>La cancellazione dell'account è un'operazione irreversibile. Tutti i tuoi dati verranno eliminati definitivamente.</p>
				<button class="btn profile-settings-danger__button" type="button" data-delete-account-open>
					<i class="bi bi-trash3" aria-hidden="true"></i>
					Elimina account
				</button>
			</div>
		</div>
	</main>

	<!-- Modale cancellazione account -->
	<div class="delete-account-overlay" data-delete-account-overlay aria-modal="true" role="dialog" aria-labelledby="delete-account-title" hidden>
		<div class="delete-account-modal">
			<h2 id="delete-account-title">Elimina il tuo account</h2>
			<p class="delete-account-modal__warning">
				<i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
				<span>Questa azione è <strong>irreversibile</strong>. Il tuo account e tutti i dati associati verranno eliminati definitivamente.</span>
			</p>
			<label class="delete-account-modal__label" for="delete-confirm-input">
				Digita <strong>CANCELLAMI</strong> per confermare
			</label>
			<input
				id="delete-confirm-input"
				class="delete-account-modal__input"
				type="text"
				placeholder="CANCELLAMI"
				autocomplete="off"
				data-delete-confirm-input
			/>
			<p class="delete-account-modal__error" data-delete-error hidden></p>
			<div class="delete-account-modal__actions">
				<button class="btn tsbs-cta-primary-soft delete-account-modal__cancel" type="button" data-delete-account-cancel>
					Annulla
				</button>
				<button class="btn delete-account-modal__confirm" type="button" data-delete-account-confirm disabled>
					<span data-delete-btn-label>Elimina il mio account</span>
					<span data-delete-btn-loading hidden>
						<span class="delete-spinner" aria-hidden="true"></span>
						Eliminazione in corso…
					</span>
				</button>
			</div>
		</div>
	</div>

	<AvatarProfiloModal renderHidden />
</Layout>

<script>
	const setupProfileAvatarPicker = () => {
		const openControls = document.querySelectorAll<HTMLElement>('[data-avatar-profile-modal-open]');
		const currentAvatar = document.querySelector<HTMLImageElement>('[data-profile-avatar-current]');

		openControls.forEach((control) => {
			if (control.dataset.avatarProfileOpenReady === 'true') return;
			control.dataset.avatarProfileOpenReady = 'true';

			control.addEventListener('click', () => {
				document.dispatchEvent(new CustomEvent('tsbs:avatar-profile-modal-open'));
			});
		});

		document.addEventListener('tsbs:avatar-profile-change', (event) => {
			if (!(event instanceof CustomEvent) || !currentAvatar) return;

			const src = event.detail?.src;
			if (typeof src === 'string' && src.length > 0) {
				currentAvatar.src = src;
			}
		});
	};

	document.addEventListener('astro:page-load', setupProfileAvatarPicker);
	setupProfileAvatarPicker();

	// --- Salvataggio impostazioni (username + password) ---

	const setupSaveSettings = () => {
		const form = document.querySelector<HTMLFormElement>('.profile-settings__form');
		if (!form) return;

		if (form.dataset.saveSettingsReady === 'true') return;
		form.dataset.saveSettingsReady = 'true';

		const usernameInput = form.querySelector<HTMLInputElement>('[name="username"]');
		const currentPwInput = form.querySelector<HTMLInputElement>('[name="current-password"]');
		const newPwInput = form.querySelector<HTMLInputElement>('[name="new-password"]');
		const confirmPwInput = form.querySelector<HTMLInputElement>('[name="confirm-password"]');
		const errorEl = document.querySelector<HTMLElement>('[data-password-error]');
		const submitBtn = form.querySelector<HTMLButtonElement>('[type="submit"]');

		if (!currentPwInput || !newPwInput || !confirmPwInput) return;

		const showPasswordError = (message: string) => {
			if (!errorEl) return;
			errorEl.textContent = message;
			errorEl.hidden = false;
		};

		const clearPasswordError = () => {
			if (!errorEl) return;
			errorEl.textContent = '';
			errorEl.hidden = true;
		};

		const feedbackEl = document.querySelector<HTMLElement>('[data-settings-feedback]');

		const showFeedback = (message: string, type: 'success' | 'error' | 'info') => {
			if (!feedbackEl) return;
			feedbackEl.textContent = message;
			feedbackEl.dataset.feedbackType = type;
			feedbackEl.hidden = false;
		};

		const clearFeedback = () => {
			if (!feedbackEl) return;
			feedbackEl.textContent = '';
			feedbackEl.hidden = true;
			delete feedbackEl.dataset.feedbackType;
		};

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			clearPasswordError();
			clearFeedback();

			const usernameValue = usernameInput?.value.trim() ?? '';
			const originalUsername = usernameInput?.dataset.originalUsername ?? '';
			const currentPassword = currentPwInput.value.trim();
			const password = newPwInput.value;
			const passwordConfirmation = confirmPwInput.value;

			const wantsUsername = usernameValue.length > 0 && usernameValue !== originalUsername;
			const wantsPassword = currentPassword || password || passwordConfirmation;

			// Nessuna modifica da salvare
			if (!wantsUsername && !wantsPassword) {
				showFeedback('Non hai apportato modifiche da salvare.', 'info');
				return;
			}

			// Validazione password client-side
			if (wantsPassword) {
				if (!currentPassword || !password || !passwordConfirmation) {
					showPasswordError('Compila tutti i campi per cambiare la password.');
					return;
				}
				if (password !== passwordConfirmation) {
					showPasswordError('La nuova password e la conferma non coincidono.');
					return;
				}
				if (password.length < 8) {
					showPasswordError('La nuova password deve contenere almeno 8 caratteri.');
					return;
				}
			}

			if (submitBtn) submitBtn.disabled = true;

			const errors: string[] = [];

			// Salvataggio username
			if (wantsUsername) {
				try {
					const res = await fetch('/api/user/update-username', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ username: usernameValue }),
					});
					const data = await res.json();
					if (!res.ok) {
						errors.push(data.message ?? 'Errore durante l\'aggiornamento del nome utente.');
					} else {
						// Aggiorna username visibile nella sidebar e segna il nuovo valore come originale
						const usernameDisplay = document.querySelector('[data-profile-username]');
						if (usernameDisplay instanceof HTMLElement) usernameDisplay.textContent = usernameValue;
						if (usernameInput) usernameInput.dataset.originalUsername = usernameValue;
					}
				} catch {
					errors.push('Errore di rete durante il salvataggio del nome utente.');
				}
			}

			// Salvataggio password
			if (wantsPassword) {
				try {
					const res = await fetch('/api/auth/change-password', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ currentPassword, password, passwordConfirmation }),
					});
					const data = await res.json();
					if (!res.ok) {
						errors.push(data.message ?? 'Errore durante il cambio password.');
					} else {
						currentPwInput.value = '';
						newPwInput.value = '';
						confirmPwInput.value = '';
					}
				} catch {
					errors.push('Errore di rete durante il cambio password.');
				}
			}

			if (submitBtn) submitBtn.disabled = false;

			if (errors.length > 0) {
				const pwError = errors.find((e) => e.toLowerCase().includes('password'));
				if (pwError) showPasswordError(pwError);
				showFeedback(errors.join(' '), 'error');
			} else {
				showFeedback('Impostazioni salvate con successo.', 'success');
			}
		});
	};

	document.addEventListener('astro:page-load', setupSaveSettings);
	setupSaveSettings();

	// --- Cancellazione account ---

	const CONFIRM_PHRASE = 'CANCELLAMI';

	const setupDeleteAccount = () => {
		const overlay = document.querySelector<HTMLElement>('[data-delete-account-overlay]');
		const openBtn = document.querySelector<HTMLButtonElement>('[data-delete-account-open]');
		const cancelBtn = document.querySelector<HTMLButtonElement>('[data-delete-account-cancel]');
		const confirmBtn = document.querySelector<HTMLButtonElement>('[data-delete-account-confirm]');
		const confirmInput = document.querySelector<HTMLInputElement>('[data-delete-confirm-input]');
		const errorEl = document.querySelector<HTMLElement>('[data-delete-error]');
		const labelEl = document.querySelector<HTMLElement>('[data-delete-btn-label]');
		const loadingEl = document.querySelector<HTMLElement>('[data-delete-btn-loading]');

		if (!overlay || !openBtn || !cancelBtn || !confirmBtn || !confirmInput) return;
		if (openBtn.dataset.deleteAccountReady === 'true') return;
		openBtn.dataset.deleteAccountReady = 'true';

		const openModal = () => {
			confirmInput.value = '';
			confirmBtn.disabled = true;
			if (errorEl) errorEl.hidden = true;
			overlay.hidden = false;
			confirmInput.focus();
		};

		const closeModal = () => {
			overlay.hidden = true;
		};

		const setLoading = (loading: boolean) => {
			confirmBtn.disabled = loading;
			if (labelEl) labelEl.hidden = loading;
			if (loadingEl) loadingEl.hidden = !loading;
		};

		const showError = (msg: string) => {
			if (!errorEl) return;
			errorEl.textContent = msg;
			errorEl.hidden = false;
		};

		openBtn.addEventListener('click', openModal);
		cancelBtn.addEventListener('click', closeModal);

		overlay.addEventListener('click', (e) => {
			if (e.target === overlay) closeModal();
		});

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && !overlay.hidden) closeModal();
		});

		confirmInput.addEventListener('input', () => {
			confirmBtn.disabled = confirmInput.value !== CONFIRM_PHRASE;
			if (errorEl) errorEl.hidden = true;
		});

		confirmBtn.addEventListener('click', async () => {
			if (confirmInput.value !== CONFIRM_PHRASE) return;

			setLoading(true);

			try {
				const res = await fetch('/api/user/delete-account', { method: 'DELETE' });

				if (!res.ok) {
					const data = await res.json().catch(() => ({}));
					console.error('[DeleteAccount] Errore API:', data);
					showError('Si è verificato un errore durante la cancellazione. Riprova o contatta il supporto.');
					setLoading(false);
					return;
				}

				// Tutto ok: redirect alla index
				window.location.href = '/';
			} catch (err) {
				console.error('[DeleteAccount] Errore di rete:', err);
				showError('Errore di rete. Verifica la connessione e riprova.');
				setLoading(false);
			}
		});
	};

	document.addEventListener('astro:page-load', setupDeleteAccount);
	setupDeleteAccount();

	// --- Tessera Biblioteca Classense ---

	const setupTessera = () => {
		const section = document.querySelector<HTMLElement>('[data-tessera-section]');
		if (!section) return;
		if (section.dataset.tesseraReady === 'true') return;
		section.dataset.tesseraReady = 'true';

		const input = section.querySelector<HTMLInputElement>('[data-tessera-input]');
		const submitBtn = section.querySelector<HTMLButtonElement>('[data-tessera-submit]');
		const errorEl = section.querySelector<HTMLElement>('[data-tessera-error]');
		const btnLabel = section.querySelector<HTMLElement>('[data-tessera-btn-label]');
		const btnLoading = section.querySelector<HTMLElement>('[data-tessera-btn-loading]');

		const showState = (stato: string, tessera?: string | null) => {
			section.querySelectorAll<HTMLElement>('[data-tessera-state]').forEach((el) => {
				el.hidden = el.dataset.tesseraState !== stato;
			});
			if (tessera) {
				section.querySelectorAll<HTMLElement>('[data-tessera-numero-display]').forEach((el) => {
					el.textContent = tessera;
				});
			}
		};

		const showError = (msg: string) => {
			if (!errorEl) return;
			errorEl.textContent = msg;
			errorEl.hidden = false;
		};

		const clearError = () => {
			if (!errorEl) return;
			errorEl.hidden = true;
		};

		const setLoading = (loading: boolean) => {
			if (submitBtn) submitBtn.disabled = loading;
			if (btnLabel) btnLabel.hidden = loading;
			if (btnLoading) btnLoading.hidden = !loading;
		};

		// Inizializza stato dalla risposta profilo (già caricata da loadProfilo)
		// La funzione viene richiamata via evento custom dopo il caricamento del profilo
		const initFromProfilo = (statoTessera: string, tessera: string | null) => {
			showState(statoTessera, tessera);
		};

		document.addEventListener('tsbs:profilo-loaded', (e) => {
			if (!(e instanceof CustomEvent)) return;
			const { statoTessera, tessera } = e.detail ?? {};
			initFromProfilo(statoTessera ?? 'nessuna', tessera ?? null);
		});

		if (!submitBtn || !input) return;

		submitBtn.addEventListener('click', async () => {
			clearError();

			const valore = input.value.replace(/[\s-]+/g, '').trim();

			if (!/^\d{14}$/.test(valore)) {
				showError('Inserisci un numero tessera valido (14 cifre numeriche).');
				input.focus();
				return;
			}

			setLoading(true);

			try {
				const res = await fetch('/api/user/tessera', {
					method: 'PUT',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ tessera: valore }),
				});

				const data = await res.json().catch(() => ({}));

				if (!res.ok) {
					if (res.status === 409) {
						showError('La tessera è già in attesa di verifica.');
					} else if (data?.message) {
						showError(data.message);
					} else {
						showError('Si è verificato un errore. Riprova più tardi.');
					}
					setLoading(false);
					return;
				}

				// Successo: transizione a in_verifica
				showState('in_verifica', valore);
			} catch {
				showError('Errore di rete. Verifica la connessione e riprova.');
				setLoading(false);
			}
		});
	};

	// Versione aggiornata di loadProfilo che emette l'evento per la tessera
	const loadProfiloConTessera = async () => {
		try {
			const res = await fetch('/api/user/profilo');
			if (!res.ok) return;
			const profilo = await res.json();

			const set = (sel: string, val: string | null) => {
				const el = document.querySelector(sel);
				if (el instanceof HTMLElement && val) el.textContent = val;
			};

			set('[data-profile-username]', profilo.username);
			set('[data-profile-livello]', profilo.livello);
			set('[data-profile-accademia]', profilo.accademia);
			set('[data-profile-email]', profilo.email);

			const usernameInput = document.querySelector<HTMLInputElement>('[data-profile-username-input]');
			if (usernameInput && profilo.username) {
				usernameInput.value = profilo.username;
				usernameInput.dataset.originalUsername = profilo.username;
			}

			if (profilo.avatarSrc) {
				const img = document.querySelector<HTMLImageElement>('[data-profile-avatar-current]');
				if (img) img.src = profilo.avatarSrc;
			}

			// Notifica la sezione tessera
			document.dispatchEvent(new CustomEvent('tsbs:profilo-loaded', {
				detail: {
					statoTessera: profilo.statoTessera ?? 'nessuna',
					tessera: profilo.tessera ?? null,
				},
			}));
		} catch {
			// Dati non disponibili: la pagina resta con i placeholder
		}
	};

	document.addEventListener('astro:page-load', setupTessera);
	setupTessera();

	loadProfiloConTessera();
