---
import RankingAccademia from '../components/ClassificaComponents/RankingAccademia.astro';
import { resolveUserContext } from '../lib/theme';
import { getReturnToLabel, getSafeReturnTo } from '../lib/navigation';

const { lang = 'it' } = Astro.props;
if (!Astro.cookies.has('jwt')) {
	return Astro.redirect('/');
}

const academyKeys = ['astraria', 'arcadia', 'armonia', 'arborea'] as const;
type AcademyKey = typeof academyKeys[number];
const isAcademyKey = (value: string | null): value is AcademyKey =>
	value !== null && academyKeys.includes(value as AcademyKey);

const userContext = await resolveUserContext(Astro.cookies.get('jwt')?.value);
const requestedAcademy = Astro.url.searchParams.get('accademia');
const accademia = isAcademyKey(requestedAcademy) ? requestedAcademy : userContext.accademia;
const theme = `theme-${accademia}`;
const returnTo = getSafeReturnTo(Astro.url, `/sala-accademia-${accademia}/`);
const returnToLabel = getReturnToLabel(returnTo, 'Torna indietro');
---

<RankingAccademia
	lang={lang}
	theme={theme}
	academy={accademia}
	showBoxCronache={false}
	showUserRank={true}
	backHref={returnTo}
	backLabel={returnToLabel}
/>
