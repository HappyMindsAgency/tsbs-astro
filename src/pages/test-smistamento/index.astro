---
import Layout from '../../layouts/Layout.astro';
import TestSmistamento from '../../components/TestSmistamentoComponents/TestSmistamento.astro';
import RisultatoSmistamento from '../../components/TestSmistamentoComponents/RisultatoSmistamento.astro';
import ConfermaAccademia from '../../components/TestSmistamentoComponents/ConfermaAccademia.astro';
import SceltaAvatar from '../../components/TestSmistamentoComponents/SceltaAvatar.astro';
import { isAcademySlug } from '../../lib/strapi/user-academy';

const { lang = 'it' } = Astro.props;

const requestedStep = Astro.url.searchParams.get('step') || 'test';
const requestedAcademy = Astro.url.searchParams.get('academy');
const academy = isAcademySlug(requestedAcademy) ? requestedAcademy : undefined;
const theme = academy ? `theme-${academy}` : 'theme-neutral';
const stepsRequiringAcademy = ['risultato', 'conferma-accademia', 'scelta-avatar'];

const steps = {
	test: TestSmistamento,
	risultato: RisultatoSmistamento,
	'conferma-accademia': ConfermaAccademia,
	'scelta-avatar': SceltaAvatar,
};

const CurrentStep = steps[requestedStep as keyof typeof steps] || TestSmistamento;
if (!Astro.cookies.has('jwt')) {
	return Astro.redirect('/');
}

if (stepsRequiringAcademy.includes(requestedStep) && !academy) {
	return Astro.redirect('/test-smistamento/');
}
---

<Layout lang={lang} theme={theme}>
	<main class="test-smistamento-page">
		<CurrentStep lang={lang} selectedAcademy={academy} academy={academy} />
	</main>
</Layout>

<style lang="scss">
	.test-smistamento-page {
		min-height: 100dvh;
		background: var(--tsbs-color-surface);
	}
</style>
