---
import Layout from '../../layouts/Layout.astro';
import RisultatoSmistamento from '../../components/TestSmistamentoComponents/RisultatoSmistamento.astro';
import ConfermaAccademia from '../../components/TestSmistamentoComponents/ConfermaAccademia.astro';
import SceltaAvatar from '../../components/TestSmistamentoComponents/SceltaAvatar.astro';
import { isAcademySlug } from '../../lib/strapi/user-academy';

const { lang = 'it' } = Astro.props;
const { accademia } = Astro.params;

const requestedStep = Astro.url.searchParams.get('step') || 'risultato';
const academy = isAcademySlug(accademia) ? accademia : undefined;

if (!academy) {
	return Astro.redirect('/test-smistamento/');
}

const theme = `theme-${academy}`;

const steps = {
	risultato: RisultatoSmistamento,
	'conferma-accademia': ConfermaAccademia,
	'scelta-avatar': SceltaAvatar,
};

const CurrentStep = steps[requestedStep as keyof typeof steps] || RisultatoSmistamento;
---

<Layout lang={lang} theme={theme}>
	<main class="test-smistamento-page">
		<CurrentStep lang={lang} selectedAcademy={academy} academy={academy} />
	</main>
</Layout>

<style lang="scss">
	.test-smistamento-page {
		min-height: 100dvh;
		background: var(--tsbs-color-surface);
	}
</style>
