---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import societaSegretaImage from '../../assets/tsbs-logo-the-secret-bookish-society.png';
import accademieImage from '../../assets/biblioteca-le-accademie.png';
import classenseImage from '../../assets/classense-logo-the-secret-bookish-society.png';
import { resolveUserContext } from '../../lib/theme';

const { lang = 'it' } = Astro.props;

const archiveItems = [
	{
		id: 'societa-segreta',
		title: 'The Secret Bookish Society',
		text: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.',
		image: societaSegretaImage,
		iconClass: 'biblioteca-archive-card__icon--tsbs',
		href: '/biblioteca/the-secret-bookish-society/',
	},
	{
		id: 'accademie',
		title: 'Le Accademie',
		text: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.',
		image: accademieImage,
		iconClass: '',
		href: '/biblioteca/accademie/',
	},
	{
		id: 'classense',
		title: 'La Biblioteca Classense',
		text: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.',
		image: classenseImage,
		iconClass: '',
		href: '/biblioteca/classense/',
	},
];
if (!Astro.cookies.has('jwt')) {
	return Astro.redirect('/');
}

const { theme, accademia } = await resolveUserContext(Astro.cookies.get('jwt')?.value);
---

<Layout lang={lang} theme={theme} accademia={accademia}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell missions-shell biblioteca-page">
		<header class="missions-header biblioteca-header">
			<h1>Biblioteca</h1>
		</header>

		<section class="container-xl tsbs-app-container biblioteca-content" aria-labelledby="biblioteca-title">
			<h2 id="biblioteca-title" class="visually-hidden">Biblioteca</h2>

			<div class="biblioteca-intro">
				<p>La Biblioteca Classense non è soltanto il luogo in cui la Società ha preso forma. È la sua origine, la sua memoria e il suo territorio più vivo.</p>
				<p>Tra sale, chiostri, archivi, fondi antichi e tracce nascoste, <strong>ogni spazio custodisce qualcosa di unico</strong>: una storia, un simbolo, una presenza, una domanda rimasta in attesa.</p>
				<p>In questa sezione puoi conoscere meglio la Biblioteca, la Società e le Accademie che ne custodiscono e preservano intatto lo spirito.</p>
			</div>

			<section class="biblioteca-archive" aria-labelledby="biblioteca-archive-title">
				<h2 id="biblioteca-archive-title" class="tsbs-section-title">Esplora l'Archivio</h2>

				<div class="biblioteca-archive__list">
					{archiveItems.map((item) => (
						<a class="biblioteca-archive-card" href={item.href}>
							<span class={`biblioteca-archive-card__icon ${item.iconClass}`} aria-hidden="true">
								<img src={item.image.src} alt="" loading="lazy" />
							</span>
							<span class="biblioteca-archive-card__copy">
								<strong class="biblioteca-archive-card__title">{item.title}</strong>
								<span class="biblioteca-archive-card__description">
									{item.id === 'societa-segreta' ? (
										<>
											<span>The Secret Bookish Society nasce per proteggere, tramandare e rinnovare un sapere che non può essere rivelato a chiunque.</span>
											<span><strong>Le sue radici affondano in tradizioni antiche tra libri, viaggiatori, accademie e presenze importanti</strong> che hanno attraversato Ravenna lasciando tracce più profonde di quanto sembri.</span>
											<span>Chi entra impara a leggere oltre la superficie: nelle pagine, negli spazi, nei simboli e nei silenzi della Biblioteca.</span>
										</>
									) : item.id === 'accademie' ? (
										<>
											<span>All’interno della Società, ogni Iniziato trova il proprio posto all'interno di una delle quattro Accademie: <strong>Astraria, Arcadia, Armonia e Arborea.</strong></span>
											<span>Non sono semplici gruppi, ma modi diversi di vivere il sapere. C’è chi osserva nel silenzio, chi affina la parola, chi crea attraverso la relazione e chi custodisce ciò che cresce lentamente.</span>
											<span>Ogni Accademia ha un tempo, un simbolo, una Guida. Scoprire a quale appartieni significa riconoscere il modo in cui sei chiamato a contribuire alla Società.</span>
										</>
									) : item.id === 'classense' ? (
										<>
											<span><strong>La Classense è il cuore pulsante di The Secret Bookish Society.</strong></span>
											<span>Un luogo reale, antico e vivo, dove la memoria della città incontra il sapere custodito nei libri, nei manoscritti, nelle mappe, nelle immagini e negli archivi.</span>
										</>
									) : (
										item.text
									)}
								</span>
							</span>
						</a>
					))}
				</div>
			</section>
		</section>
	</main>
</Layout>
