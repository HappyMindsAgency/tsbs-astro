---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import classificaIcon from '../../assets/03_classifica_bianco_scrivania.svg';
import grimorioIcon from '../../assets/icona-grimorio-light-scrivania.png';
import trofeiIcon from '../../assets/01_trofei_bianco_scrivania.svg';
import scrivaniaArboreaHero from '../../assets/scrivania-arborea.jpg';
import scrivaniaArcadiaHero from '../../assets/scrivania-arcadia.jpg';
import scrivaniaArmoniaHero from '../../assets/scrivania-armonia.jpg';
import scrivaniaAstrariaHero from '../../assets/scrivania-astraria.jpg';
import { resolveUserContext } from '../../lib/theme';
import { withReturnTo } from '../../lib/navigation';
import {
	formatGrimorioDate,
	getCurrentMembroFromJwt,
	getGrimorioCategorySlug,
	getGrimorioExcerpt,
	getGrimorioNoteByMembro,
	getGrimorioStateLabel,
} from '../../lib/strapi/grimorio';

const { lang = 'it' } = Astro.props;
const jwt = Astro.cookies.get('jwt')?.value;

const featuredNoteHref = '/scrivania/grimorio/nuova/';
const rankingHref = withReturnTo('/classifica-generale/', '/scrivania/');
if (!jwt) {
	return Astro.redirect('/');
}

const { theme, accademia } = await resolveUserContext(Astro.cookies.get('jwt')?.value);
const membro = await getCurrentMembroFromJwt(jwt);
const notes = membro ? await getGrimorioNoteByMembro(membro.documentId, lang) : [];
const deskHeroImages = {
	arborea: scrivaniaArboreaHero,
	arcadia: scrivaniaArcadiaHero,
	armonia: scrivaniaArmoniaHero,
	astraria: scrivaniaAstrariaHero,
};
const deskHeroImage = deskHeroImages[accademia] ?? scrivaniaArboreaHero;

const getNoteMeta = (note: (typeof notes)[number]) => {
	const dayLabel = formatGrimorioDate(note.publishedAt);
	const scopeLabel = getGrimorioStateLabel(note);

	return [dayLabel, scopeLabel].filter(Boolean).join(' • ');
};

const getNoteHref = (note: (typeof notes)[number]) => {
	const isEditableSavedNote = !note.visibilePubblico && getGrimorioCategorySlug(note) === 'salvata';
	return isEditableSavedNote
		? `/scrivania/grimorio/${note.slug}/`
		: `/scrivania/grimorio/pubblicate/${note.slug}/`;
};
---

<Layout lang={lang} theme={theme} accademia={accademia}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell desk-page" style={`--desk-hero-pattern: url(${deskHeroImage.src});`}>
		<header class="desk-hero" aria-labelledby="desk-title">
			<div class="desk-hero__panel">
				<a class="desk-favorites-button" href="/scrivania/utenti-preferiti/" aria-label="Utenti preferiti">
					<i class="bi bi-heart" aria-hidden="true"></i>
				</a>

				<div class="desk-identity-card">
					<p class="desk-academy-pill" data-desk-accademia>—</p>

					<div class="desk-avatar" aria-hidden="true" data-desk-avatar>
						<i class="bi bi-eyeglasses" data-desk-avatar-fallback></i>
						<canvas class="avatar-lottie" data-avatar-lottie data-desk-avatar-img hidden></canvas>
					</div>

					<h1 id="desk-title">
						<a class="desk-username-link" href="/scrivania/i-codici/" data-desk-username>—</a>
					</h1>
					<p class="desk-rank" data-desk-livello>—</p>
					<p class="desk-code">
						<i class="bi bi-person-vcard" aria-hidden="true"></i>
						<span data-desk-codice>—</span>
					</p>
				</div>
			</div>
		</header>

		<div class="container-xl tsbs-app-container desk-content">
			<section class="desk-section" aria-labelledby="recap-title">
				<h2 id="recap-title" class="tsbs-section-title">La tua scrivania</h2>

				<div class="desk-recap-grid">
					<a class="desk-recap-card" href="/scrivania/trofei/">
						<img
							class="desk-recap-card__icon"
							src={trofeiIcon.src}
							width={trofeiIcon.width}
							height={trofeiIcon.height}
							alt=""
							aria-hidden="true"
							loading="lazy"
							decoding="async"
						/>
						<span>Trofei</span>
					</a>
					<a class="desk-recap-card" href={rankingHref}>
						<img
							class="desk-recap-card__icon"
							src={classificaIcon.src}
							width={classificaIcon.width}
							height={classificaIcon.height}
							alt=""
							aria-hidden="true"
							loading="lazy"
							decoding="async"
						/>
						<span>Classifica Accademia</span>
					</a>
					<a class="desk-recap-card" href="/scrivania/grimorio/">
						<img
							class="desk-recap-card__icon"
							src={grimorioIcon.src}
							width={grimorioIcon.width}
							height={grimorioIcon.height}
							alt=""
							aria-hidden="true"
							loading="lazy"
							decoding="async"
						/>
						<span>Grimorio</span>
					</a>
				</div>
			</section>

			<a class="tsbs-note-pad" href={featuredNoteHref} aria-labelledby="note-title">
				<h2 id="note-title">Titolo della nota</h2>
				<p>Scrivi qui le tue annotazioni</p>
				<div class="tsbs-note-pad__lines" aria-hidden="true">
					<span></span>
					<span></span>
					<span></span>
					<span></span>
				</div>
			</a>

			<section class="desk-section desk-latest" aria-labelledby="latest-title">
				<h2 id="latest-title" class="tsbs-section-title">Le tue ultime note</h2>

				<div class="tsbs-note-list">
					{notes.map((note, index) => (
						<a
							class={`tsbs-note-card ${index >= 3 ? 'is-hidden' : ''}`}
							href={getNoteHref(note)}
							data-grimorio-card
						>
							<div class="tsbs-note-card__copy">
								<p class="tsbs-note-card__meta">
									{getNoteMeta(note)}
								</p>
								<h3>{note.titolo}</h3>
								<p>{getGrimorioExcerpt(note.contenuto)}</p>
							</div>
							<div class="tsbs-note-card__actions" aria-hidden="true">
								<i class="bi bi-chevron-right"></i>
							</div>
						</a>
					))}
				</div>

				{notes.length > 3 && (
					<button class="missions-load-more grimorio-load-more" type="button" data-grimorio-load-more aria-controls="latest-title">
						<span>Carica altro</span>
						<i class="bi bi-arrow-right" aria-hidden="true"></i>
					</button>
				)}
			</section>
		</div>
	</main>
</Layout>

<script>
	import { setAvatarLottie } from '../../scripts/avatarLottie';

	const getGrimorioBatchSize = () => {
		if (window.matchMedia('(min-width: 992px)').matches) return 5;
		if (window.matchMedia('(min-width: 768px)').matches) return 4;
		return 3;
	};

	const setupGrimorioArchive = () => {
		const cards = [...document.querySelectorAll<HTMLElement>('[data-grimorio-card]')];
		const loadMoreButton = document.querySelector<HTMLButtonElement>('[data-grimorio-load-more]');
		if (!loadMoreButton) return;

		const batchSize = getGrimorioBatchSize();
		let visibleCount = Number(loadMoreButton.dataset.visibleCount || batchSize);
		visibleCount = Math.max(batchSize, visibleCount);

		const updateCards = () => {
			cards.forEach((card, index) => {
				card.classList.toggle('is-hidden', index >= visibleCount);
			});

			loadMoreButton.hidden = visibleCount >= cards.length;
			loadMoreButton.dataset.visibleCount = String(visibleCount);
		};

		loadMoreButton.onclick = () => {
			visibleCount += batchSize;
			updateCards();
		};

		updateCards();
	};

	const loadDeskHeader = async () => {
		try {
			const res = await fetch('/api/user/profilo');
			if (!res.ok) return;
			const profilo = await res.json();

			const set = (sel: string, val: string | null) => {
				const el = document.querySelector(sel);
				if (el instanceof HTMLElement && val) el.textContent = val;
			};

			set('[data-desk-username]', profilo.username);
			set('[data-desk-livello]', profilo.livello);
			set('[data-desk-accademia]', profilo.accademia);
			set('[data-desk-codice]', profilo.tessera);

			if (profilo.avatarSrc) {
				const fallback = document.querySelector('[data-desk-avatar-fallback]');
				const canvas = document.querySelector<HTMLCanvasElement>('[data-desk-avatar-img]');
				if (fallback instanceof HTMLElement) fallback.hidden = true;
				if (canvas instanceof HTMLCanvasElement) {
					canvas.hidden = false;
					setAvatarLottie(canvas, profilo.avatarSrc);
				}
			}
		} catch {
			// Fallback silenzioso
		}
	};

	loadDeskHeader();
	setupGrimorioArchive();
	document.addEventListener('astro:page-load', () => {
		loadDeskHeader();
		setupGrimorioArchive();
	});
</script>
