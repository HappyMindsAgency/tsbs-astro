---
import Layout from '../../../../layouts/Layout.astro';
import Nav from '../../../../components/Nav.astro';
import BackButton from '../../../../components/BackButton.astro';
import RitchText from '../../../../components/RitchText.astro';
import ConfermaEliminaNota from '../../../../components/toastComponents/ConfermaEliminaNota.astro';
import { getCurrentMembroFromJwt, getGrimorioNotaBySlugForMembro } from '../../../../lib/strapi/grimorio';
import { resolveUserContext } from '../../../../lib/theme';

const { lang = 'it' } = Astro.props;
const jwt = Astro.cookies.get('jwt')?.value;
const slugNotaPub = Astro.params.slugNotaPub;

if (!jwt) {
	return Astro.redirect('/');
}

if (!slugNotaPub) {
	return Astro.redirect('/scrivania/grimorio/');
}

const membro = await getCurrentMembroFromJwt(jwt);
const nota = membro ? await getGrimorioNotaBySlugForMembro(slugNotaPub, membro.documentId, lang) : null;
const { theme, accademia } = await resolveUserContext(jwt);

if (!nota) {
	return Astro.redirect('/scrivania/grimorio/');
}
---

<Layout lang={lang} theme={theme} accademia={accademia}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell missions-shell note-page">
		<header class="missions-header missions-header--note">
			<h1>Nota</h1>
			<BackButton href="/scrivania/grimorio/" label="Torna al grimorio" />
		</header>

		<div class="container-xl tsbs-app-container note-page__content">
			<section class="note-editor note-editor--published" aria-labelledby="published-note-title" data-published-note data-note-document-id={nota.documentId}>
				<div class="note-editor__head">
					<h2 id="published-note-title" class="note-editor__title note-editor__title--static">{nota.titolo}</h2>
					<button class="note-editor__icon-button" type="button" aria-label="Elimina nota" data-published-note-delete>
						<i class="bi bi-trash" aria-hidden="true"></i>
					</button>
				</div>

				<div class="note-editor__body note-editor__body--published">
					<RitchText block={nota.contenuto} className="note-editor__richtext" />
				</div>
			</section>
		</div>
	</main>

	<ConfermaEliminaNota renderHidden />

	<script>
		const setupPublishedNoteDelete = () => {
			document.querySelectorAll<HTMLElement>('[data-published-note]').forEach((note) => {
				if (note.dataset.publishedNoteReady === 'true') return;
				note.dataset.publishedNoteReady = 'true';

				const deleteButton = note.querySelector<HTMLButtonElement>('[data-published-note-delete]');
				let isDeleting = false;

				const deleteNote = async () => {
					if (isDeleting) return;

					const noteDocumentId = note.dataset.noteDocumentId || '';
					if (!noteDocumentId) return;

					isDeleting = true;
					if (deleteButton) deleteButton.disabled = true;

					try {
						const response = await fetch('/api/grimorio/note', {
							method: 'DELETE',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({ noteDocumentId }),
						});

						if (!response.ok) {
							if (deleteButton) deleteButton.disabled = false;
							isDeleting = false;
							return;
						}

						window.location.assign('/scrivania/grimorio/');
					} catch {
						if (deleteButton) deleteButton.disabled = false;
						isDeleting = false;
					}
				};

				deleteButton?.addEventListener('click', () => {
					if (isDeleting) return;
					document.dispatchEvent(new CustomEvent('tsbs:nota-delete-open'));
				});

				document.addEventListener('tsbs:nota-delete-confirm', () => {
					void deleteNote();
				});
			});
		};

		document.addEventListener('astro:page-load', setupPublishedNoteDelete);
		setupPublishedNoteDelete();
	</script>
</Layout>
