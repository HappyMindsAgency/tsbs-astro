---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import BackButton from '../../../components/BackButton.astro';
import NotaEditor from '../../../components/GrimorioComponents/NotaEditor.astro';
import { resolveUserContext } from '../../../lib/theme';
import { getCurrentMembroFromJwt } from '../../../lib/strapi/grimorio';

const { lang = 'it' } = Astro.props;
const jwt = Astro.cookies.get('jwt')?.value;

if (!jwt) {
	return Astro.redirect('/');
}

const membro = await getCurrentMembroFromJwt(jwt);
const { theme, accademia } = await resolveUserContext(jwt);
---

<Layout lang={lang} theme={theme} accademia={accademia}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell missions-shell note-page">
		<header class="missions-header missions-header--note">
			<h1>Nuova nota</h1>
			<BackButton href="/scrivania/grimorio/" label="Torna al grimorio" />
		</header>

		<div class="container-xl tsbs-app-container note-page__content">
			<NotaEditor storageScope={membro?.documentId} />
		</div>
	</main>
</Layout>
