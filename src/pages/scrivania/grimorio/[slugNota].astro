---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import NotaModal from '../../../components/PopupComponents/NotaModal.astro';
import NotaToast from '../../../components/toastComponents/NotaToast.astro';

const { lang = 'it' } = Astro.props;

if (!Astro.cookies.has('jwt')) {
	return Astro.redirect('/');
}
---

<Layout lang={lang}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell missions-shell note-page">
		<header class="missions-header">
			<h1>Nota</h1>
		</header>

		<div class="container-xl tsbs-app-container note-page__content">
			<section class="note-editor" aria-labelledby="note-editor-title">
				<div class="note-editor__head">
					<label class="visually-hidden" for="note-title-input">Titolo della nota</label>
					<input
						id="note-title-input"
						class="note-editor__title"
						type="text"
						value="Titolo della nota"
						autocomplete="off"
						data-note-title
					/>
					<button class="note-editor__icon-button" type="button" aria-label="Elimina nota" data-note-delete>
						<i class="bi bi-trash" aria-hidden="true"></i>
					</button>
				</div>

				<div class="note-editor__toolbar" role="toolbar" aria-label="Formattazione nota">
					<div class="note-editor__button-group" aria-label="Stile testo">
						<button type="button" data-command="bold" aria-label="Grassetto">
							<i class="bi bi-type-bold" aria-hidden="true"></i>
						</button>
						<button type="button" data-command="italic" aria-label="Corsivo">
							<i class="bi bi-type-italic" aria-hidden="true"></i>
						</button>
					</div>

					<div class="note-editor__button-group" aria-label="Liste">
						<button type="button" data-command="insertUnorderedList" aria-label="Elenco puntato">
							<i class="bi bi-list-ul" aria-hidden="true"></i>
						</button>
						<button type="button" data-command="insertOrderedList" aria-label="Elenco numerato">
							<i class="bi bi-list-ol" aria-hidden="true"></i>
						</button>
					</div>
				</div>

				<div
					id="note-editor-title"
					class="note-editor__body"
					contenteditable="true"
					role="textbox"
					aria-label="Testo della nota"
					aria-multiline="true"
					data-placeholder="Scrivi qui le tue annotazioni da Adepto"
					data-note-body
				></div>

				<div class="note-editor__actions">
					<button class="btn tsbs-cta-primary-soft note-editor__button" type="button" data-note-save>Salva</button>
					<button class="btn tsbs-cta-primary note-editor__button" type="button" data-note-submit>Invia al Prefetto</button>
				</div>
			</section>
		</div>
	</main>

	<NotaModal renderHidden />
	<NotaToast renderHidden />

	<script>
		const storageKey = 'tsbs-grimorio-note-draft';
		const noteStorage = (() => {
			try {
				return window.localStorage;
			} catch {
				return null;
			}
		})();
		const titleInput = document.querySelector<HTMLInputElement>('[data-note-title]');
		const bodyEditor = document.querySelector<HTMLElement>('[data-note-body]');
		const saveButton = document.querySelector<HTMLButtonElement>('[data-note-save]');
		const submitButton = document.querySelector<HTMLButtonElement>('[data-note-submit]');
		const deleteButton = document.querySelector<HTMLButtonElement>('[data-note-delete]');
		const commandButtons = document.querySelectorAll<HTMLButtonElement>('[data-command]');

		const getDraft = () => ({
			title: titleInput?.value.trim() || '',
			body: bodyEditor?.innerHTML || '',
			updatedAt: new Date().toISOString(),
		});

		const saveDraft = (status = 'draft') => {
			const draft = { ...getDraft(), status };
			noteStorage?.setItem(storageKey, JSON.stringify(draft));
			return draft;
		};

		const updatePlaceholder = () => {
			if (!bodyEditor) return;
			bodyEditor.classList.toggle('is-empty', bodyEditor.textContent?.trim().length === 0);
		};

		const savedDraft = noteStorage?.getItem(storageKey);
		if (savedDraft) {
			try {
				const draft = JSON.parse(savedDraft);
				if (titleInput && draft.title) titleInput.value = draft.title;
				if (bodyEditor && draft.body) bodyEditor.innerHTML = draft.body;
			} catch {
				noteStorage?.removeItem(storageKey);
			}
		}

		updatePlaceholder();

		commandButtons.forEach((button) => {
			button.addEventListener('click', () => {
				const command = button.dataset.command;
				if (!command || !bodyEditor) return;

				bodyEditor.focus();
				document.execCommand(command, false);
				updatePlaceholder();
			});
		});

		bodyEditor?.addEventListener('input', updatePlaceholder);

		saveButton?.addEventListener('click', () => {
			saveDraft('draft');
		});

		submitButton?.addEventListener('click', () => {
			document.dispatchEvent(new CustomEvent('tsbs:nota-modal-open'));
		});

		document.addEventListener('tsbs:nota-submit-confirm', () => {
			saveDraft('submitted');
			document.dispatchEvent(new CustomEvent('tsbs:nota-toast-open'));
		});

		deleteButton?.addEventListener('click', () => {
			const shouldDelete = window.confirm('Eliminare questa nota?');
			if (!shouldDelete) return;

			noteStorage?.removeItem(storageKey);
			if (titleInput) titleInput.value = 'Titolo della nota';
			if (bodyEditor) bodyEditor.innerHTML = '';
			updatePlaceholder();
		});
	</script>
</Layout>
