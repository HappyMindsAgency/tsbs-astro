---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import BackButton from '../../../components/BackButton.astro';
import NotaEditor from '../../../components/GrimorioComponents/NotaEditor.astro';
import { getReturnToLabel, getSafeReturnTo, withReturnTo } from '../../../lib/navigation';
import { resolveUserContext } from '../../../lib/theme';
import { getCurrentMembroFromJwt, getGrimorioCategorySlug, getGrimorioNotaBySlugForMembro } from '../../../lib/strapi/grimorio';

const { lang = 'it' } = Astro.props;
const jwt = Astro.cookies.get('jwt')?.value;
const slugNota = Astro.params.slugNota;

if (!jwt) {
	return Astro.redirect('/');
}

if (!slugNota) {
	return Astro.redirect('/scrivania/grimorio/');
}

const membro = await getCurrentMembroFromJwt(jwt);
const nota = membro ? await getGrimorioNotaBySlugForMembro(slugNota, membro.documentId, lang) : null;

// Nota inesistente o non di proprietà del membro: torna al grimorio.
if (!nota) {
	return Astro.redirect('/scrivania/grimorio/');
}

// Le note rese pubbliche dalla redazione si visualizzano (sola lettura) nella
// pagina dedicata: qui si modificano solo le note private del membro.
if (nota.visibilePubblico) {
	return Astro.redirect(withReturnTo(`/scrivania/grimorio/pubblicate/${nota.slug}/`, Astro.url.searchParams.get('returnTo')));
}

const categorySlug = getGrimorioCategorySlug(nota);

// Solo le note salvate restano modificabili. Le inviate/in approvazione si
// aprono nella vista sola lettura anche se si raggiunge direttamente questa rotta.
if (categorySlug !== 'salvata') {
	return Astro.redirect(withReturnTo(`/scrivania/grimorio/pubblicate/${nota.slug}/`, Astro.url.searchParams.get('returnTo')));
}

const { theme, accademia } = await resolveUserContext(jwt);
const returnTo = getSafeReturnTo(Astro.url);
const backLabel = getReturnToLabel(returnTo);
---

<Layout lang={lang} theme={theme} accademia={accademia}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell missions-shell note-page">
		<header class="missions-header missions-header--note">
			<h1>Nota</h1>
			<BackButton href={returnTo} label={backLabel} />
		</header>

		<div class="container-xl tsbs-app-container note-page__content">
			<NotaEditor
				noteDocumentId={nota.documentId}
				titleValue={nota.titolo}
				bodyValue={nota.contenuto ?? ''}
				categorySlug={categorySlug}
			/>
		</div>
	</main>
</Layout>
