---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import SnakeGame from '../../components/SnakeGame.astro';
import { resolveUserTheme } from '../../lib/theme';

const { lang = 'it' } = Astro.props;
const jwt = Astro.cookies.get('jwt')?.value;
if (!jwt) {
	return Astro.redirect('/');
}
const theme = await resolveUserTheme(jwt);
---

<Layout lang={lang} theme={theme}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell segnalibro-page">
		<div class="container-xl tsbs-app-container">
			<header class="segnalibro-header">
				<p class="segnalibro-header__eyebrow">Archivio Segreto</p>
				<h1 class="segnalibro-header__title">Il Segnalibro</h1>
				<p class="segnalibro-header__sub">Un antico passatempo ritrovato tra le pagine della Società.</p>
				<a class="btn tsbs-cta-primary segnalibro-header__link" href="/scrivania/i-codici/">Vai a I Codici</a>
			</header>

			<div class="segnalibro-game-wrap">
				<SnakeGame lang={lang} />
			</div>
		</div>
	</main>
</Layout>

<style>
	.segnalibro-page {
		background-color: var(--tsbs-color-surface);
		min-height: 100vh;
	}

	.segnalibro-header {
		text-align: center;
		padding-block: 2rem 1.5rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.25rem;
	}

	.segnalibro-header__eyebrow {
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--tsbs-color-neutral-accent);
		margin: 0;
	}

	.segnalibro-header__title {
		font-family: var(--tsbs-font-heading-academy);
		font-size: clamp(1.5rem, 4vw, 2.5rem);
		font-weight: 700;
		color: var(--tsbs-color-neutral);
		margin: 0;
	}

	.segnalibro-header__sub {
		font-size: 0.9rem;
		color: var(--tsbs-color-body);
		margin: 0.25rem 0 0;
		max-width: 38ch;
		text-align: center;
	}

	.segnalibro-header__link {
		margin-top: 1rem;
	}

	.segnalibro-game-wrap {
		display: flex;
		justify-content: center;
		padding-bottom: 3rem;
	}

	/* Su mobile comprime l'header per lasciare l'altezza al gioco. */
	@media (max-width: 767px) {
		.segnalibro-header {
			padding-block: 1rem 0.5rem;
		}
		.segnalibro-header__sub {
			display: none;
		}
		.segnalibro-game-wrap {
			padding-bottom: 1.5rem;
		}
	}
</style>
