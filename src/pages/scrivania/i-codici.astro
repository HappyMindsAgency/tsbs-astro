---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import TetrisGame from '../../components/TetrisGame.astro';
import { resolveUserTheme } from '../../lib/theme';

const { lang = 'it' } = Astro.props;
const jwt = Astro.cookies.get('jwt')?.value;
if (!jwt) {
	return Astro.redirect('/');
}
const theme = await resolveUserTheme(jwt);
---

<Layout lang={lang} theme={theme}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell codici-page">
		<div class="container-xl tsbs-app-container">
			<header class="codici-header">
				<p class="codici-header__eyebrow">Archivio Segreto</p>
				<h1 class="codici-header__title">I Codici</h1>
				<p class="codici-header__sub">Antichi frammenti cifrati ritrovati tra i volumi della Società.</p>
				<a class="btn tsbs-cta-primary codici-header__link" href="/scrivania/il-segnalibro/">Vai a Il Segnalibro</a>
			</header>

			<div class="codici-game-wrap">
				<TetrisGame lang={lang} />
			</div>
		</div>
	</main>
</Layout>

<style>
	.codici-page {
		background-color: var(--tsbs-color-surface);
		min-height: 100vh;
	}

	.codici-header {
		text-align: center;
		padding-block: 2rem 1.5rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.25rem;
	}

	.codici-header__eyebrow {
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--tsbs-color-neutral-accent);
		margin: 0;
	}

	.codici-header__title {
		font-family: var(--tsbs-font-heading-academy);
		font-size: clamp(1.5rem, 4vw, 2.5rem);
		font-weight: 700;
		color: var(--tsbs-color-neutral);
		margin: 0;
	}

	.codici-header__sub {
		font-size: 0.9rem;
		color: var(--tsbs-color-body);
		margin: 0.25rem 0 0;
		max-width: 38ch;
		text-align: center;
	}

	.codici-header__link {
		margin-top: 1rem;
	}

	.codici-game-wrap {
		display: flex;
		justify-content: center;
		padding-bottom: 3rem;
	}

	/* Su mobile comprime l'header per lasciare l'altezza al gioco. */
	@media (max-width: 767px) {
		.codici-header {
			padding-block: 1rem 0.5rem;
		}
		.codici-header__sub {
			display: none;
		}
		.codici-game-wrap {
			padding-bottom: 1.5rem;
		}
	}
</style>
