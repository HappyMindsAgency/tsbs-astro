---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import { getFavoriteProfilesByJwt } from '../../../lib/strapi/preferiti';
import { resolveUserContext } from '../../../lib/theme';

const { lang = 'it' } = Astro.props;
if (!Astro.cookies.has('jwt')) {
	return Astro.redirect('/');
}

const jwt = Astro.cookies.get('jwt')?.value;
const { theme, accademia } = await resolveUserContext(jwt);
const favoriteProfiles = jwt ? await getFavoriteProfilesByJwt(jwt) : [];
---

<Layout lang={lang} theme={theme} accademia={accademia}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell academy-page academy-ranking-page profile-favorites-page">
		<header class="missions-header academy-ranking-header">
			<h1>Utenti preferiti</h1>
		</header>

		<div class="container-xl tsbs-app-container academy-ranking-page__content">
			<section class="academy-section" aria-label="Utenti preferiti">
				<p class="profile-favorites-empty" hidden={favoriteProfiles.length > 0}>
					In questa pagina, trovi tutti gli utenti preferiti. Attualmente non ci sono utenti preferiti.
				</p>

				<div class="academy-ranking-list">
					{favoriteProfiles.map((row, index) => (
						<a class={`academy-ranking-card is-academy-${row.academy}`} href={row.href}>
							<div class="academy-ranking-card__position">
								<span>{index + 1}</span>
							</div>
							<div class="academy-ranking-card__avatar" aria-hidden="true">{row.initials}</div>
							<p class="academy-ranking-card__name">{row.name}</p>
							<p class="academy-ranking-card__points">
								<strong>{row.points}</strong>
								<i class="bi bi-trophy" aria-hidden="true"></i>
							</p>
						</a>
					))}
				</div>
			</section>
		</div>
	</main>
</Layout>

<style lang="scss">
	.profile-favorites-empty {
		margin: 0;
		color: var(--tsbs-theme-body);
		font-size: 1rem;
		font-weight: 500;
		line-height: 1.4;
	}
</style>
