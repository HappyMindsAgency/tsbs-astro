---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import BackButton from '../../../components/BackButton.astro';
import AvatarLottie from '../../../components/AvatarLottie.astro';
import { getProfileDetailByJwt } from '../../../lib/strapi/preferiti';
import { getTrofeiStanzaByMembroDocumentId } from '../../../lib/strapi/trofei';
import { buildTrophyCatalog } from '../../../lib/trofei-forme';
import { resolveUserContext } from '../../../lib/theme';
import { getReturnToLabel, getSafeReturnTo } from '../../../lib/navigation';

const { lang = 'it' } = Astro.props;
if (!Astro.cookies.has('jwt')) {
	return Astro.redirect('/');
}

const jwt = Astro.cookies.get('jwt')?.value;
const currentProfile = jwt ? await getProfileDetailByJwt(jwt, Astro.url.searchParams.get('membro')) : null;

if (!currentProfile) {
	return Astro.redirect('/scrivania/utenti-preferiti/');
}

// Griglia identica a quella di modifica (Stanza Trofei) per rispettare le posizioni salvate.
const board = {
	rows: 6,
	cols: 5,
};

// Trofei conquistati dall'utente visualizzato + la sua disposizione salvata (sola lettura).
const { trofei: trofeiUtente, layout: layoutUtente } = await getTrofeiStanzaByMembroDocumentId(currentProfile.id);
const trophyCatalog = buildTrophyCatalog(trofeiUtente);

// Solo i trofei effettivamente posizionati dall'utente, con forma/dimensione dal catalogo.
const placedTrophies = layoutUtente.flatMap((item) => {
	const definition = trophyCatalog.find((trophy) => trophy.id === item.id);
	if (!definition) return [];
	return [{ ...definition, row: item.row, col: item.col }];
});

const cells = Array.from({ length: board.rows * board.cols });

const { theme, accademia } = await resolveUserContext(jwt);
const profileAcademies = ['astraria', 'arcadia', 'armonia', 'arborea'];
const profileAcademy = profileAcademies.includes(currentProfile.academy) ? currentProfile.academy : accademia;
const returnTo = getSafeReturnTo(Astro.url, '/scrivania/utenti-preferiti/');
const returnToLabel = getReturnToLabel(returnTo, 'Torna agli utenti preferiti');
---

<Layout lang={lang} theme={theme} accademia={accademia}>
	<Nav lang={lang} />

	<main class={`tsbs-app-shell desk-page profile-exploded-page theme-${profileAcademy}`} data-profile-academy={profileAcademy}>
		<header class="desk-hero profile-exploded-hero" aria-labelledby="profile-exploded-title">
			<div class="desk-hero__panel profile-exploded-hero__panel">
				<BackButton href={returnTo} label={returnToLabel} class="profile-exploded-back" />

				<button
					class={`profile-favorite-button${currentProfile.isFavorite ? ' is-favorite' : ''}`}
					type="button"
					aria-label={currentProfile.isFavorite ? 'Rimuovi dai preferiti' : 'Aggiungi ai preferiti'}
					aria-pressed={String(currentProfile.isFavorite)}
					data-profile-favorite-toggle
					data-profile-id={currentProfile.id}
				>
					<i class={`bi ${currentProfile.isFavorite ? 'bi-heart-fill' : 'bi-heart'}`} aria-hidden="true"></i>
				</button>

				<p class="desk-academy-pill">{currentProfile.academyLabel}</p>

				<div class="desk-avatar" aria-hidden="true">
					{currentProfile.avatarSrc
						? <AvatarLottie class="desk-avatar__img" src={currentProfile.avatarSrc} />
						: <i class="bi bi-image"></i>}
				</div>

				<h1 id="profile-exploded-title">{currentProfile.name}</h1>
				<p class="desk-rank">{currentProfile.rankLabel}</p>
			</div>
		</header>

		<div class="container-xl tsbs-app-container profile-exploded-content">
			<section
				class="profile-trophy-board"
				aria-label="Trofei impostati dall'utente"
				style={`--profile-trophy-rows: ${board.rows}; --profile-trophy-cols: ${board.cols};`}
			>
				<div class="profile-trophy-board__grid" aria-hidden="true">
					{cells.map(() => <span></span>)}
				</div>

				<div class="profile-trophy-board__pieces">
					{placedTrophies.map((trophy) => (
						<article
							class="profile-trophy-piece"
							aria-label={`Trofeo ${trophy.label}`}
							style={`--piece-row: ${trophy.row + 1}; --piece-col: ${trophy.col + 1}; --piece-width: ${trophy.width}; --piece-height: ${trophy.height};`}
						>
							<img src={trophy.src} alt={trophy.label} loading="lazy" draggable="false" />
						</article>
					))}
				</div>
			</section>
		</div>
	</main>
</Layout>

<script>
	import { toggleFavorite } from '../../../lib/profileFavorites.js';

	const setupProfileFavoriteToggle = () => {
		const favoriteButton = document.querySelector('[data-profile-favorite-toggle]');
		if (!favoriteButton || favoriteButton.dataset.profileFavoriteReady === 'true') return;

		const syncFavoriteButton = (favorite) => {
			const icon = favoriteButton.querySelector('.bi');

			favoriteButton.setAttribute('aria-pressed', String(favorite));
			favoriteButton.classList.toggle('is-favorite', favorite);
			favoriteButton.setAttribute('aria-label', favorite ? 'Rimuovi dai preferiti' : 'Aggiungi ai preferiti');
			icon?.classList.toggle('bi-heart', !favorite);
			icon?.classList.toggle('bi-heart-fill', favorite);
		};

		favoriteButton.dataset.profileFavoriteReady = 'true';
		favoriteButton.addEventListener('click', async () => {
			const profileId = favoriteButton.dataset.profileId;
			if (!profileId || favoriteButton.disabled) return;

			favoriteButton.disabled = true;

			try {
				const favorites = await toggleFavorite(profileId);
				syncFavoriteButton(favorites.includes(profileId));
			} catch {
				syncFavoriteButton(favoriteButton.getAttribute('aria-pressed') === 'true');
			} finally {
				favoriteButton.disabled = false;
			}
		});

		syncFavoriteButton(favoriteButton.getAttribute('aria-pressed') === 'true');
	};

	document.addEventListener('astro:page-load', setupProfileFavoriteToggle);
</script>

<style lang="scss">
	.profile-exploded-page {
		--profile-board-max-width: 23.125rem;
		--profile-hero-space: 20.75rem;
		--profile-content-top: 2rem;
		--profile-content-bottom: 1rem;
		--profile-board-height-space: calc(
			100dvh - var(--profile-hero-space) - var(--profile-content-top) - var(--profile-content-bottom) -
				var(--tsbs-mobile-nav-height)
		);
		--profile-board-size: min(100%, var(--profile-board-max-width), calc(var(--profile-board-height-space) * 5 / 6));

		min-height: 100vh;
		padding-bottom: var(--tsbs-mobile-nav-height);
	}

	.profile-exploded-hero {
		position: relative;
		padding-bottom: 2rem;
	}

	.profile-exploded-hero .desk-avatar {
		overflow: hidden;
		color: #ffffff;
		background: color-mix(in srgb, var(--desk-accent) 58%, #ffffff);
	}

	:global(.profile-exploded-back.tsbs-back-button) {
		position: absolute;
		top: 0.625rem;
		left: 0.625rem;
		z-index: 2;
		color: #ffffff;
		background: color-mix(in srgb, var(--desk-accent) 74%, #ffffff);
		border-color: #ffffff;
	}

	:global(.profile-exploded-back.tsbs-back-button:hover),
	:global(.profile-exploded-back.tsbs-back-button:focus) {
		color: var(--desk-accent);
		background: #ffffff;
		border-color: #ffffff;
	}

	.desk-avatar__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 50%;
	}

	.profile-favorite-button {
		position: absolute;
		z-index: 2;
		top: 0.625rem;
		right: 0.625rem;
		display: grid;
		place-items: center;
		width: 2.75rem;
		height: 2.75rem;
		padding: 0;
		color: var(--desk-accent);
		background: #ffffff;
		border: 0;
		border-radius: 50%;
		cursor: pointer;
	}

	.profile-favorite-button .bi {
		font-size: 1.25rem;
		line-height: 1;
	}

	.profile-favorite-button.is-favorite {
		color: var(--desk-accent);
	}

	.profile-exploded-content {
		display: grid;
		align-items: start;
		justify-items: center;
		min-height: 0;
		padding-top: var(--profile-content-top);
		padding-bottom: var(--profile-content-bottom);
	}

	.profile-trophy-board {
		--profile-trophy-gap: 0.375rem;

		position: relative;
		display: grid;
		width: min(100%, var(--profile-board-max-width), var(--profile-board-size));
		aspect-ratio: var(--profile-trophy-cols) / var(--profile-trophy-rows);
		gap: var(--profile-trophy-gap);
	}

	.profile-trophy-board,
	.profile-trophy-board__grid,
	.profile-trophy-board__pieces {
		grid-template-columns: repeat(var(--profile-trophy-cols), minmax(0, 1fr));
		grid-template-rows: repeat(var(--profile-trophy-rows), minmax(0, 1fr));
	}

	.profile-trophy-board__grid,
	.profile-trophy-board__pieces {
		position: absolute;
		inset: 0;
		display: grid;
		gap: var(--profile-trophy-gap);
		padding: 0.375rem;
	}

	.profile-trophy-board__grid {
		background-image: url('../../../assets/bg-grigla-trofei.png');
		background-size: 100% 100%;
		background-repeat: no-repeat;
	}

	.profile-trophy-board__grid span {
		min-width: 0;
		min-height: 0;
	}

	.profile-trophy-board__pieces {
		pointer-events: none;
	}

	.profile-trophy-piece {
		position: relative;
		z-index: 1;
		grid-row: var(--piece-row) / span var(--piece-height);
		grid-column: var(--piece-col) / span var(--piece-width);
		display: grid;
		place-items: center;
		width: 100%;
		height: 100%;
		margin: 0;
	}

	.profile-trophy-piece img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: contain;
		user-select: none;
		-webkit-user-drag: none;
	}

	.profile-favorite-button:focus-visible {
		outline: 3px solid color-mix(in srgb, var(--desk-accent) 50%, #ffffff);
		outline-offset: 3px;
	}

	@media (min-width: 768px) {
		.profile-exploded-page {
			--profile-board-max-width: 27rem;
			--profile-hero-space: 20.75rem;
		}
	}

	@media (min-width: 992px) {
		.profile-exploded-page {
			--profile-board-max-width: 44rem;
			--profile-hero-space: 0rem;
			--profile-content-top: 2rem;
			--profile-content-bottom: 2rem;
			--profile-sidebar-width: clamp(20rem, 28vw, 30rem);
			--profile-board-height-space: calc(100dvh - var(--profile-content-top) - var(--profile-content-bottom));

			display: grid;
			grid-template-columns: var(--profile-sidebar-width) minmax(0, 1fr);
			align-items: stretch;
			padding-bottom: 0;
		}

		.profile-exploded-hero {
			display: grid;
			align-items: center;
			min-height: 100vh;
			padding: 3rem 2rem;
			background: var(--desk-accent);
		}

		.profile-exploded-hero__panel {
			position: static;
			width: 100%;
			min-height: 0;
		}

		.profile-favorite-button {
			top: 1.25rem;
			right: 1.25rem;
		}

		:global(.profile-exploded-back.tsbs-back-button) {
			top: 1.25rem;
			left: 1.25rem;
		}

		:global(.profile-exploded-back.tsbs-back-button:hover),
		:global(.profile-exploded-back.tsbs-back-button:focus) {
			color: var(--desk-accent);
			background: #ffffff;
			border-color: #ffffff;
		}

		.profile-exploded-content {
			width: 100%;
			min-height: 100vh;
			padding-top: var(--profile-content-top);
			padding-bottom: 2rem;
		}
	}
</style>
