---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import RitchText from '../../components/RitchText.astro';
import { formatEventoDate, getEventoSocietyBySlug } from '../../lib/strapi/eventi';

export const prerender = false;

const { lang = 'it' } = Astro.props;
const { slugEv = '' } = Astro.params;

if (!Astro.cookies.has('jwt')) {
	return Astro.redirect('/');
}

const societyEvent = await getEventoSocietyBySlug(slugEv, lang);
---

<Layout lang={lang}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell missions-shell event-detail-page">
		<header class="missions-header event-detail-header">
			<h1>Eventi</h1>
		</header>

		<article class="container-xl tsbs-app-container event-detail" aria-labelledby="event-detail-title">
			<div class="event-detail__hero">
				<p class="event-detail__date">{societyEvent ? formatEventoDate(societyEvent.dataEvento) : '04 Feb - 21 Mar 2026'}</p>

				<div class="event-detail__heading">
					<h2 id="event-detail-title">{societyEvent?.titolo ?? "Titolo dell'evento placeholder per ingombro"}</h2>
					<p class="event-detail__category">{societyEvent?.tipoEvento ?? 'Categoria evento'}</p>
					<p>{societyEvent?.luogo ?? 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Pellentesque sit amet quam felis.'}</p>
				</div>
			</div>

			{societyEvent?.descrizione && (
				<RitchText block={societyEvent.descrizione} className="event-detail__intro event-detail__richtext" />
			)}

			{societyEvent?.missione?.descrizione && (
				<section class="event-detail__mission">
					<i class="bi bi-award" aria-hidden="true"></i>
					<div>
						<RitchText block={societyEvent.missione.descrizione} className="event-detail__mission-description" />
					</div>
				</section>
			)}
		</article>
	</main>
</Layout>
