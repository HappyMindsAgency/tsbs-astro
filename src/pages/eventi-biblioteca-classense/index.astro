---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { formatEventoDate, getEventiSociety, getEventoSocietyHref } from '../../lib/strapi/eventi';
import { getEventiClassense } from '../../lib/classense';
import { resolveUserContext } from '../../lib/theme';

const { lang = 'it' } = Astro.props;

const eventTabs = [
	{ id: 'society', label: 'Society' },
	{ id: 'biblioteca', label: 'Biblioteca' },
];

if (!Astro.cookies.has('jwt')) {
	return Astro.redirect('/');
}

const { theme, accademia } = await resolveUserContext(Astro.cookies.get('jwt')?.value);

const [societyEvents, bibliotecaEvents] = await Promise.all([
	getEventiSociety(lang),
	getEventiClassense(6),
]);
const visibleEventsBeforeLoadMore = 3;
---

<Layout lang={lang} theme={theme} accademia={accademia}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell events-page">
		<header class="missions-header events-header">
			<h1>Eventi</h1>
		</header>

		<section class="container-xl tsbs-app-container events-content" aria-labelledby="events-title">
			<ul class="nav missions-tabs events-tabs" id="events-tabs" role="tablist" aria-label="Tipologia eventi">
				{eventTabs.map((tab, index) => (
					<li class="nav-item missions-tabs__item" role="presentation">
						<button
							class={`nav-link missions-tabs__button ${index === 0 ? 'active' : ''}`}
							id={`${tab.id}-tab`}
							data-bs-toggle="tab"
							data-bs-target={`#${tab.id}`}
							type="button"
							role="tab"
							aria-controls={tab.id}
							aria-selected={index === 0 ? 'true' : 'false'}
						>
							{tab.label}
						</button>
					</li>
				))}
			</ul>

			<div class="tab-content events-tab-content" id="events-tabs-content">
				{eventTabs.map((tab, tabIndex) => (
					<div
						class={`tab-pane fade ${tabIndex === 0 ? 'show active' : ''}`}
						id={tab.id}
						role="tabpanel"
						aria-labelledby={`${tab.id}-tab`}
						tabindex="0"
					>
						<h2 id={tabIndex === 0 ? 'events-title' : undefined} class="tsbs-section-title events-section-title">Eventi</h2>

						{tab.id === 'society' ? (
							societyEvents.length > 0 ? (
								<div class="events-grid">
									{societyEvents.map((event, index) => (
										<a
											class={`events-card ${index > 8 ? 'is-hidden-desktop' : ''} ${index > 2 ? 'is-hidden-mobile' : ''}`}
											href={getEventoSocietyHref(event)}
											data-event-card
										>
											<div class="events-card__media">
												{formatEventoDate(event.dataEvento) && <span class="events-card__date">{formatEventoDate(event.dataEvento)}</span>}
												{event.coverUrl ? (
													<img class="events-card__cover" src={event.coverUrl} alt={event.coverAlt ?? event.titolo} loading="lazy" />
												) : (
													<i class="bi bi-image" aria-hidden="true"></i>
												)}
											</div>
											<h3>{event.titolo}</h3>
										</a>
									))}
								</div>
							) : (
								<p class="events-empty">Nessun evento Society pubblicato.</p>
							)
						) : (
							<div class="events-grid">
								{bibliotecaEvents.map((event, index) => (
									<a
										class={`events-card ${index > 8 ? 'is-hidden-desktop' : ''} ${index > 2 ? 'is-hidden-mobile' : ''}`}
										href={event.link}
											target="_blank"
											rel="noopener noreferrer"
										data-event-card
									>
										<div class="events-card__media">
											<img class="events-card__cover" src={event.immagine} alt={event.titolo} loading="lazy" />
										</div>
										<h3>{event.titolo}</h3>
									</a>
								))}
							</div>
						)}

						{((tab.id === 'society' ? societyEvents.length : bibliotecaEvents.length) > visibleEventsBeforeLoadMore) && (
							<button class="missions-load-more events-load-more" type="button" data-events-load-more aria-controls={tab.id}>
								<span>Carica altro</span>
								<i class="bi bi-arrow-right" aria-hidden="true"></i>
							</button>
						)}
					</div>
				))}
			</div>
		</section>
	</main>

	<script>
		const syncEventPane = (pane: Element) => {
			const button = pane.querySelector<HTMLButtonElement>('[data-events-load-more]');
			const hiddenCards = pane.querySelectorAll<HTMLElement>('[data-event-card].is-hidden-mobile, [data-event-card].is-hidden-desktop');

			if (!button) return;

			button.hidden = hiddenCards.length === 0;
		};

		document.querySelectorAll('.events-tab-content .tab-pane').forEach(syncEventPane);

		document.querySelectorAll('[data-bs-toggle="tab"]').forEach((tabButton) => {
			tabButton.addEventListener('shown.bs.tab', (event) => {
				const target = event.target instanceof HTMLElement ? event.target.dataset.bsTarget : '';
				if (!target) return;

				const pane = document.querySelector(target);
				if (pane) syncEventPane(pane);
			});
		});

		document.querySelectorAll<HTMLButtonElement>('[data-events-load-more]').forEach((button) => {
			button.addEventListener('click', () => {
				const pane = button.closest('.tab-pane');
				if (!pane) return;

				pane.querySelectorAll<HTMLElement>('[data-event-card]').forEach((card) => {
					card.classList.remove('is-hidden-mobile', 'is-hidden-desktop');
				});

				button.hidden = true;
			});
		});
	</script>
</Layout>
