---
import Layout from '../../../layouts/Layout.astro';
import onboardingVector from '../../../assets/onboarding-vector.png';

const { lang = 'it' } = Astro.props;

const academySlides = [
	{
		id: 'astraria',
		title: 'Astraria',
	},
	{
		id: 'arcadia',
		title: 'Arcadia',
	},
	{
		id: 'armonia',
		title: 'Armonia',
	},
	{
		id: 'arborea',
		title: 'Arborea',
	},
];
---

<Layout lang={lang} theme="theme-neutral">
	<main class="onboarding-page" data-onboarding-page>
		<div class="onboarding-stage">
			<section class="onboarding-video" aria-label="Video introduttivo">
				<div class="onboarding-video__frame">
					<button class="onboarding-video__play" type="button" aria-label="Riproduci video introduttivo">
						<i class="bi bi-play-fill" aria-hidden="true"></i>
					</button>
				</div>

				<a class="onboarding-video__scroll" href="#onboarding-signup" aria-label="Vai alla sezione iscrizione">
					<i class="bi bi-arrow-down" aria-hidden="true"></i>
				</a>
			</section>

			<section class="onboarding-disclaimer" id="onboarding-disclaimer" aria-labelledby="onboarding-disclaimer-title">
				<div class="onboarding-card-icon" aria-hidden="true">
					<i class="bi bi-image"></i>
				</div>
				<h1 id="onboarding-disclaimer-title">Disclaimer</h1>
				<p>
					Lorem ipsum dolor sit amet, consectetur adipiscing elit. Morbi at est et tortor laoreet placerat id in neque. Maecenas vel erat lacinia.
				</p>
			</section>

			<section class="onboarding-academies" aria-labelledby="onboarding-academies-title">
				<div class="onboarding-academies__header">
					<h2 id="onboarding-academies-title">Le accademie</h2>
				</div>

				<div class="academy-slider" data-academy-slider>
					<button class="academy-slider__nav academy-slider__nav--prev" type="button" aria-label="Accademia precedente" data-slider-prev>
						<i class="bi bi-arrow-left-circle" aria-hidden="true"></i>
					</button>

					<div class="academy-slider__track" data-slider-track tabindex="0" aria-label="Slider delle accademie">
						{
							academySlides.map((slide, index) => (
								<article class={`academy-slide academy-slide--${slide.id}`} aria-label={`${slide.title} di ${academySlides.length}`}>
									<div class="academy-slide__visual" aria-hidden="true">
										<img
											src={onboardingVector.src}
											width={onboardingVector.width}
											height={onboardingVector.height}
											alt=""
											loading={index === 0 ? 'eager' : 'lazy'}
										/>
									</div>

									<div class="academy-slide__panel">
										<div class="academy-slide__dots" aria-hidden="true">
											{academySlides.map((_, dotIndex) => (
												<span class={dotIndex === index ? 'is-active' : ''} />
											))}
										</div>
										<h3>{slide.title}</h3>
										<p>
											Lorem ipsum dolor sit amet, consectetur adipiscing elit. Morbi at est et tortor laoreet placerat id in neque. Maecenas vel erat lacinia.
										</p>
									</div>
								</article>
							))
						}
					</div>

					<button class="academy-slider__nav academy-slider__nav--next" type="button" aria-label="Accademia successiva" data-slider-next>
						<i class="bi bi-arrow-right-circle" aria-hidden="true"></i>
					</button>
				</div>
			</section>

			<section class="onboarding-signup" id="onboarding-signup" aria-labelledby="onboarding-signup-title">
				<div class="onboarding-signup__icon" aria-hidden="true">
					<i class="bi bi-image"></i>
				</div>
				<h2 id="onboarding-signup-title">Call to action iscrizione</h2>
				<p>
					Lorem ipsum dolor sit amet, consectetur adipiscing elit. Morbi at est et tortor laoreet placerat id in neque.
				</p>
				<a class="onboarding-signup__button" href="/registrazione/">Iscriviti</a>
			</section>
		</div>
	</main>
</Layout>

<script>
	const initOnboardingSlider = () => {
		document.querySelectorAll('[data-academy-slider]').forEach((slider) => {
			if (!(slider instanceof HTMLElement) || slider.dataset.sliderBound === 'true') {
				return;
			}

			const track = slider.querySelector('[data-slider-track]');
			const prev = slider.querySelector('[data-slider-prev]');
			const next = slider.querySelector('[data-slider-next]');

			if (!(track instanceof HTMLElement) || !(prev instanceof HTMLButtonElement) || !(next instanceof HTMLButtonElement)) {
				return;
			}

			slider.dataset.sliderBound = 'true';

			const getSlides = () => Array.from(track.querySelectorAll<HTMLElement>('.academy-slide'));

			const getSlideScrollLeft = (slide: HTMLElement) => {
				return Math.max(0, slide.offsetLeft - track.offsetLeft);
			};

			const getMaxScrollableIndex = () => {
				const slides = getSlides();
				const maxScrollLeft = Math.max(0, track.scrollWidth - track.clientWidth);
				const lastScrollableIndex = slides.findLastIndex((slide) => getSlideScrollLeft(slide) <= maxScrollLeft + 1);

				return Math.max(0, lastScrollableIndex);
			};

			const getCurrentIndex = () => {
				const slides = getSlides();

				return slides.reduce((nearestIndex, slide, index) => {
					const nearestSlide = slides[nearestIndex];
					const slideLeft = getSlideScrollLeft(slide);
					const nearestLeft = getSlideScrollLeft(nearestSlide);

					return Math.abs(slideLeft - track.scrollLeft) < Math.abs(nearestLeft - track.scrollLeft)
						? index
					: nearestIndex;
				}, 0);
			};

			track.dataset.currentSlide = String(getCurrentIndex());

			const scrollBySlide = (direction: number) => {
				const slides = getSlides();
				if (slides.length === 0) {
					return;
				}

				const maxScrollableIndex = getMaxScrollableIndex();
				const storedIndex = Number.parseInt(track.dataset.currentSlide ?? '', 10);
				const currentIndex = Math.min(Number.isNaN(storedIndex) ? getCurrentIndex() : storedIndex, maxScrollableIndex);
				const targetIndex = Math.min(Math.max(currentIndex + direction, 0), maxScrollableIndex);
				track.dataset.currentSlide = String(targetIndex);

				track.scrollTo({
					left: getSlideScrollLeft(slides[targetIndex]),
					behavior: 'smooth',
				});
			};

			let scrollTimeout: number | undefined;
			track.addEventListener(
				'scroll',
				() => {
					window.clearTimeout(scrollTimeout);
					scrollTimeout = window.setTimeout(() => {
						track.dataset.currentSlide = String(getCurrentIndex());
					}, 120);
				},
				{ passive: true },
			);

			prev.addEventListener('click', () => scrollBySlide(-1));
			next.addEventListener('click', () => scrollBySlide(1));
		});
	};

	initOnboardingSlider();
	document.addEventListener('astro:page-load', initOnboardingSlider);
</script>

<style lang="scss">
	.onboarding-page {
		--onboarding-accent: var(--tsbs-color-neutral);
		--onboarding-muted: var(--tsbs-color-body);
		--onboarding-line: color-mix(in srgb, var(--tsbs-color-neutral) 18%, var(--tsbs-color-white));
		--onboarding-soft: var(--tsbs-color-neutral-soft);
		--onboarding-panel: #ffffff;
		--onboarding-shadow: 0 1.125rem 3rem color-mix(in srgb, var(--tsbs-color-neutral) 12%, transparent);

		min-height: 100vh;
		color: var(--onboarding-muted);
		background: var(--tsbs-color-surface);
	}

	.onboarding-stage {
		display: grid;
		gap: clamp(2.375rem, 9vw, 4.5rem);
		width: min(100%, 75rem);
		margin: 0 auto;
		padding: clamp(3.0625rem, 9vw, 5rem) clamp(0.9375rem, 4vw, 2rem) calc(2.75rem + env(safe-area-inset-bottom));
	}

	.onboarding-video {
		display: grid;
		gap: 1.75rem;
		justify-items: center;
	}

	.onboarding-video__frame {
		position: relative;
		display: grid;
		place-items: center;
		width: 100%;
		min-height: clamp(32rem, 158vw, 45rem);
		overflow: hidden;
		background: color-mix(in srgb, var(--tsbs-color-white) 86%, #ffffff);
		border: 1px solid var(--onboarding-line);
		border-radius: 0.5rem;
	}

	.onboarding-video__frame::before,
	.onboarding-video__frame::after {
		position: absolute;
		inset: -10%;
		content: "";
		border-top: 1px solid color-mix(in srgb, var(--onboarding-accent) 10%, transparent);
		transform-origin: center;
	}

	.onboarding-video__frame::before {
		transform: rotate(63deg);
	}

	.onboarding-video__frame::after {
		transform: rotate(-63deg);
	}

	.onboarding-video__play {
		position: relative;
		z-index: 1;
		display: grid;
		place-items: center;
		width: 4rem;
		aspect-ratio: 1;
		padding: 0;
		color: var(--tsbs-color-white);
		background: color-mix(in srgb, var(--onboarding-accent) 70%, var(--tsbs-color-body));
		border: 0;
		border-radius: 50%;
	}

	.onboarding-video__play .bi {
		margin-left: 0.1875rem;
		font-size: 2.25rem;
		line-height: 1;
	}

	.onboarding-video__scroll {
		display: grid;
		place-items: center;
		width: 2.75rem;
		aspect-ratio: 1;
		color: color-mix(in srgb, var(--onboarding-accent) 78%, var(--tsbs-color-body));
		text-decoration: none;
		border-radius: 50%;
	}

	.onboarding-video__scroll .bi {
		font-size: 1.875rem;
		line-height: 1;
	}

	.onboarding-disclaimer,
	.onboarding-signup {
		display: grid;
		justify-items: center;
		width: min(100%, 21.5rem);
		margin: 0 auto;
		text-align: center;
	}

	.onboarding-disclaimer {
		gap: 0.875rem;
		padding: clamp(3.75rem, 16vw, 5.25rem) 1.5rem 2rem;
		background: var(--onboarding-soft);
		border-radius: var(--tsbs-radius-sm);
	}

	.onboarding-card-icon,
	.onboarding-signup__icon {
		display: grid;
		place-items: center;
		color: var(--tsbs-color-white);
		background: color-mix(in srgb, var(--onboarding-accent) 66%, var(--tsbs-color-body));
		border-radius: 50%;
	}

	.onboarding-card-icon {
		width: 4.75rem;
		aspect-ratio: 1;
		margin-bottom: 0.625rem;
	}

	.onboarding-card-icon .bi {
		font-size: 2rem;
		line-height: 1;
	}

	.onboarding-disclaimer h1,
	.onboarding-signup h2,
	.academy-slide__panel h3 {
		margin: 0;
		color: var(--tsbs-color-heading);
		font-family: var(--tsbs-font-body);
		font-weight: 700;
		letter-spacing: 0;
	}

	.onboarding-disclaimer h1 {
		font-size: 1rem;
		line-height: 1.2;
	}

	.onboarding-disclaimer p,
	.onboarding-signup p,
	.academy-slide__panel p {
		color: var(--onboarding-muted);
		font-size: 0.875rem;
		line-height: 1.22;
	}

	.onboarding-academies {
		display: grid;
		gap: 1rem;
		min-width: 0;
	}

	.onboarding-academies__header {
		padding: 0 clamp(1rem, 5vw, 1.5rem);
	}

	.onboarding-academies h2 {
		margin: 0;
		color: color-mix(in srgb, var(--onboarding-accent) 70%, #546176);
		font-size: clamp(1.75rem, 8vw, 2.5rem);
		font-weight: 700;
		line-height: 1.1;
	}

	.academy-slider {
		position: relative;
		min-width: 0;
	}

	.academy-slider__track {
		display: flex;
		gap: 1rem;
		width: 100%;
		max-width: 100%;
		overflow-x: auto;
		overscroll-behavior-x: contain;
		scroll-behavior: smooth;
		scroll-snap-type: x mandatory;
		scrollbar-width: none;
	}

	.academy-slider__track::-webkit-scrollbar {
		display: none;
	}

	.academy-slide {
		--academy-slide-accent: var(--tsbs-color-neutral);

		position: relative;
		display: grid;
		flex: 0 0 100%;
		min-height: 35.875rem;
		overflow: hidden;
		background: var(--onboarding-soft);
		border-radius: 1.25rem;
		scroll-snap-align: start;
	}

	.academy-slide--astraria {
		--academy-slide-accent: var(--tsbs-color-astraria);
	}

	.academy-slide--arcadia {
		--academy-slide-accent: var(--tsbs-color-arcadia);
	}

	.academy-slide--armonia {
		--academy-slide-accent: var(--tsbs-color-armonia);
	}

	.academy-slide--arborea {
		--academy-slide-accent: var(--tsbs-color-arborea);
	}

	.academy-slide__visual {
		position: relative;
		min-height: 30rem;
		overflow: hidden;
		background: var(--onboarding-soft);
		border-radius: inherit;
	}

	.academy-slide__visual img {
		position: absolute;
		right: clamp(1.25rem, 9vw, 3.25rem);
		bottom: clamp(8rem, 28vw, 9.5rem);
		z-index: 3;
		width: min(30vw, 6.25rem);
		height: auto;
		filter: saturate(0) brightness(0.65);
	}

	.academy-slide__panel {
		position: absolute;
		right: 0;
		bottom: 0;
		left: 0;
		z-index: 2;
		display: grid;
		gap: 0.8125rem;
		min-height: 12rem;
		padding: 2rem 1.5rem 1.875rem;
		background: var(--onboarding-panel);
		border-radius: 1.25rem 1.25rem 0 0;
		box-shadow: var(--onboarding-shadow);
	}

	.academy-slide__dots {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		min-height: 0.5rem;
	}

	.academy-slide__dots span {
		width: 0.375rem;
		aspect-ratio: 1;
		background: color-mix(in srgb, var(--academy-slide-accent) 16%, var(--tsbs-color-white));
		border-radius: 50%;
	}

	.academy-slide__dots .is-active {
		background: color-mix(in srgb, var(--academy-slide-accent) 72%, var(--tsbs-color-body));
	}

	.academy-slide__panel h3 {
		color: var(--academy-slide-accent);
		font-family: var(--tsbs-font-heading-academy);
		font-size: clamp(1.375rem, 6vw, 1.875rem);
		font-weight: 700;
		line-height: 1.08;
	}

	.academy-slider__nav {
		position: absolute;
		top: 41%;
		z-index: 2;
		display: grid;
		place-items: center;
		width: 2.25rem;
		aspect-ratio: 1;
		padding: 0;
		color: color-mix(in srgb, var(--onboarding-accent) 70%, #546176);
		background: transparent;
		border: 0;
		border-radius: 50%;
		transform: translateY(-50%);
	}

	.academy-slider__nav .bi {
		font-size: 1.75rem;
		line-height: 1;
	}

	.academy-slider__nav--prev {
		left: 0.25rem;
	}

	.academy-slider__nav--next {
		right: 0.25rem;
	}

	.onboarding-signup {
		gap: 0.75rem;
		padding: 2.125rem 2rem 2rem;
		background: var(--onboarding-panel);
		border: 1px solid var(--onboarding-line);
		border-radius: var(--tsbs-radius-sm);
	}

	.onboarding-signup__icon {
		width: 2rem;
		aspect-ratio: 1;
		color: color-mix(in srgb, var(--onboarding-accent) 42%, var(--tsbs-color-white));
		background: transparent;
		border: 1px dashed color-mix(in srgb, var(--onboarding-accent) 18%, transparent);
		border-radius: var(--tsbs-radius-sm);
	}

	.onboarding-signup h2 {
		margin-top: 0.25rem;
		color: color-mix(in srgb, var(--onboarding-accent) 72%, #546176);
		font-size: clamp(1.375rem, 6vw, 1.75rem);
		line-height: 1.1;
	}

	.onboarding-signup__button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		min-height: 3rem;
		margin-top: 0.5rem;
		padding: 0.75rem 1rem;
		color: var(--tsbs-color-white);
		font-family: var(--tsbs-font-body);
		font-weight: 700;
		line-height: 1.2;
		text-decoration: none;
		background: var(--tsbs-global-cta-var1-bg);
		border-radius: var(--tsbs-radius-sm);
	}

	.onboarding-signup__button:hover,
	.onboarding-signup__button:focus-visible {
		color: var(--tsbs-color-white);
		background: var(--tsbs-global-cta-var1-hover-bg);
	}

	.onboarding-signup__button:active {
		background: var(--tsbs-global-cta-var1-active-bg);
	}

	@media (max-width: 374.98px) {
		.onboarding-stage {
			padding-right: 0.9375rem;
			padding-left: 0.9375rem;
		}

		.onboarding-academies__header,
		.academy-slide__panel {
			padding-right: 1rem;
			padding-left: 1rem;
		}
	}

	@media (min-width: 768px) {
		.onboarding-stage {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			align-items: start;
			padding-top: clamp(2rem, 4vw, 4rem);
			padding-bottom: clamp(3rem, 5vw, 5rem);
		}

		.onboarding-video {
			grid-column: 1 / -1;
			gap: 1.25rem;
		}

		.onboarding-video__frame {
			min-height: auto;
			aspect-ratio: 16 / 9;
		}

		.onboarding-disclaimer,
		.onboarding-signup {
			width: 100%;
			height: 100%;
			align-content: center;
		}

		.onboarding-disclaimer {
			min-height: clamp(20rem, 28vw, 24rem);
			padding: clamp(4.5rem, 8vw, 6.5rem) clamp(2rem, 8vw, 7rem);
		}

		.onboarding-signup {
			min-height: clamp(16.25rem, 22vw, 17.75rem);
		}

		.onboarding-academies {
			grid-column: 1 / -1;
			grid-row: 3;
			gap: 2rem;
			margin-top: 2rem;
		}

		.onboarding-academies__header {
			padding: 0;
		}

		.academy-slider__track {
			gap: 1.5rem;
			padding-top: 2rem;
		}

		.academy-slide {
			flex-basis: max(20rem, calc((100% - 1.5rem) / 2));
			min-height: 31rem;
		}

		.academy-slide__visual {
			min-height: 26rem;
		}

		.academy-slide__visual img {
			bottom: clamp(14rem, 16vw, 16rem);
			width: min(6vw, 5rem);
		}

		.academy-slide__panel {
			right: 1.5rem;
			bottom: 1.5rem;
			left: 1.5rem;
			width: auto;
			min-height: 11rem;
			border-radius: 1.25rem;
		}

		.academy-slider__nav--prev {
			left: -0.875rem;
		}

		.academy-slider__nav--next {
			right: -0.875rem;
		}

		.onboarding-disclaimer {
			grid-column: 1 / -1;
			grid-row: 2;
		}

		.onboarding-signup {
			grid-column: 1 / -1;
			grid-row: 4;
			width: 100%;
			margin-top: 2rem;
			min-height: clamp(20rem, 28vw, 24rem);
			padding: clamp(4.5rem, 8vw, 6.5rem) clamp(2rem, 8vw, 7rem);
		}

		.onboarding-signup__button {
			width: min(100%, 28rem);
			justify-self: center;
		}
	}

	@media (min-width: 1100px) {
		.onboarding-stage {
			gap: 3rem;
		}

		.onboarding-video__frame {
			aspect-ratio: 16 / 8.5;
		}

		.onboarding-disclaimer {
			align-self: stretch;
		}

		.onboarding-signup {
			align-self: stretch;
		}

		.onboarding-academies {
			margin-top: 3.5rem;
		}

		.onboarding-signup {
			margin-top: 3.5rem;
		}

		.academy-slider__track {
			padding-top: 2.5rem;
		}

		.academy-slide {
			flex-basis: max(20rem, calc((100% - 3rem) / 3));
		}
	}
</style>
