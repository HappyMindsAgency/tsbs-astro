---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import RitchText from '../components/RitchText.astro';
import { getPolicyPage } from '../lib/strapi/policy';

const { lang = 'it' } = Astro.props;

const fallbackContent = `
Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer vitae nibh sed lorem facilisis dictum. Sed venenatis, arcu a fermentum feugiat, lorem ipsum consequat augue, vitae cursus lorem ipsum et nisl.

## Lorem ipsum

Lorem ipsum dolor sit amet, consectetur adipiscing elit. Donec non ligula vitae neque tempor laoreet. Nulla facilisi. Vestibulum ante ipsum primis in faucibus orci luctus et ultrices posuere cubilia curae.

## Lorem ipsum

Lorem ipsum dolor sit amet, consectetur adipiscing elit. Praesent dictum, sem at dignissim gravida, lectus lectus cursus tortor, in pulvinar risus lorem vitae lorem.
`.trim();

const policyPage = await getPolicyPage('cookie', lang);
const policyContent = policyPage?.content || fallbackContent;
---

<Layout lang={lang} theme="" entita="pagina-cookie-policy">
	<Nav lang={lang} />

	<main class="tsbs-app-shell tsbs-legal-page">
		<article class="container-xl tsbs-legal-page__content" aria-labelledby="cookie-policy-title">

			<div class="tsbs-legal-page__body">
				<RitchText block={policyContent} className="tsbs-legal-page__richtext" />
			</div>
		</article>
	</main>
</Layout>
