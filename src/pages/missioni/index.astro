---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import {
	getMissioniAttive,
	getPartecipazioniMissioneByJwt,
	type Missione,
	type PartecipazioneMissione,
} from '../../lib/strapi/missioni';
import { resolveUserContext } from '../../lib/theme';

const { lang = 'it' } = Astro.props;

if (!Astro.cookies.has('jwt')) {
	return Astro.redirect('/');
}

const jwt = Astro.cookies.get('jwt')?.value;
const { theme, accademia } = await resolveUserContext(jwt);

type MissionCard = {
	title: string;
	description: string;
	href: string;
	progress: number;
	meta: string;
};

type MissionTab = {
	id: string;
	label: string;
	missions: MissionCard[];
};

function getPlainText(value: string | null | undefined) {
	if (!value) return '';
	return value
		.replace(/[#*_>`[\]()]/g, '')
		.replace(/\s+/g, ' ')
		.trim();
}

function getExcerpt(value: string | null | undefined) {
	const plainText = getPlainText(value);
	if (!plainText) return 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.';
	if (plainText.length <= 110) return plainText;

	return `${plainText.slice(0, 107).trim()}...`;
}

function normalizeProgress(value: string | null | undefined, fallback = 0) {
	if (!value) return fallback;

	const progress = Number.parseFloat(value.replace(',', '.').replace('%', '').trim());
	if (!Number.isFinite(progress)) return fallback;

	return Math.min(100, Math.max(0, Math.round(progress)));
}

function getMissionProgress(partecipazione: PartecipazioneMissione | undefined) {
	if (partecipazione?.stato === 'completata') return 100;
	return normalizeProgress(partecipazione?.progresso, 0);
}

function toMissionCard(missione: Missione, partecipazione: PartecipazioneMissione | undefined): MissionCard {
	const progress = getMissionProgress(partecipazione);

	return {
		title: missione.titolo,
		description: getExcerpt(missione.descrizione),
		href: `/missioni/${missione.slug}/`,
		progress,
		meta: `${progress}%`,
	};
}

function buildMissionTabs(missioni: Missione[], partecipazioni: PartecipazioneMissione[]): MissionTab[] {
	const partecipazioniByMissione = new Map<string, PartecipazioneMissione>();
	for (const partecipazione of partecipazioni) {
		const missioneSlug = partecipazione.missione?.slug;
		if (missioneSlug) partecipazioniByMissione.set(missioneSlug, partecipazione);
	}

	const inCorso: MissionCard[] = [];
	const completate: MissionCard[] = [];
	const disponibili: MissionCard[] = [];

	for (const missione of missioni) {
		const partecipazione = partecipazioniByMissione.get(missione.slug);
		const missionCard = toMissionCard(missione, partecipazione);

		if (partecipazione?.stato === 'completata') {
			completate.push(missionCard);
			continue;
		}

		if (partecipazione?.stato === 'inCorso') {
			inCorso.push(missionCard);
			continue;
		}

		disponibili.push(missionCard);
	}

	return [
		{ id: 'in-corso', label: 'In corso', missions: inCorso },
		{ id: 'completate', label: 'Completate', missions: completate },
		{ id: 'disponibili', label: 'Disponibili', missions: disponibili },
	];
}

const [missioniAttive, partecipazioniMissione] = await Promise.all([
	getMissioniAttive(lang),
	jwt ? getPartecipazioniMissioneByJwt(jwt, lang) : Promise.resolve([]),
]);
const missionTabs = buildMissionTabs(missioniAttive, partecipazioniMissione);
const firstPopulatedTabIndex = missionTabs.findIndex((tab) => tab.missions.length > 0);
const activeTabIndex = firstPopulatedTabIndex >= 0 ? firstPopulatedTabIndex : 0;
---

<Layout lang={lang} theme={theme} accademia={accademia}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell missions-shell">
		<header class="missions-header">
			<h1>Missioni</h1>
		</header>

		<section class="container-xl tsbs-app-container missions-content" aria-labelledby="missions-title">
			<h2 id="missions-title" class="visually-hidden">Elenco missioni</h2>

			<ul class="nav missions-tabs" id="missions-tabs" role="tablist" aria-label="Stato missioni">
				{missionTabs.map((tab, index) => (
					<li class="nav-item missions-tabs__item" role="presentation">
						<button
							class={`nav-link missions-tabs__button ${index === activeTabIndex ? 'active' : ''}`}
							id={`${tab.id}-tab`}
							data-bs-toggle="tab"
							data-bs-target={`#${tab.id}`}
							type="button"
							role="tab"
							aria-controls={tab.id}
							aria-selected={index === activeTabIndex ? 'true' : 'false'}
						>
							{tab.label}
						</button>
					</li>
				))}
			</ul>

			<div class="tab-content missions-tab-content" id="missions-tabs-content">
				{missionTabs.map((tab, tabIndex) => (
					<div
						class={`tab-pane fade ${tabIndex === activeTabIndex ? 'show active' : ''}`}
						id={tab.id}
						role="tabpanel"
						aria-labelledby={`${tab.id}-tab`}
						tabindex="0"
					>
						{tab.missions.length > 0 ? (
							<>
								<div class="missions-grid dashboard-task-grid">
									{tab.missions.map((mission) => (
										<a class="tsbs-card dashboard-task mission-card mission-card-link" href={mission.href} data-mission-card>
											<div class="dashboard-task__header">
												<div>
													<h3 class="tsbs-accent-title">{mission.title}</h3>
													<p>{mission.description}</p>
												</div>
											</div>
											<div class="tsbs-progress tsbs-progress-accent dashboard-progress" aria-label={`Progresso ${mission.meta}`}>
												<span style={`width: ${mission.progress}%`}></span>
											</div>
											<p class="dashboard-progress-label">{mission.meta}</p>
										</a>
									))}
								</div>

								<button class="missions-load-more" type="button" data-load-more aria-controls={tab.id}>
									<span>Carica altro</span>
									<i class="bi bi-arrow-right" aria-hidden="true"></i>
								</button>
							</>
						) : (
							<div class="missions-grid dashboard-task-grid">
								<article class="tsbs-card dashboard-task mission-card">
									<div class="dashboard-task__header">
										<div>
											<h3 class="tsbs-accent-title">Nessuna missione</h3>
											<p>Nessuna missione in questa sezione.</p>
										</div>
									</div>
									<div class="tsbs-progress tsbs-progress-accent dashboard-progress" aria-label="Progresso 0%">
										<span style="width: 0%"></span>
									</div>
									<p class="dashboard-progress-label">0%</p>
								</article>
							</div>
						)}
					</div>
				))}
			</div>
		</section>
	</main>

	<script>
		const getColumnCount = (grid: HTMLElement) => {
			const columns = window.getComputedStyle(grid).gridTemplateColumns;
			return columns ? columns.split(' ').length : 1;
		};

		const getViewportBottom = () => {
			if (window.matchMedia('(min-width: 992px)').matches) return window.innerHeight - 24;

			const navHeight = getComputedStyle(document.documentElement).getPropertyValue('--tsbs-mobile-nav-height');
			return window.innerHeight - (parseFloat(navHeight) || 72) - 24;
		};

		const updateMissionCards = (pane: Element) => {
			const grid = pane.querySelector<HTMLElement>('.missions-grid');
			const button = pane.querySelector<HTMLButtonElement>('[data-load-more]');
			if (!grid || !button) return;

			const cards = [...pane.querySelectorAll<HTMLElement>('[data-mission-card]')];

			if (button.dataset.expanded === 'true') {
				cards.forEach((card) => card.classList.remove('is-hidden'));
				button.hidden = true;
				return;
			}

			cards.forEach((card) => card.classList.remove('is-hidden'));
			button.hidden = false;

			const gridStyles = window.getComputedStyle(grid);
			const columnCount = getColumnCount(grid);
			const rowGap = parseFloat(gridStyles.rowGap) || 0;
			const firstCardHeight = cards[0]?.offsetHeight || 0;
			if (firstCardHeight === 0) return;

			const totalRows = Math.ceil(cards.length / columnCount);
			const fullGridHeight = (totalRows * firstCardHeight) + (Math.max(totalRows - 1, 0) * rowGap);
			const gridTop = grid.getBoundingClientRect().top;
			const availableHeight = getViewportBottom() - gridTop;

			if (fullGridHeight <= availableHeight) {
				button.hidden = true;
				button.dataset.expanded ||= 'false';
				return;
			}

			const buttonStyles = window.getComputedStyle(button);
			const buttonBlockHeight = button.offsetHeight + (parseFloat(buttonStyles.marginTop) || 0);
			const availableRowsHeight = Math.max(0, availableHeight - buttonBlockHeight);
			const visibleRows = Math.max(1, Math.floor((availableRowsHeight + rowGap) / (firstCardHeight + rowGap)));
			const minVisibleCards = window.matchMedia('(max-width: 767.98px)').matches ? 3 : 1;
			const visibleLimit = Math.min(cards.length, Math.max(columnCount * visibleRows, minVisibleCards));

			cards.forEach((card, index) => {
				card.classList.toggle('is-hidden', index >= visibleLimit);
			});

			button.hidden = cards.length <= visibleLimit;
			button.dataset.expanded ||= 'false';
		};

		const updateActivePane = () => {
			const activePane = document.querySelector('.missions-tab-content .tab-pane.active');
			if (activePane) updateMissionCards(activePane);
		};

		updateActivePane();

		document.querySelectorAll('[data-bs-toggle="tab"]').forEach((tabButton) => {
			tabButton.addEventListener('shown.bs.tab', updateActivePane);
		});

		window.addEventListener('resize', updateActivePane);

		document.querySelectorAll<HTMLButtonElement>('[data-load-more]').forEach((button) => {
			button.addEventListener('click', () => {
				const pane = button.closest('.tab-pane');
				if (!pane) return;

				pane.querySelectorAll<HTMLElement>('[data-mission-card].is-hidden').forEach((card) => {
					card.classList.remove('is-hidden');
				});

				button.hidden = true;
				button.dataset.expanded = 'true';
			});
		});
	</script>
</Layout>
