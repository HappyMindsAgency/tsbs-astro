---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';

const { lang = 'it' } = Astro.props;
const academyTheme = 'theme-astraria';

const missionTabs = [
	{
		id: 'in-corso',
		label: 'In corso',
		missions: [
			{ progress: 65, meta: '65%' },
			{ progress: 90, meta: '90%' },
			{ progress: 50, meta: 'Step 2/4' },
			{ progress: 25, meta: 'Step 1/4' },
			{ progress: 80, meta: '80%' },
			{ progress: 100, meta: 'Completata' },
			{ progress: 35, meta: '35%' },
			{ progress: 70, meta: 'Step 3/4' },
		],
	},
	{
		id: 'completate',
		label: 'Completate',
		missions: [
			{ progress: 100, meta: 'Completata' },
			{ progress: 100, meta: 'Completata' },
			{ progress: 100, meta: 'Completata' },
			{ progress: 100, meta: 'Completata' },
			{ progress: 100, meta: 'Completata' },
			{ progress: 100, meta: 'Completata' },
			{ progress: 100, meta: 'Completata' },
			{ progress: 100, meta: 'Completata' },
		],
	},
	{
		id: 'disponibili',
		label: 'Disponibili',
		missions: [
			{ progress: 0, meta: 'Disponibile' },
			{ progress: 0, meta: 'Disponibile' },
			{ progress: 0, meta: 'Disponibile' },
			{ progress: 0, meta: 'Disponibile' },
			{ progress: 0, meta: 'Disponibile' },
			{ progress: 0, meta: 'Disponibile' },
			{ progress: 0, meta: 'Disponibile' },
			{ progress: 0, meta: 'Disponibile' },
		],
	},
];
---

<Layout lang={lang}>
	<Nav lang={lang} />

	<main class={`tsbs-app-shell missions-shell ${academyTheme}`}>
		<header class="missions-header">
			<h1>Missioni</h1>
		</header>

		<section class="missions-content" aria-labelledby="missions-title">
			<h2 id="missions-title" class="visually-hidden">Elenco missioni</h2>

			<ul class="nav missions-tabs" id="missions-tabs" role="tablist" aria-label="Stato missioni">
				{missionTabs.map((tab, index) => (
					<li class="nav-item missions-tabs__item" role="presentation">
						<button
							class={`nav-link missions-tabs__button ${index === 0 ? 'active' : ''}`}
							id={`${tab.id}-tab`}
							data-bs-toggle="tab"
							data-bs-target={`#${tab.id}`}
							type="button"
							role="tab"
							aria-controls={tab.id}
							aria-selected={index === 0 ? 'true' : 'false'}
						>
							{tab.label}
						</button>
					</li>
				))}
			</ul>

			<div class="tab-content missions-tab-content" id="missions-tabs-content">
				{missionTabs.map((tab, tabIndex) => (
					<div
						class={`tab-pane fade ${tabIndex === 0 ? 'show active' : ''}`}
						id={tab.id}
						role="tabpanel"
						aria-labelledby={`${tab.id}-tab`}
						tabindex="0"
					>
						<div class="missions-grid dashboard-task-grid">
							{tab.missions.map((mission) => (
								<article class="tsbs-card dashboard-task mission-card" data-mission-card>
									<div class="dashboard-task__header">
										<div>
											<h3 class="tsbs-accent-title">Lorem ipsum dolor</h3>
											<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
										</div>
									</div>
									<div class="tsbs-progress tsbs-progress-accent dashboard-progress" aria-label={`Progresso ${mission.meta}`}>
										<span style={`width: ${mission.progress}%`}></span>
									</div>
									<p class="dashboard-progress-label">{mission.meta}</p>
								</article>
							))}
						</div>

						<button class="missions-load-more" type="button" data-load-more aria-controls={tab.id}>
							<span>Carica altro</span>
							<i class="bi bi-arrow-right" aria-hidden="true"></i>
						</button>
					</div>
				))}
			</div>
		</section>
	</main>

	<script>
		const getColumnCount = (grid: HTMLElement) => {
			const columns = window.getComputedStyle(grid).gridTemplateColumns;
			return columns ? columns.split(' ').length : 1;
		};

		const getViewportBottom = () => {
			if (window.matchMedia('(min-width: 992px)').matches) return window.innerHeight - 24;

			const navHeight = getComputedStyle(document.documentElement).getPropertyValue('--tsbs-mobile-nav-height');
			return window.innerHeight - (parseFloat(navHeight) || 72) - 24;
		};

		const updateMissionCards = (pane: Element) => {
			const grid = pane.querySelector<HTMLElement>('.missions-grid');
			const button = pane.querySelector<HTMLButtonElement>('[data-load-more]');
			if (!grid || !button) return;

			const cards = [...pane.querySelectorAll<HTMLElement>('[data-mission-card]')];

			if (button.dataset.expanded === 'true') {
				cards.forEach((card) => card.classList.remove('is-hidden'));
				button.hidden = true;
				return;
			}

			cards.forEach((card) => card.classList.remove('is-hidden'));
			button.hidden = false;

			const gridStyles = window.getComputedStyle(grid);
			const columnCount = getColumnCount(grid);
			const rowGap = parseFloat(gridStyles.rowGap) || 0;
			const firstCardHeight = cards[0]?.offsetHeight || 0;
			if (firstCardHeight === 0) return;

			const totalRows = Math.ceil(cards.length / columnCount);
			const fullGridHeight = (totalRows * firstCardHeight) + (Math.max(totalRows - 1, 0) * rowGap);
			const gridTop = grid.getBoundingClientRect().top;
			const availableHeight = getViewportBottom() - gridTop;

			if (fullGridHeight <= availableHeight) {
				button.hidden = true;
				button.dataset.expanded ||= 'false';
				return;
			}

			const buttonStyles = window.getComputedStyle(button);
			const buttonBlockHeight = button.offsetHeight + (parseFloat(buttonStyles.marginTop) || 0);
			const availableRowsHeight = Math.max(0, availableHeight - buttonBlockHeight);
			const visibleRows = Math.max(1, Math.floor((availableRowsHeight + rowGap) / (firstCardHeight + rowGap)));
			const minVisibleCards = window.matchMedia('(max-width: 767.98px)').matches ? 3 : 1;
			const visibleLimit = Math.min(cards.length, Math.max(columnCount * visibleRows, minVisibleCards));

			cards.forEach((card, index) => {
				card.classList.toggle('is-hidden', index >= visibleLimit);
			});

			button.hidden = cards.length <= visibleLimit;
			button.dataset.expanded ||= 'false';
		};

		const updateActivePane = () => {
			const activePane = document.querySelector('.missions-tab-content .tab-pane.active');
			if (activePane) updateMissionCards(activePane);
		};

		updateActivePane();

		document.querySelectorAll('[data-bs-toggle="tab"]').forEach((tabButton) => {
			tabButton.addEventListener('shown.bs.tab', updateActivePane);
		});

		window.addEventListener('resize', updateActivePane);

		document.querySelectorAll<HTMLButtonElement>('[data-load-more]').forEach((button) => {
			button.addEventListener('click', () => {
				const pane = button.closest('.tab-pane');
				if (!pane) return;

				pane.querySelectorAll<HTMLElement>('[data-mission-card].is-hidden').forEach((card) => {
					card.classList.remove('is-hidden');
				});

				button.hidden = true;
				button.dataset.expanded = 'true';
			});
		});
	</script>
</Layout>

<style lang="scss">
	.missions-shell {
		--missions-header-bg: var(--tsbs-color-astraria);
		min-height: 100vh;
		background: var(--tsbs-color-surface);
	}

	.missions-header {
		display: grid;
		place-items: center;
		min-height: 5.25rem;
		padding: 1.25rem 1.875rem;
		background: var(--missions-header-bg);
	}

	.missions-shell .missions-header h1 {
		margin: 0;
		color: var(--tsbs-color-white);
		font-size: 2rem;
		font-weight: 700;
		line-height: 1;
	}

	.missions-content {
		width: min(100%, 72rem);
		padding: 1.875rem 1.875rem 2rem;
		margin: 0 auto;
	}

	.missions-tabs {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0;
		padding: 0.25rem;
		margin: 0 0 1.875rem;
		background: #d8e5fb;
		border-radius: 0.875rem;
	}

	.missions-tabs__item {
		min-width: 0;
	}

	.missions-tabs__button {
		width: 100%;
		min-height: 2.125rem;
		padding: 0.5rem 0.375rem;
		color: rgba(29, 23, 21, 0.55);
		font-size: clamp(0.8125rem, 0.72rem + 0.3vw, 0.9375rem);
		font-weight: 700;
		line-height: 1;
		text-align: center;
		border: 0;
		border-radius: 0.75rem;
	}

	.missions-tabs .nav-link:hover,
	.missions-tabs .nav-link:focus {
		color: var(--tsbs-color-astraria);
	}

	.missions-tabs .nav-link.active {
		color: var(--tsbs-color-heading);
		background: var(--tsbs-color-white);
		box-shadow: 0 0.125rem 0.625rem rgba(42, 51, 105, 0.08);
	}

	.missions-grid {
		display: grid;
	}

	.mission-card.is-hidden {
		display: none;
	}

	.missions-load-more {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.375rem;
		width: fit-content;
		margin: 1.5rem auto 0;
		color: var(--tsbs-color-astraria);
		font-size: 0.875rem;
		font-weight: 700;
		line-height: 1;
		text-decoration: none;
		background: transparent;
		border: 0;
	}

	.missions-load-more .bi {
		font-size: 1rem;
		line-height: 1;
	}

	.missions-load-more[hidden] {
		display: none;
	}

	@media (min-width: 768px) {
		.missions-content {
			padding-right: 3rem;
			padding-left: 3rem;
		}

		.missions-tabs {
			width: min(100%, clamp(28rem, 42vw, 36rem));
			margin-right: auto;
			margin-left: auto;
		}
	}

	@media (min-width: 992px) {
		.missions-header {
			place-items: center start;
			min-height: 5.625rem;
			padding: 0 3rem;
		}

		.missions-shell .missions-header h1 {
			font-size: 2.125rem;
		}

		.missions-content {
			padding-top: 2rem;
			padding-right: 3rem;
			padding-left: 3rem;
		}

		.missions-tabs__button {
			min-height: 2.5rem;
			padding: 0.625rem 0.75rem;
		}
	}
</style>
