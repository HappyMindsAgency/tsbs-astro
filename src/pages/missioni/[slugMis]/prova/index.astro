---
import Layout from '../../../../layouts/Layout.astro';
import Nav from '../../../../components/Nav.astro';
import SceltaDomanda from '../../../../components/MissioniComponents/SceltaDomanda.astro';
import RispostaLibera from '../../../../components/MissioniComponents/RispostaLibera.astro';
import { getMissioneBySlug } from '../../../../lib/strapi/missioni';
import { resolveUserTheme } from '../../../../lib/theme';

export const prerender = false;

const { lang = 'it' } = Astro.props;
const jwt = Astro.cookies.get('jwt')?.value;

if (!jwt) {
	return Astro.redirect('/');
}

const { slugMis } = Astro.params;
const locale = typeof lang === 'string' && lang.trim() ? lang.trim() : 'it';

if (!slugMis) {
	return Astro.redirect('/404');
}

const theme = await resolveUserTheme(jwt);
const missione = await getMissioneBySlug(slugMis, locale);
const rawQuestions = missione?.quiz?.domande ?? [];
const hasAnswerElements = rawQuestions.some((domanda) => (domanda.risposte || []).length > 0);

if (!missione?.quiz || rawQuestions.length === 0 || !hasAnswerElements) {
	return Astro.redirect('/404');
}

const questions = rawQuestions.map((domanda) => ({
	question: domanda.domanda?.trim() || 'Lorem ipsum',
	answers: (domanda.risposte || []).map((risposta) => ({
		label: risposta.risposta?.trim() || 'Lorem ipsum',
	})),
}));

const isFreeAnswer = questions.every((domanda) => domanda.answers.length === 1);
const ProvaComponent = isFreeAnswer ? RispostaLibera : SceltaDomanda;
---

<Layout lang={locale} theme={theme}>
	<Nav lang={locale} />

	<main class="tsbs-app-shell mission-proof">
		<ProvaComponent missione={missione} questions={questions} lang={locale} slugMis={slugMis} />
	</main>
</Layout>
