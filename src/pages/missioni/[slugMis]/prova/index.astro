---
import Layout from '../../../../layouts/Layout.astro';
import Nav from '../../../../components/Nav.astro';
import SceltaDomanda from '../../../../components/MissioniComponents/SceltaDomanda.astro';
import RispostaLibera from '../../../../components/MissioniComponents/RispostaLibera.astro';
import ParolaDordine from '../../../../components/MissioniComponents/ParolaDordine.astro';
import { strapi } from '@strapi/client';

export const prerender = false;

const { lang = 'it' } = Astro.props;
const { slugMis } = Astro.params;
const locale = typeof lang === 'string' && lang.trim() ? lang.trim() : 'it';
const strapiBaseURL = import.meta.env.STRAPI_API_URL || import.meta.env.STRAPI_URL;
const requestedTipoProva = Astro.url.searchParams.get('tipoProva');

// Questa pagina resta la regia stabile della prova: quando Strapi sara la fonte dati completa,
// usera slug missione, tipo prova e stato partecipazione per scegliere il componente corretto
// senza creare route Astro separate per domanda, parola d'ordine, risposta libera o varianti future.
const provaComponents = {
	'scelta-multipla': SceltaDomanda,
	sceltaMultipla: SceltaDomanda,
	quiz: SceltaDomanda,
	'risposta-libera': RispostaLibera,
	rispostaLibera: RispostaLibera,
	'parola-dordine': ParolaDordine,
	parolaDordine: ParolaDordine,
};

let missione = null;

if (strapiBaseURL && slugMis) {
	try {
		const client = strapi({ baseURL: strapiBaseURL });
		const response = await client.collection('missioni').find({
			locale,
			filters: {
				slugMis: {
					$eq: slugMis,
				},
			},
			populate: ['prova', 'partecipazioni'],
		});

		missione = response?.data?.[0] || null;
	} catch {
		missione = null;
	}
}

const tipoProva =
	requestedTipoProva ||
	missione?.tipoProva ||
	missione?.prova?.tipoProva ||
	missione?.categoriaMissione?.tipoProva ||
	'scelta-multipla';

const ProvaComponent = provaComponents[tipoProva as keyof typeof provaComponents] || SceltaDomanda;
---

<Layout lang={locale}>
	<Nav lang={locale} />

	<main class="tsbs-app-shell mission-proof">
		<ProvaComponent missione={missione} lang={locale} slugMis={slugMis} />
	</main>
</Layout>
