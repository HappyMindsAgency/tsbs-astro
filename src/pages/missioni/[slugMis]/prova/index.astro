---
import Layout from '../../../../layouts/Layout.astro';
import Nav from '../../../../components/Nav.astro';
import SceltaDomanda from '../../../../components/MissioniComponents/SceltaDomanda.astro';
import RispostaLibera from '../../../../components/MissioniComponents/RispostaLibera.astro';
import ProvaMissioneMista from '../../../../components/MissioniComponents/ProvaMissioneMista.astro';
import NotaEditor from '../../../../components/GrimorioComponents/NotaEditor.astro';
import TrofeoModal from '../../../../components/PopupComponents/TrofeoModal.astro';
import { getMissioneBySlug } from '../../../../lib/strapi/missioni';
import { getMembroProgressioneByJwt, getPartecipazione } from '../../../../lib/strapi/progressione';
import { resolveUserTheme } from '../../../../lib/theme';

export const prerender = false;

const { lang = 'it' } = Astro.props;
const jwt = Astro.cookies.get('jwt')?.value;

if (!jwt) {
	return Astro.redirect('/');
}

const { slugMis } = Astro.params;
const locale = typeof lang === 'string' && lang.trim() ? lang.trim() : 'it';
const MISSIONE_GRIMORIO_SLUG = 'missione-02-il-segno';
const MISSIONE_GRIMORIO_SLUG_ALTERNATIVE = 'il-segno';

if (!slugMis) {
	return Astro.redirect('/404');
}

const theme = await resolveUserTheme(jwt);
const [missione, membro] = await Promise.all([
	getMissioneBySlug(slugMis, locale),
	getMembroProgressioneByJwt(jwt),
]);

if (!missione) {
	return Astro.redirect('/404');
}

const partecipazione = membro ? await getPartecipazione(membro.documentId, missione.documentId) : null;
if (partecipazione?.stato === 'completata') {
	return Astro.redirect(`/missioni/${missione.slug}/`);
}

// Le cacce al tesoro hanno una pagina dedicata (indizi in quiz.step, non in
// quiz.domande): instrada lì chi arriva diretto alla prova standard.
if (missione.quiz?.cacciaAlTesoro) {
	return Astro.redirect(`/missioni/${missione.slug}/caccia-tesoro/`);
}

const isMissioneGrimorio = missione.slug === MISSIONE_GRIMORIO_SLUG || missione.slug === MISSIONE_GRIMORIO_SLUG_ALTERNATIVE;
const rawQuestions = missione?.quiz?.domande ?? [];
const hasAnswerElements = rawQuestions.some((domanda) => (domanda.risposte || []).length > 0);

if (!isMissioneGrimorio && (!missione?.quiz || rawQuestions.length === 0 || !hasAnswerElements)) {
	return Astro.redirect('/404');
}

const questions = rawQuestions.map((domanda) => ({
	question: domanda.domanda?.trim() || '',
	lore: domanda.lore?.trim() || '',
	answers: (domanda.risposte || []).map((risposta) => ({
		label: risposta.risposta?.trim() || '',
	})),
}));

const questionComponentTypes = questions.map((domanda) => (domanda.answers.length === 1 ? 'free-answer' : 'choice-question'));
const hasMixedQuestionComponents = new Set(questionComponentTypes).size > 1;
const ProvaComponent = hasMixedQuestionComponents
	? ProvaMissioneMista
	: questionComponentTypes[0] === 'free-answer'
		? RispostaLibera
		: SceltaDomanda;
---

<Layout lang={locale} theme={theme}>
	<Nav lang={locale} />

	<main class="tsbs-app-shell mission-proof">
		{isMissioneGrimorio ? (
			<section class="missions-shell note-page">
				<header class="missions-header">
					<h1>{missione.titolo}</h1>
				</header>

				<div class="container-xl tsbs-app-container note-page__content">
					<NotaEditor missioneSlug={missione.slug} />
				</div>
			</section>
		) : (
			<ProvaComponent missione={missione} questions={questions} lang={locale} slugMis={slugMis} />
		)}
	</main>

	<TrofeoModal theme={theme} />
</Layout>
