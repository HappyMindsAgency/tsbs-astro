---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import BackButton from '../../../components/BackButton.astro';
import RitchText from '../../../components/RitchText.astro';
import DomandaModal from '../../../components/PopupComponents/DomandaModal.astro';
import TrofeoModal from '../../../components/PopupComponents/TrofeoModal.astro';
import ConfermaCheackSfidaLettura from '../../../components/toastComponents/ConfermaCheackSfidaLettura.astro';
import { getMissioneBySlug } from '../../../lib/strapi/missioni';
import { getMembroProgressioneByJwt } from '../../../lib/strapi/progressione';
import { getStatoSfidaLettura, type LibroSfida } from '../../../lib/strapi/sfida-lettura';
import { resolveUserTheme } from '../../../lib/theme';

export const prerender = false;

const { lang = 'it' } = Astro.props;
const jwt = Astro.cookies.get('jwt')?.value;

if (!jwt) {
	return Astro.redirect('/');
}

const { slugMis } = Astro.params;
const locale = typeof lang === 'string' && lang.trim() ? lang.trim() : 'it';
const missionPath = `/missioni/${slugMis ?? ''}/`;

if (!slugMis) {
	return Astro.redirect('/404');
}

const [theme, missione, membro] = await Promise.all([
	resolveUserTheme(jwt),
	getMissioneBySlug(slugMis, locale),
	getMembroProgressioneByJwt(jwt),
]);

if (!missione || !membro) {
	return Astro.redirect('/404');
}

const stato = await getStatoSfidaLettura(membro.documentId);
const riconosciuti = new Set(stato.libriRiconosciuti);

// Raggruppa la lista chiusa dei libri per genere (accordion).
const FALLBACK_GENERE = 'Altro';
const categorieMap = new Map<string, LibroSfida[]>();
for (const libro of stato.libri) {
	const genere = libro.genere?.trim() || FALLBACK_GENERE;
	const gruppo = categorieMap.get(genere) ?? [];
	gruppo.push(libro);
	categorieMap.set(genere, gruppo);
}

const slugify = (value: string) =>
	value
		.toLocaleLowerCase('it-IT')
		.normalize('NFD')
		.replace(/\p{Diacritic}/gu, '')
		.replace(/[^a-z0-9]+/g, '-')
		.replace(/^-+|-+$/g, '') || 'categoria';

const categories = [...categorieMap.entries()]
	.sort(([labelA], [labelB]) => {
		if (labelA === FALLBACK_GENERE && labelB !== FALLBACK_GENERE) return 1;
		if (labelA !== FALLBACK_GENERE && labelB === FALLBACK_GENERE) return -1;
		return 0;
	})
	.map(([label, books]) => ({
		id: slugify(label),
		label,
		books,
	}));

const OBIETTIVO_LETTURE = 20;
const libriLetti = stato.libriRiconosciuti.length;
const hasDescription = Boolean(missione.descrizione?.trim());
const trophyLabel = missione.trofeo?.nome || (missione.punteggio ? `${missione.punteggio} punti` : '');
---

<Layout lang={locale} theme={theme}>
	<Nav lang={locale} />

	<main class="tsbs-app-shell reading-challenge">
		<header class="mission-detail__topbar">
			<BackButton href={missionPath} label="Torna alla missione" withText variant="plain" class="mission-detail__back" />
		</header>

		<section
			class="container-xl tsbs-app-container reading-challenge__content"
			aria-labelledby="reading-challenge-title"
			data-reading-challenge
			data-slug-mis={slugMis}
			data-tentativo-effettuato={stato.tentativoOdiernoEffettuato ? 'true' : 'false'}
		>
			<div class="mission-detail__media reading-challenge__media" aria-label="Immagine sfida di lettura">
				<i class="bi bi-image" aria-hidden="true"></i>
			</div>

			<div class="reading-challenge__body">
				<h1 id="reading-challenge-title">{missione.titolo}</h1>

				<hr class="mission-detail__rule reading-challenge__rule" />

				{hasDescription && (
					<article class="mission-detail__objective reading-challenge__objective" aria-labelledby="reading-challenge-objective-title">
						<h2 id="reading-challenge-objective-title">Obiettivo:</h2>
						<RitchText block={missione.descrizione} />
					</article>
				)}

				<div class="reading-challenge__progress" aria-label="Progresso letture">
					<strong data-sfida-progress>{libriLetti} / {OBIETTIVO_LETTURE}</strong>
					<span>libri letti</span>
				</div>

				<p class="reading-challenge__feedback" data-sfida-feedback hidden aria-live="polite" tabindex="-1"></p>

				<div class="accordion reading-challenge__accordion" id="reading-challenge-categories">
					{categories.map((category) => (
						<div class="accordion-item reading-challenge__category">
							<h2 class="accordion-header" id={`heading-${category.id}`}>
								<button
									class="accordion-button reading-challenge__category-button collapsed"
									type="button"
									data-bs-toggle="collapse"
									data-bs-target={`#collapse-${category.id}`}
									aria-expanded="false"
									aria-controls={`collapse-${category.id}`}
								>
									{category.label}
								</button>
							</h2>

							<div
								id={`collapse-${category.id}`}
								class="accordion-collapse collapse"
								aria-labelledby={`heading-${category.id}`}
								data-bs-parent="#reading-challenge-categories"
							>
								<div class="accordion-body reading-challenge__book-list">
									{category.books.map((book) => (
										<label class="reading-challenge__book">
											<input
												type="checkbox"
												data-sfida-libro={book.documentId}
												checked={riconosciuti.has(book.documentId)}
												disabled={riconosciuti.has(book.documentId)}
											/>
											<span>{book.autore ? `${book.titolo} - ${book.autore}` : book.titolo}</span>
										</label>
									))}
								</div>
							</div>
						</div>
					))}
				</div>

				{trophyLabel && (
					<>
						<hr class="mission-detail__rule reading-challenge__rule reading-challenge__rule--reward" />

						<div class="mission-detail__reward reading-challenge__reward" aria-label="Ricompensa sfida lettura">
							<p>Completando questa missione otterrai:</p>
							<p class="mission-detail__trophy">
								<i class="bi bi-award" aria-hidden="true"></i>
								<strong>{trophyLabel}</strong>
							</p>
						</div>
					</>
				)}
			</div>
		</section>
	</main>

	<DomandaModal />
	<ConfermaCheackSfidaLettura renderHidden />
	<TrofeoModal theme={theme} />
</Layout>

<script>
	const setupReadingChallenge = () => {
		const root = document.querySelector<HTMLElement>('[data-reading-challenge]');
		if (!root || root.dataset.readingChallengeReady === 'true') return;
		root.dataset.readingChallengeReady = 'true';

		const slugMis = root.dataset.slugMis || '';
		const progress = root.querySelector<HTMLElement>('[data-sfida-progress]');
		const feedback = root.querySelector<HTMLElement>('[data-sfida-feedback]');
		const checkboxes = root.querySelectorAll<HTMLInputElement>('[data-sfida-libro]');

		let dayLocked = root.dataset.tentativoEffettuato === 'true';
		let activeLibroId = '';
		let activeInput: HTMLInputElement | null = null;
		let selectionLocked = false;

		checkboxes.forEach((input) => {
			if (input.disabled) input.dataset.sfidaPermanentlyDisabled = 'true';
		});

		const setSelectionLocked = (locked: boolean) => {
			selectionLocked = locked;
			checkboxes.forEach((input) => {
				if (input.dataset.sfidaPermanentlyDisabled === 'true') return;
				input.disabled = locked;
			});
		};

		const setFeedback = (message: string) => {
			if (!feedback) return;
			feedback.textContent = message;
			feedback.hidden = !message;
		};

		const focusFeedback = () => {
			if (!feedback || feedback.hidden) return;
			feedback.scrollIntoView({ behavior: 'smooth', block: 'center' });
			feedback.focus({ preventScroll: true });
		};

		const setFeedbackAndFocus = (message: string) => {
			setFeedback(message);
			window.requestAnimationFrame(focusFeedback);
		};

		const messages: Record<string, string> = {
			tentativo_gia_effettuato_oggi: 'Hai già effettuato il tentativo di oggi. Torna domani.',
			libro_gia_riconosciuto: 'Hai già riconosciuto questo libro.',
			generico: 'Operazione non riuscita. Riprova.',
		};

		const apiUrl = `/api/missioni/${slugMis}/sfida-lettura`;

		const richiediDomanda = async (input: HTMLInputElement, libroId: string) => {
			try {
				const response = await fetch(apiUrl, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ azione: 'domanda', libro: libroId }),
				});
				const payload = await response.json().catch(() => null);

				if (!response.ok || !Array.isArray(payload?.estratti)) {
					input.checked = false;
					setSelectionLocked(false);
					if (payload?.error === 'tentativo_gia_effettuato_oggi') dayLocked = true;
					const message = messages[payload?.error] || messages.generico;
					if (payload?.error === 'tentativo_gia_effettuato_oggi') {
						setFeedbackAndFocus(message);
					} else {
						setFeedback(message);
					}
					return;
				}

				activeLibroId = libroId;
				activeInput = input;
				setFeedback('');

				document.dispatchEvent(
					new CustomEvent('tsbs:question-modal-open', {
						detail: {
							input,
							variant: 'reading-challenge',
							answers: payload.estratti.map((estratto: string) => ({ description: estratto })),
						},
					}),
				);
			} catch {
				input.checked = false;
				setSelectionLocked(false);
				setFeedback(messages.generico);
			}
		};

		const inviaRisposta = async (indice: number) => {
			if (!activeLibroId) return;
			const input = activeInput;

			try {
				const response = await fetch(apiUrl, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ azione: 'risposta', libro: activeLibroId, indice }),
				});
				const payload = await response.json().catch(() => null);

				if (!response.ok || typeof payload?.corretta !== 'boolean') {
					if (input) input.checked = false;
					if (payload?.error === 'tentativo_gia_effettuato_oggi') dayLocked = true;
					const message = messages[payload?.error] || messages.generico;
					if (payload?.error === 'tentativo_gia_effettuato_oggi') {
						setFeedbackAndFocus(message);
					} else {
						setFeedback(message);
					}
					return;
				}

				// Un solo inserimento al giorno: la risposta consuma il tentativo.
				dayLocked = true;
				document.dispatchEvent(new CustomEvent('tsbs:sfida-lettura-check-open', { detail: { correct: payload.corretta } }));

				if (payload.corretta) {
					if (input) {
						input.checked = true;
						input.dataset.sfidaPermanentlyDisabled = 'true';
						input.disabled = true;
					}
					if (progress) progress.textContent = `${payload.libriRiconosciuti} / 20`;
					setFeedback('');
				} else {
					if (input) input.checked = false;
					setFeedback('');
				}

				const trofei = Array.isArray(payload.trofeiSbloccati) ? payload.trofeiSbloccati : [];
				if (trofei.length > 0) {
					const thresholdCopy = {
						4: {
							titoloNotifica: 'Prima soglia raggiunta!',
							messaggioNotifica: 'Hai confermato 4 letture.',
							ctaLabel: 'Ritira il trofeo',
						},
						6: {
							titoloNotifica: 'Seconda soglia raggiunta!',
							messaggioNotifica: 'Hai confermato 6 letture.',
							ctaLabel: 'Ritira il trofeo',
						},
						12: {
							titoloNotifica: 'Terza soglia raggiunta!',
							messaggioNotifica: 'Hai confermato 12 letture!',
							ctaLabel: 'Ritira il trofeo',
						},
						20: {
							titoloNotifica: 'Hai portato a termine la Sfida di lettura!',
							messaggioNotifica: 'Hai sbloccato un nuovo trofeo.',
							ctaLabel: 'Collezionalo',
						},
					};
					const notificationCopy = thresholdCopy[payload.libriRiconosciuti];
					document.dispatchEvent(new CustomEvent('tsbs:trofei-sbloccati', {
						detail: {
							trofei,
							...notificationCopy,
						},
					}));
				}
			} catch {
				if (input) input.checked = false;
				setFeedback(messages.generico);
			} finally {
				activeLibroId = '';
				activeInput = null;
				setSelectionLocked(false);
			}
		};

		checkboxes.forEach((input) => {
			input.addEventListener('change', () => {
				if (!input.checked) return;

				if (selectionLocked) {
					input.checked = false;
					return;
				}

				if (dayLocked) {
					input.checked = false;
					setFeedbackAndFocus(messages.tentativo_gia_effettuato_oggi);
					return;
				}

				setSelectionLocked(true);
				void richiediDomanda(input, input.dataset.sfidaLibro || '');
			});
		});

		document.addEventListener('tsbs:question-modal-close', (event) => {
			if (!(event instanceof CustomEvent)) return;
			if (event.detail?.confirmed) return;

			activeLibroId = '';
			activeInput = null;
			setSelectionLocked(false);
		});

		document.addEventListener('tsbs:question-modal-submit', (event) => {
			if (!(event instanceof CustomEvent)) return;

			const indice = Number.parseInt(String(event.detail?.value ?? ''), 10);
			if (!Number.isFinite(indice) || indice < 0) return;

			void inviaRisposta(indice);
		});
	};

	document.addEventListener('astro:page-load', setupReadingChallenge);
	setupReadingChallenge();
</script>

<style lang="scss">
	.reading-challenge__feedback {
		margin: 0;
		font-size: 0.9375rem;
		color: var(--tsbs-theme-accent);
	}
</style>
