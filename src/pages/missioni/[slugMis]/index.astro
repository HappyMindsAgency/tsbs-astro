---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import RitchText from '../../../components/RitchText.astro';
import { getMissioneBySlug } from '../../../lib/strapi/missioni';
import { resolveUserTheme } from '../../../lib/theme';

export const prerender = false;

const { lang = 'it' } = Astro.props;
const { slugMis } = Astro.params;
const jwt = Astro.cookies.get('jwt')?.value;

if (!jwt) {
	return Astro.redirect('/');
}

if (!slugMis) {
	return Astro.redirect('/404');
}

const theme = await resolveUserTheme(jwt);
const missione = await getMissioneBySlug(slugMis, lang);

if (!missione) {
	return Astro.redirect('/404');
}

const hasDescription = Boolean(missione.descrizione?.trim());
const trophyLabel = missione.trofeo?.nome || (missione.punteggio ? `${missione.punteggio} punti` : '');
// "Avvia la missione" crea la Partecipazione (inCorso, progresso 50) e
// reindirizza alla prova: il target è calcolato lato server dall'endpoint.
const avviaActionHref = `/api/missioni/${missione.slug}/avvia`;
---

<Layout lang={lang} theme={theme}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell mission-detail">
		<header class="mission-detail__topbar">
			<a class="mission-detail__back" href="/missioni/">
				<i class="bi bi-arrow-left" aria-hidden="true"></i>
				<span>Torna alle missioni</span>
			</a>
		</header>

		<section class="container-xl tsbs-app-container mission-detail__content" aria-labelledby="mission-title">
			<div class="mission-detail__body">
				<h1 id="mission-title">{missione.titolo}</h1>

				{hasDescription && <hr class="mission-detail__rule" />}

				{hasDescription && (
					<RitchText block={missione.descrizione} className="mission-detail__description" />
				)}

				{trophyLabel && (
					<>
						{hasDescription && <hr class="mission-detail__rule mission-detail__rule--reward" />}

						<div class="mission-detail__reward" aria-label="Ricompensa missione">
							<p>Completando questa missione otterrai:</p>
							<p class="mission-detail__trophy">
								<i class="bi bi-award" aria-hidden="true"></i>
								<strong>{trophyLabel}</strong>
							</p>
						</div>
					</>
				)}

				<form class="mission-detail__cta-form" method="POST" action={avviaActionHref}>
					<button class="btn tsbs-cta-primary mission-detail__cta" type="submit">Avvia la missione</button>
				</form>
			</div>
		</section>
	</main>
</Layout>

<style>
	/* Il form wrappa solo il pulsante: display:contents lo toglie dal layout
	   così il bottone resta l'elemento del grid e conserva centratura/margini. */
	.mission-detail__cta-form {
		display: contents;
	}
</style>
