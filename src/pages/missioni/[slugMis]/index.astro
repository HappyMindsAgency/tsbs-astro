---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';
import BackButton from '../../../components/BackButton.astro';
import RitchText from '../../../components/RitchText.astro';
import { getMissioneBySlug, MISSIONI_SPECIALI } from '../../../lib/strapi/missioni';
import { getMembroProgressioneByJwt, getPartecipazione } from '../../../lib/strapi/progressione';
import { resolveUserTheme } from '../../../lib/theme';

export const prerender = false;

const { lang = 'it' } = Astro.props;
const { slugMis } = Astro.params;
const jwt = Astro.cookies.get('jwt')?.value;

if (!jwt) {
	return Astro.redirect('/');
}

if (!slugMis) {
	return Astro.redirect('/404');
}

const theme = await resolveUserTheme(jwt);
const [missione, membro] = await Promise.all([
	getMissioneBySlug(slugMis, lang),
	getMembroProgressioneByJwt(jwt),
]);

if (!missione) {
	return Astro.redirect('/404');
}

const partecipazione = membro ? await getPartecipazione(membro.documentId, missione.documentId) : null;
const missioneCompletata = partecipazione?.stato === 'completata';
const hasDescription = Boolean(missione.descrizione?.trim());
const trophyLabel = missione.trofeo?.nome || (missione.punteggio ? `${missione.punteggio} punti` : '');
// "Avvia la missione" crea la Partecipazione (inCorso, progresso 50) e
// reindirizza alla prova: il target è calcolato lato server dall'endpoint.
const avviaActionHref = `/api/missioni/${missione.slug}/avvia`;

// Missione 12 "referral": niente quiz. Se il membro ha gia un codice
// (externalAuthId), mostriamo il link di condivisione; altrimenti "Avvia" lo genera.
const isReferral = missione.documentId === MISSIONI_SPECIALI.referral;
const referralCode = isReferral ? membro?.externalAuthId?.trim() || '' : '';
let referralLink = '';
if (referralCode) {
	const host = Astro.request.headers.get('x-forwarded-host') || Astro.request.headers.get('host') || Astro.url.host;
	const proto = Astro.request.headers.get('x-forwarded-proto') || Astro.url.protocol.replace(':', '');
	referralLink = `${proto}://${host}/?ref=${referralCode}`;
}
---

<Layout lang={lang} theme={theme}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell mission-detail">
		<header class="mission-detail__topbar">
			<BackButton href="/missioni/" label="Torna alle missioni" withText variant="plain" class="mission-detail__back" />
		</header>

		<section class="container-xl tsbs-app-container mission-detail__content" aria-labelledby="mission-title">
			<div class="mission-detail__body">
				<h1 id="mission-title">{missione.titolo}</h1>

				{hasDescription && <hr class="mission-detail__rule" />}

				{hasDescription && (
					<RitchText block={missione.descrizione} className="mission-detail__description" />
				)}

				{trophyLabel && (
					<>
						{hasDescription && <hr class="mission-detail__rule mission-detail__rule--reward" />}

						<div class="mission-detail__reward" aria-label="Ricompensa missione">
							<p>Completando questa missione otterrai:</p>
							<p class="mission-detail__trophy">
								<i class="bi bi-award" aria-hidden="true"></i>
								<strong>{trophyLabel}</strong>
							</p>
						</div>
					</>
				)}

				{missioneCompletata ? (
					<button class="btn tsbs-cta-primary mission-detail__cta" type="button" disabled>Missione completata</button>
				) : referralLink ? (
					<div class="mission-detail__referral" data-referral>
						<label for="referral-link">Il tuo link di invito</label>
						<div class="mission-detail__referral-row">
							<input id="referral-link" type="text" readonly value={referralLink} data-referral-link />
							<button class="btn tsbs-cta-primary" type="button" data-referral-copy>Copia</button>
						</div>
					</div>
				) : (
					<form class="mission-detail__cta-form" method="POST" action={avviaActionHref}>
						<button class="btn tsbs-cta-primary mission-detail__cta" type="submit">{isReferral ? 'Genera il mio link' : 'Avvia la missione'}</button>
					</form>
				)}
			</div>
		</section>
	</main>
</Layout>

<script>
	// Copia link referral negli appunti, con fallback select+execCommand.
	function initReferralCopy() {
		const btn = document.querySelector('[data-referral-copy]');
		const input = document.querySelector('[data-referral-link]');
		if (!(btn instanceof HTMLButtonElement) || !(input instanceof HTMLInputElement)) return;

		btn.addEventListener('click', async () => {
			try {
				await navigator.clipboard.writeText(input.value);
			} catch {
				input.select();
				document.execCommand('copy');
			}
			const original = btn.textContent;
			btn.textContent = 'Copiato!';
			setTimeout(() => { btn.textContent = original; }, 1500);
		});
	}
	document.addEventListener('astro:page-load', initReferralCopy);
	initReferralCopy();
</script>

<style>
	/* Il form wrappa solo il pulsante: display:contents lo toglie dal layout
	   così il bottone resta l'elemento del grid e conserva centratura/margini. */
	.mission-detail__cta-form {
		display: contents;
	}

	.mission-detail__referral-row {
		display: flex;
		gap: 0.5rem;
		align-items: stretch;
	}

	.mission-detail__referral-row input {
		flex: 1;
		min-width: 0;
	}
</style>
