---
import Layout from '../../../layouts/Layout.astro';
import Nav from '../../../components/Nav.astro';

export const prerender = false;

const { lang = 'it' } = Astro.props;
---

<Layout lang={lang}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell mission-detail">
		<header class="mission-detail__topbar">
			<a class="mission-detail__back" href="/missioni/">
				<i class="bi bi-arrow-left" aria-hidden="true"></i>
				<span>Torna alle missioni</span>
			</a>
		</header>

		<section class="container-xl tsbs-app-container mission-detail__content" aria-labelledby="mission-title">
			<div class="mission-detail__media" aria-label="Immagine missione">
				<i class="bi bi-image" aria-hidden="true"></i>
			</div>

			<div class="mission-detail__body">
				<h1 id="mission-title">Nome della missione</h1>

				<hr class="mission-detail__rule" />

				<blockquote class="mission-detail__quote">
					<p>"Si dice che l'antico astronomo abbia nascosto le coordinate del sapere proprio sotto gli occhi di tutti. Il mondo non e piatto, e nemmeno la verita..."</p>
				</blockquote>

				<article class="mission-detail__objective" aria-labelledby="mission-objective-title">
					<h2 id="mission-objective-title">Obiettivo:</h2>
					<p>Trova il Mappamondo antico al centro della Sala e trova il sigillo nascosto alla base.</p>
				</article>

				<p class="mission-detail__description">
					Aenean placerat eros turpis, nec posuere massa fermentum malesuada. Morbi at est et tortor laoreet placerat id in neque. Maecenas vel erat lacinia, sodales ipsum id, porta sapien.
				</p>

				<hr class="mission-detail__rule mission-detail__rule--reward" />

				<div class="mission-detail__reward" aria-label="Ricompensa missione">
					<p>Completando questa missione otterrai:</p>
					<p class="mission-detail__trophy">
						<i class="bi bi-award" aria-hidden="true"></i>
						<strong>Trofeo "Esploratore"</strong>
					</p>
				</div>

				<a class="btn tsbs-cta-primary mission-detail__cta" href="prova/">Avvia la missione</a>
			</div>
		</section>
	</main>
</Layout>
