---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import RitchText from '../../components/RitchText.astro';
import { isEpistolaVisible } from '../../lib/filtri/epistole';
import { getEpistolaBySlug } from '../../lib/strapi/epistole';
import { getMembroMissioniByJwt } from '../../lib/strapi/missioni';
import { resolveUserContext } from '../../lib/theme';

export const prerender = false;

const { lang = 'it' } = Astro.props;
const { slugEpis } = Astro.params;

if (!Astro.cookies.has('jwt')) {
	return Astro.redirect('/');
}

if (!slugEpis) {
	return Astro.redirect('/404');
}

const jwt = Astro.cookies.get('jwt')?.value;
const { theme, accademia } = await resolveUserContext(jwt);
const [epistola, membroMissioni] = await Promise.all([
	getEpistolaBySlug(slugEpis),
	jwt ? getMembroMissioniByJwt(jwt) : Promise.resolve(null),
]);

if (!epistola) {
	return Astro.redirect('/404');
}

const testSmistamentoCompletato = Boolean(membroMissioni?.accademia);

if (!isEpistolaVisible(epistola, {
	accademiaMembro: membroMissioni?.accademia?.slug ?? null,
	livelloMembro: membroMissioni?.livello ?? null,
	testSmistamentoCompletato,
})) {
	return Astro.redirect('/404');
}
---

<Layout lang={lang} theme={theme} accademia={accademia}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell epistle-detail-page">
		<article class="container-xl tsbs-app-container epistle-detail" aria-labelledby="epistle-detail-title">
			<h1 id="epistle-detail-title" class="tsbs-accent-title epistle-detail__title">{epistola.titolo}</h1>

			<div class="epistle-detail__body">
				<RitchText block={epistola.contenuto} className="epistle-detail__richtext" />
			</div>
		</article>
	</main>
</Layout>
