---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { getEpistole } from '../../lib/strapi/epistole';
import { resolveUserContext } from '../../lib/theme';

const { lang = 'it' } = Astro.props;

if (!Astro.cookies.has('jwt')) {
	return Astro.redirect('/');
}

const { theme, accademia } = await resolveUserContext(Astro.cookies.get('jwt')?.value);

const epistole = await getEpistole();
const featuredEpistola = epistole[0] || null;
const archiveEpistole = epistole.slice(1);

function getPlainText(value: string | null) {
	if (!value) return '';

	return value
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/`([^`]+)`/g, '$1')
		.replace(/!\[[^\]]*\]\([^)]*\)/g, ' ')
		.replace(/\[([^\]]+)\]\([^)]*\)/g, '$1')
		.replace(/[#>*_\-~]/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();
}

function getExcerpt(value: string | null, maxLength = 130) {
	const plainText = getPlainText(value);

	if (plainText.length <= maxLength) return plainText;

	return `${plainText.slice(0, maxLength).trim()}...`;
}

function formatEpistolaDate(value?: string | null) {
	if (!value) return '';

	const date = new Date(value);
	if (Number.isNaN(date.getTime())) return '';

	return new Intl.DateTimeFormat('it-IT', {
		day: 'numeric',
		month: 'long',
		year: 'numeric',
	}).format(date);
}

function getPrimaryCategory(epistola: typeof epistole[number]) {
	return epistola.categorie_epistola?.[0]?.nome || "L'EPISTOLA";
}
---

<Layout lang={lang} theme={theme} accademia={accademia}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell missions-shell epistole-page">
		<header class="missions-header epistole-header">
			<h1>Epistole</h1>
		</header>

		<div class="container-xl tsbs-app-container epistole-content">
			{featuredEpistola && (
				<section class="tsbs-card epistole-featured" aria-labelledby="epistole-featured-title">
					<div class="epistole-featured__copy">
						<p class="epistole-eyebrow">{getPrimaryCategory(featuredEpistola)}</p>
						<h2 id="epistole-featured-title">{featuredEpistola.titolo}</h2>
						<p>{getExcerpt(featuredEpistola.contenuto, 150)}</p>
					</div>
					<a class="btn tsbs-cta-primary epistole-featured__button" href={`/epistole/${featuredEpistola.slug}/`}>
						Leggi Epistola
					</a>
				</section>
			)}

			<section class="epistole-archive" aria-labelledby="epistole-archive-title">
				<h2 id="epistole-archive-title" class="tsbs-section-title">Archivio Epistole</h2>

				<div class="epistole-list">
					{archiveEpistole.map((epistola, index) => (
						<a class={`epistole-card ${index >= 3 ? 'is-hidden' : ''}`} href={`/epistole/${epistola.slug}/`} data-epistole-card>
							<p class="epistole-card__meta">{formatEpistolaDate(epistola.publishedAt)}</p>
							<h3>{epistola.titolo}</h3>
							<p>{getExcerpt(epistola.contenuto)}</p>
						</a>
					))}
				</div>

				{archiveEpistole.length > 0 && (
					<button class="missions-load-more epistole-load-more" type="button" data-epistole-load-more aria-controls="epistole-archive-title">
						<span>Carica altro</span>
						<i class="bi bi-arrow-right" aria-hidden="true"></i>
					</button>
				)}
			</section>
		</div>
	</main>

	<script>
		const getEpistoleBatchSize = () => {
			if (window.matchMedia('(min-width: 992px)').matches) return 5;
			if (window.matchMedia('(min-width: 768px)').matches) return 4;
			return 3;
		};

		const setupEpistoleArchive = () => {
			const cards = [...document.querySelectorAll<HTMLElement>('[data-epistole-card]')];
			const loadMoreButton = document.querySelector<HTMLButtonElement>('[data-epistole-load-more]');
			if (!loadMoreButton) return;

			const batchSize = getEpistoleBatchSize();
			let visibleCount = Number(loadMoreButton.dataset.visibleCount || batchSize);
			visibleCount = Math.max(batchSize, visibleCount);

			const updateCards = () => {
				cards.forEach((card, index) => {
					card.classList.toggle('is-hidden', index >= visibleCount);
				});

				loadMoreButton.hidden = visibleCount >= cards.length;
				loadMoreButton.dataset.visibleCount = String(visibleCount);
			};

			loadMoreButton.onclick = () => {
				visibleCount += batchSize;
				updateCards();
			};

			updateCards();
		};

		document.addEventListener('astro:page-load', setupEpistoleArchive);
		setupEpistoleArchive();
	</script>
</Layout>
