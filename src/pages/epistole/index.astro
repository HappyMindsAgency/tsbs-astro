---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import FiltroEpistole from '../../lib/filtri/FiltroEpistole.astro';
import { getEpistole } from '../../lib/strapi/epistole';
import { getMembroMissioniByJwt } from '../../lib/strapi/missioni';
import { resolveUserContext } from '../../lib/theme';

const { lang = 'it' } = Astro.props;

if (!Astro.cookies.has('jwt')) {
	return Astro.redirect('/');
}

const jwt = Astro.cookies.get('jwt')?.value;
const { theme, accademia } = await resolveUserContext(jwt);

const [epistole, membroMissioni] = await Promise.all([
	getEpistole(),
	jwt ? getMembroMissioniByJwt(jwt) : Promise.resolve(null),
]);
const testSmistamentoCompletato = Boolean(membroMissioni?.accademia);
---

<Layout lang={lang} theme={theme} accademia={accademia}>
	<Nav lang={lang} />

	<main class="tsbs-app-shell missions-shell epistole-page">
		<header class="missions-header epistole-header">
			<h1>Epistole</h1>
		</header>

		<div class="container-xl tsbs-app-container epistole-content">
			<FiltroEpistole
				epistole={epistole}
				accademiaMembro={membroMissioni?.accademia?.slug ?? null}
				livelloMembro={membroMissioni?.livello ?? null}
				testSmistamentoCompletato={testSmistamentoCompletato}
			/>
		</div>
	</main>

	<script>
		const getEpistoleBatchSize = () => {
			if (window.matchMedia('(min-width: 992px)').matches) return 5;
			if (window.matchMedia('(min-width: 768px)').matches) return 4;
			return 3;
		};

		const setupEpistoleArchive = () => {
			const cards = [...document.querySelectorAll<HTMLElement>('[data-epistole-card]')];
			const loadMoreButton = document.querySelector<HTMLButtonElement>('[data-epistole-load-more]');
			if (!loadMoreButton) return;

			const batchSize = getEpistoleBatchSize();
			let visibleCount = Number(loadMoreButton.dataset.visibleCount || batchSize);
			visibleCount = Math.max(batchSize, visibleCount);

			const updateCards = () => {
				cards.forEach((card, index) => {
					card.classList.toggle('is-hidden', index >= visibleCount);
				});

				loadMoreButton.hidden = visibleCount >= cards.length;
				loadMoreButton.dataset.visibleCount = String(visibleCount);
			};

			loadMoreButton.onclick = () => {
				visibleCount += batchSize;
				updateCards();
			};

			updateCards();
		};

		document.addEventListener('astro:page-load', setupEpistoleArchive);
		setupEpistoleArchive();
	</script>
</Layout>
